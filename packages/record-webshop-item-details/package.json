{
  "name": "@centralbeans/record-webshop-item-details",
  "type": "module",
  "scripts": {
    "build": "cp .yarnrc-lambda.yml .yarnrc.yml && yarn workspaces focus --production && zip -rq package.zip . -x .yarnrc.yml .yarnrc-lambda.yml && rm .yarnrc.yml",
    "deploy": "aws lambda update-function-code --function-name recordWebshopItemDetails --zip-file fileb://package.zip --publish"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.975.0",
    "@aws-sdk/client-s3": "^3.975.0",
    "@aws-sdk/client-secrets-manager": "^3.975.0",
    "@libsql/client": "^0.17.0",
    "@sentry/aws-serverless": "^10.36.0",
    "sharp": "^0.34.5"
  }
}
