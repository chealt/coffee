{
  "name": "@centralbeans/flag-removed",
  "type": "module",
  "scripts": {
    "build": "cp .yarnrc-lambda.yml .yarnrc.yml && yarn workspaces focus --production && zip -rq package.zip . -x .yarnrc.yml .yarnrc-lambda.yml && rm .yarnrc.yml",
    "deploy": "aws lambda update-function-code --function-name flagRemoved --zip-file fileb://package.zip --publish"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1029.0",
    "@libsql/client": "^0.17.2",
    "@sentry/aws-serverless": "^10.48.0",
    "jsdom": "27.0.0",
    "undici": "^8.0.2"
  }
}
