{
  "$schema": "https://json.schemastore.org/web-manifest-combined.json",
  "short_name": "Central Beans",
  "name": "Central Beans - Specialty Coffee Explorer",
  "description": "Explore the world of coffee and collect your favorites.",
  "icons": [
    {
      "src": "/favicon.svg",
      "type": "image/svg+xml",
      "sizes": "32x32"
    },
    {
      "src": "/favicons/favicon-96x96.svg",
      "type": "image/svg+xml",
      "sizes": "96x96"
    },
    {
      "src": "/favicons/favicon-128x128.svg",
      "type": "image/svg+xml",
      "sizes": "128x128"
    },
    {
      "src": "/favicons/favicon-192x192.svg",
      "type": "image/svg+xml",
      "sizes": "192x192"
    },
    {
      "src": "/favicons/favicon-256x256.svg",
      "type": "image/svg+xml",
      "sizes": "256x256"
    },
    {
      "src": "/favicons/favicon-512x512.svg",
      "type": "image/svg+xml",
      "sizes": "512x512"
    },
    {
      "src": "/favicons/favicon-1024x1024.svg",
      "type": "image/svg+xml",
      "sizes": "1024x1024"
    }
  ],
  "screenshots": [
    {
      "src": "/screenshots/mobile.png",
      "sizes": "1442x3202",
      "type": "image/png",
      "label": "Home screen showing coffee roasters."
    },
    {
      "src": "/screenshots/desktop.png",
      "sizes": "2560x1328",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Home screen showing coffee roasters."
    }
  ],
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "orientation": "portrait-primary",
  "background_color": "#000000",
  "theme_color": "#f1e3cd",
  "prefer_related_applications": false,
  "shortcuts": [
    {
      "name": "Collections",
      "url": "/collections"
    },
    {
      "name": "Settings",
      "url": "/settings"
    }
  ]
}
