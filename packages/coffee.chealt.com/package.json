{
  "name": "@centralbeans/website",
  "homepage": "https://github.com/chealt/coffee",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chealt/coffee.git"
  },
  "type": "module",
  "scripts": {
    "add:logos": "node --env-file=.env data/addLogos.js",
    "build": "astro build",
    "dev": "AWS_PROFILE=centralbeans.com astro dev",
    "export:translations": "node --env-file=.env data/i18n.js",
    "export:data": "node --env-file=.env data/export.js",
    "export:data:ci": "node data/export.js",
    "import": "node --env-file=.env data/importData.js",
    "import:logos": "node data/importLogos.js",
    "preview": "astro build && wrangler pages dev ./dist",
    "recommendations": "node --env-file=.env data/recommendations/generate.js",
    "recommendations:ci": "node data/recommendations/generate.js",
    "test": "playwright test"
  },
  "dependencies": {
    "@astrojs/cloudflare": "12.6.13",
    "@aws-sdk/client-lambda": "^3.1086.0",
    "@aws-sdk/client-s3": "^3.1086.0",
    "@aws-sdk/s3-request-presigner": "^3.1086.0",
    "@libsql/client": "^0.17.4",
    "@playwright-testing-library/test": "^4.5.0",
    "@playwright/test": "^1.61.1",
    "@sentry/astro": "^10.65.0",
    "@sentry/cloudflare": "^10.65.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "@tursodatabase/api": "^2.0.5",
    "astro": "7.1.0",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "axe-html-reporter": "^2.2.11",
    "navigation-api-types": "^0.6.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "vite": "8.1.4",
    "wrangler": "^4.110.0"
  },
  "engines": {
    "node": ">=24"
  }
}
