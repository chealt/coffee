---
import { getRelativeLocaleUrl } from "astro:i18n";

import Button from "../form/button/button.astro";
import Form from "../form/form.astro";
import Icon from "../icon/icon.astro";
import Input from "../form/input/input.astro";
import Label from "../form/label/label.astro";

import APIButton from "@components/common/api-button.astro";
import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

import "./login.css";

const t = await getTranslator({
  filePath: "login",
  locale: Astro.currentLocale,
});

const { username, redirectUrl } = Astro.props;
---

<div class="login-page">
  <h1><T namespace="login.locales" key="title">{t("title")}</T></h1>
  <chealt-auth-login
    data-authentication-options={Astro.locals.authenticationOptions}
    data-authentication-options-endpoint="/api/authentication/login/options.json"
    data-verify-endpoint="/api/authentication/login/verify.json"
    data-redirect-url={redirectUrl || "/"}
  >
    <Form name="login" data-storage="localStorage" data-save-on-input>
      <section>
        <Label>
          {t("usernameOrEmail")}
          <Input
            type="text"
            name="username"
            autocomplete="username"
            value={username}
            readonly={Boolean(username)}
            disabled={Boolean(username)}
            required
          />
        </Label>
        <p data-error-code="API_CALL_FAILED" class="error hidden">
          <T namespace="login.locales" key="apiCallFailed"
            >{t("apiCallFailed")}</T
          >
        </p>
        <p data-error-code="USER_NOT_FOUND" class="error hidden">
          <T namespace="login.locales" key="userNotFound">{t("userNotFound")}</T
          >
        </p>
        <p
          data-error-code="CANNOT_GET_AUTHENTICATION_OPTIONS"
          class="error hidden"
        >
          <T namespace="login.locales" key="cannotGetAuthenticationOptions"
            >{t("cannotGetAuthenticationOptions")}</T
          >
        </p>
        <p data-error-code="RATE_LIMIT_EXCEEDED" class="error hidden">
          <T namespace="login.locales" key="rateLimitExceeded"
            >{t("rateLimitExceeded")}</T
          >
        </p>
      </section>
      <section>
        <APIButton
          inputsToSend="username"
          apiEndpoint="/api/authentication/registration/send-new-code.json"
        >
          <Button class="bordered column">
            <span
              ><T namespace="login.locales" key="sendRegistrationCode"
                >{t("sendRegistrationCode")}</T
              ></span
            >
            <Icon type="email" />
          </Button>
        </APIButton>
      </section>
      <section>
        <Button class="primary" type="submit"
          ><T namespace="login.locales" key="login">{t("login")}</T></Button
        >
      </section>
    </Form>
  </chealt-auth-login>
  <section>
    <Button
      class="bordered"
      href={getRelativeLocaleUrl(Astro.currentLocale, `/registration/new-user`)}
    >
      <T namespace="login.locales" key="register">{t("register")}</T>
    </Button>
  </section>
</div>

<script src="../chealt-auth-login.js"></script>
