---
import { getRelativeLocaleUrl } from 'astro:i18n';

import T from '@components/i18n/t.astro';
import { getTranslator } from '@components/i18n/t.js';
import Common from '../common/common.astro';

const t = await getTranslator({
  filePath: 'you',
  locale: Astro.currentLocale,
});

const { shouldAuthenticate } = Astro.locals;
const { notificationType } = Astro.params;
---

<Common
  shouldAuthenticate={shouldAuthenticate}
  redirectUrl={getRelativeLocaleUrl(Astro.currentLocale, `/you/unsubscribe/${notificationType}`)}
>
  <h1><T namespace="you.locales" key="unsubscribedTitle">{t("unsubscribedTitle")}</T></h1>
  <section><T namespace="you.locales" key="unsubscribed">{t("unsubscribed")}</T></section>
</Common>
