---
import { getRelativeLocaleUrl } from "astro:i18n";

import exchangeRates from "@data/exchangeRates.json" with { type: "json" };
import supportedLanguages from "@data/supportedLanguages.json" with { type: "json" };

import T from "@components/i18n/t.astro";
import { capitalize } from "../../../utils/string.js";
import Button from "../../form/button/button.astro";
import Checkbox from "../../form/checkbox/checkbox.astro";
import Common from "../../common/common.astro";
import Form from "../../form/form.astro";
import Icon from "../../icon/icon.astro";
import Label from "../../form/label/label.astro";
import Logout from "../../logout/logout.astro";
import Select from "../../form/select/select.astro";

import allLocaleTranslations from "./locales.json" with { type: "json" };

const t =
  allLocaleTranslations[Astro.currentLocale] || allLocaleTranslations["en"];

const {
  shouldAuthenticate,
  currency: selectedCurrency,
  settings,
  canTranslate,
} = Astro.locals;

const currencies = exchangeRates.map(({ currency_code }) => currency_code);
---

<Common
  shouldAuthenticate={shouldAuthenticate}
  redirectUrl={getRelativeLocaleUrl(Astro.currentLocale, "/you/profile")}
>
  <h1><T namespace="you.profile.locales" key="title">{t.title}</T></h1>
  <section>
    <Form
      name="settings"
      data-storage="api"
      data-save-endpoint="/api/storage/save-form-data"
      data-save-on-input
      data-exclude-from-local-storage
    >
      <p data-error-code="RATE_LIMIT_EXCEEDED" class="error hidden">
        {t.rateLimitExceeded}
      </p>
      <Label>
        <div class="name">{t.language}</div>
        <Select name="language">
          {
            supportedLanguages.map(({ locale, label }) => (
              <option value={locale} selected={locale === Astro.currentLocale}>
                {capitalize(label)}
              </option>
            ))
          }
        </Select>
      </Label>
      <Label>
        <div class="name">{t.currency}</div>
        <Select name="currency">
          {
            currencies.map((currency) => (
              <option value={currency} selected={currency === selectedCurrency}>
                {currency}
              </option>
            ))
          }
        </Select>
      </Label>
      {
        canTranslate && (
          <Checkbox
            name="isTranslating"
            value="on"
            checked={settings?.isTranslating === "on"}
          >
            {t.isTranslating}
          </Checkbox>
        )
      }
      <fieldset>
        <legend>
          <div class="name">{t.notifications}</div>
        </legend>
        <Checkbox
          name="newCoffeeNotification"
          value="on"
          checked={settings?.newCoffeeNotification === "on"}
        >
          {t.newCoffee}
        </Checkbox>
      </fieldset>
      <coffee-api-button
        data-api-endpoint="/api/authentication/registration/send-new-code.json?profile"
      >
        <Button class="bordered column">
          <span>{t.sendRegistrationCode}</span>
          <Icon type="email" />
        </Button>
      </coffee-api-button>
    </Form>
  </section>
  <section>
    <Logout logoutUrl="/api/authentication/logout.json">
      <Button class="danger column" data-logout-trigger>
        <Icon type="power" />
        <span>{t.logout}</span>
      </Button>
    </Logout>
  </section>
</Common>

<script src="../../common/api-button.js"></script>
