---
import { getRelativeLocaleUrl } from 'astro:i18n';
import Button from '../../../../form/button/button.astro';
import CoffeeImageUpload from '../../../../common/coffee-image-upload.astro';
import Dialog from '../../../../dialog/dialog.astro';
import Icon from '../../../../icon/icon.astro';

import './controls.css';

import allLocaleTranslations from './locales.json';

const t = allLocaleTranslations[Astro.currentLocale];

const { collectionId, isFavorite, itemId } = Astro.props;
---

<div class="controls">
  <coffee-controls
    data-item-id={itemId}
    data-collections-url={getRelativeLocaleUrl(Astro.currentLocale, '/you/collections')}
  >
    <Button class="favorite">
      <Icon type="favorite" class=`${isFavorite ? 'active' : ''}` />
      <span>{t.favorite}</span>
    </Button>
  </coffee-controls>
  <CoffeeImageUpload data-collection-id={collectionId} data-item-id={itemId}>
    <Button class="add triggerButton" href={getRelativeLocaleUrl(Astro.currentLocale, '/you/collections')}>
      <Icon type="add" />
      <span>{t.add}</span>
    </Button>
  </CoffeeImageUpload>
  <Button class="more" data-dialog-id={`collection-item-menu-${collectionId}-${itemId}`}>
    <Icon type="menu" />
    <span>{t.more}</span>
  </Button>
  <Dialog class="drawer" id={`collection-item-menu-${collectionId}-${itemId}`}>
    <ul>
      <li>
        <Button
          class="column danger"
          data-delete-trigger
          for={itemId}
          data-redirect-url={getRelativeLocaleUrl(Astro.currentLocale, '/you/collections')}
          data-dont-remove-element
          data-dont-close-dialog
        >
          <Icon type="delete" />
          {t.delete}
        </Button>
      </li>
    </ul>
  </Dialog>
</div>

<!-- add CoffeeImageUpload script, without this import it won't work -->
<script src="../../../../common/coffee-image-upload.js"></script>
<script src="./controls.js"></script>
