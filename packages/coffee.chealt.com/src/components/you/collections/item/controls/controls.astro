---
import { getRelativeLocaleUrl } from "astro:i18n";
import Button from "../../../../form/button/button.astro";
import Checkbox from "../../../../form/checkbox/checkbox.astro";
import CoffeeImageUpload from "../../../../common/coffee-image-upload.astro";
import Dialog from "../../../../dialog/dialog.astro";
import Icon from "../../../../icon/icon.astro";

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

import "./controls.css";

const t = await getTranslator({
  filePath: "you/collections/item/controls",
  locale: Astro.currentLocale,
});

const { collectionId, itemId } = Astro.props;

const { collectionItem, collections } = Astro.locals;
---

<coffee-controls
  class="controls"
  data-item-id={itemId}
  data-collections-url={getRelativeLocaleUrl(
    Astro.currentLocale,
    "/you/collections",
  )}
>
  <Button class="favorite">
    <Icon
      type="favorite"
      class=`${collectionItem.isFavorite ? 'active' : ''}`
    />
    <span
      ><T namespace="you.collections.item.controls.locales" key="favorite"
        >{t("favorite")}</T
      ></span
    >
  </Button>
  <CoffeeImageUpload data-collection-id={collectionId} data-item-id={itemId}>
    <Button
      class="add triggerButton"
      href={getRelativeLocaleUrl(Astro.currentLocale, "/you/collections")}
    >
      <Icon type="add" />
      <span
        ><T namespace="you.collections.item.controls.locales" key="add"
          >{t("add")}</T
        ></span
      >
    </Button>
  </CoffeeImageUpload>
  <Button
    class="more"
    data-dialog-id={`collection-item-menu-${collectionId}-${itemId}`}
  >
    <Icon type="menu" />
    <span
      ><T namespace="you.collections.item.controls.locales" key="more"
        >{t("more")}</T
      ></span
    >
  </Button>
  <Dialog class="drawer" id={`collection-item-menu-${collectionId}-${itemId}`}>
    <ul>
      <li>
        <Button class="column" for="edit-collections">
          <Icon type="edit" />
          <T namespace="you.collections.item.controls.locales" key="collections"
            >{t("collections")}</T
          >
        </Button>
        <Button
          class="column danger"
          data-delete-trigger
          for={itemId}
          data-redirect-url={getRelativeLocaleUrl(
            Astro.currentLocale,
            "/you/collections",
          )}
          data-dont-remove-element
          data-dont-close-dialog
        >
          <Icon type="delete" />
          <T namespace="you.collections.item.controls.locales" key="delete"
            >{t("delete")}</T
          >
        </Button>
      </li>
    </ul>
  </Dialog>
  <Dialog class="drawer" id="edit-collections">
    <ul data-item-id={itemId}>
      {
        collections.map(({ id, name }) => (
          <li>
            <Checkbox
              name={id}
              value={id}
              checked={collectionItem.inCollections?.includes(id)}
              disabled={
                collectionItem.inCollections?.length === 1 &&
                collectionId === id
              }
            >
              {name}
            </Checkbox>
          </li>
        ))
      }
    </ul>
  </Dialog>
</coffee-controls>

<!-- add CoffeeImageUpload script, without this import it won't work -->
<script src="../../../../common/coffee-image-upload.js"></script>
<script src="./controls.js"></script>
