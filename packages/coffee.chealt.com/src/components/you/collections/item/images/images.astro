---
import Button from "../../../../form/button/button.astro";
import Dialog from "../../../../dialog/dialog.astro";
import Icon from "../../../../icon/icon.astro";

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

import "./images.css";

const t = await getTranslator({
  filePath: "you/collections/item/images",
  locale: Astro.currentLocale,
});

const { collectionItem } = Astro.locals;
const { collectionId } = Astro.props;
---

<ul>
  <li class="picture-collection">
    {
      (collectionItem?.images.length && (
        <div class="carousel">
          {collectionItem?.images.map(
            ({ src, srcSmall, srcMedium, filename, status }, index) => (
              <picture>
                <source srcset={srcSmall} media="(max-width: 599px)" />
                <source srcset={srcMedium} media="(max-width: 1023px)" />
                <img
                  id={filename}
                  data-dialog-id={`image-dialog-${index}`}
                  src={src}
                />
                {status === "processing" && (
                  <Fragment>
                    <Button class="small round status" popovertarget="status">
                      <Icon type="info" />
                    </Button>
                    <span popover="hint" id="status" class="tooltip">
                      <T namespace="you.collections.item.images.locales" key="processing">{t("processing")}</T>
                    </span>
                  </Fragment>
                )}
              </picture>
            ),
          )}
        </div>
      )) ||
        null
    }
  </li>
</ul>
{
  collectionItem?.images.map(({ src }, index) => (
    <Dialog class="full-size-image" id={`image-dialog-${index}`} showClose>
      <img src={src} />
    </Dialog>
  ))
}
