---
import Dialog from '../../../../dialog/dialog.astro';

import './images.css';

const { collectionItem } = Astro.locals;
const { collectionId } = Astro.props;
---

<ul>
  <li class="picture-collection">
    {
      (collectionItem?.images.length && (
        <div class="carousel">
          {collectionItem?.images.map(({ src, srcSmall, srcMedium, filename }, index) => (
            <picture>
              <source srcset={srcSmall} media="(max-width: 599px)" />
              <source srcset={srcMedium} media="(max-width: 1023px)" />
              <img id={filename} data-dialog-id={`image-dialog-${index}`} src={src} />
            </picture>
          ))}
        </div>
      )) ||
        null
    }
  </li>
</ul>
{
  collectionItem?.images.map(({ src }, index) => (
    <Dialog class="full-size-image" id={`image-dialog-${index}`} showClose>
      <img src={src} />
    </Dialog>
  ))
}
