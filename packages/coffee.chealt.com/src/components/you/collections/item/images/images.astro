---
const { collectionItem } = Astro.locals;
const { collectionId } = Astro.props;
---

<ul>
  <li class="picture-collection">
    {
      collectionItem?.images.length && (
        <div class="carousel">
          {collectionItem?.images.map(({ src, filename }, index) => (
            // only the cover image should have a transition
            <img
              id={filename}
              src={src}
              style={index === 0 ? `view-transition-name: collection-${collectionId}-image-${filename}` : ''}
            />
          ))}
        </div>
      )
    }
  </li>
</ul>
