---
import { getRelativeLocaleUrl } from 'astro:i18n';

import Button from '../../../form/button/button.astro';
import Common from '../../../common/common.astro';
import Controls from './controls/controls.astro';
import Details from './details/details.astro';
import Icon from '../../../icon/icon.astro';
import Review from './review/review.astro';

import './item.css';

import allLocaleTranslations from './locales.json';

const t = allLocaleTranslations[Astro.currentLocale];

const { collectionId, itemId } = Astro.props;

const { collectionItem, shouldAuthenticate } = Astro.locals;
---

<Common
  shouldAuthenticate={shouldAuthenticate}
  redirectUrl={getRelativeLocaleUrl(Astro.currentLocale, `/you/collections/${collectionId}/items/${itemId}`)}
>
  <Button
    id="back-button"
    href={getRelativeLocaleUrl(Astro.currentLocale, '/you/collections')}
    class="small bordered"
    aria-label={t.back}
  >
    <Icon type="back" />
  </Button>
  <div
    id={collectionItem?.id}
    data-type="chealt-collection-item"
    data-delete-confirm-message={t.deleteItemConfirmMessage}
  >
    <ul>
      <li class="picture-collection">
        {
          collectionItem?.images.length && (
            <div class="carousel images-container">
              {collectionItem?.images.map(({ src, filename }) => (
                <img
                  id={filename}
                  src={src}
                  style={`view-transition-name: collection-${collectionId}-image-${filename}`}
                />
              ))}
            </div>
          )
        }
      </li>
    </ul>
    <Controls collectionId={collectionId} itemId={itemId} isFavorite={collectionItem?.isFavorite} />
    <Details />
    <Review />
    <section>
      <h1>{t.dangerZone}</h1>
      <Button
        class="column danger"
        data-delete-trigger
        for={itemId}
        data-redirect-url={getRelativeLocaleUrl(Astro.currentLocale, '/you/collections')}
        data-dont-remove-element
      >
        <Icon type="delete" />
        {t.delete}
      </Button>
    </section>
  </div>
</Common>
