---
import { getRelativeLocaleUrl } from "astro:i18n";

import Button from "../../../form/button/button.astro";
import Common from "../../../common/common.astro";
import Controls from "./controls/controls.astro";
import Details from "./details/details.astro";
import Icon from "../../../icon/icon.astro";
import Images from "./images/images.astro";
import Review from "./review/review.astro";

import "./item.css";

import allLocaleTranslations from "./locales.json" with { type: "json" };

const t =
  allLocaleTranslations[Astro.currentLocale] || allLocaleTranslations["en"];

const { collectionId, itemId } = Astro.props;

const { collectionItem, shouldAuthenticate } = Astro.locals;
---

<Common
  shouldAuthenticate={shouldAuthenticate}
  redirectUrl={getRelativeLocaleUrl(
    Astro.currentLocale,
    `/you/collections/${collectionId}/items/${itemId}`,
  )}
>
  <Button
    id="back-button"
    href={`${getRelativeLocaleUrl(Astro.currentLocale, `/you/collections`)}#item-id-${itemId}`}
    class="small bordered"
  >
    <Icon type="back" class="icon-only" />
    <span class="visually-hidden">{t.back}</span>
  </Button>
  <div
    id={collectionItem?.id}
    class="item-details"
    data-type="chealt-collection-item"
    data-delete-confirm-message={t.deleteItemConfirmMessage}
  >
    <Images collectionId={collectionId} />
    <Controls collectionId={collectionId} />
    <Details />
    <Review />
    <section>
      <h1>{t.dangerZone}</h1>
      <Button
        class="column danger"
        data-delete-trigger
        for={itemId}
        data-redirect-url={getRelativeLocaleUrl(
          Astro.currentLocale,
          "/you/collections",
        )}
        data-dont-remove-element
      >
        <Icon type="delete" />
        {t.delete}
      </Button>
    </section>
  </div>
</Common>
