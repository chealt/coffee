---
import Range from "../../../../../form/range/range.astro";
import Input from "../../../../../form/input/input.astro";
import Label from "../../../../../form/label/label.astro";
import Toggle from "../../../../../toggle/toggle.astro";

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

import "./geek-zone.css";

const t = await getTranslator({
  filePath: "you/collections/item/review/geek-zone",
  locale: Astro.currentLocale,
});

const {
  collectionItem: { review },
} = Astro.locals;
---

<Toggle>
  <span slot="trigger"><T namespace="you.collections.item.review.geek-zone.locales" key="geek-zone">{t("geek-zone")}</T></span>
  <div slot="content" id="geek-zone-container" data-content>
    <div class="range-group">
      <Range
        name="roast-level"
        min="1"
        max="5"
        excludeFromSum
        value={review?.["roast-level"]}
      >
        <span slot="title"><T namespace="you.collections.item.review.geek-zone.locales" key="roast-level">{t("roast-level")}</T></span>
        <span slot="min"><T namespace="you.collections.item.review.geek-zone.locales" key="light">{t("light")}</T></span>
        <span slot="max"><T namespace="you.collections.item.review.geek-zone.locales" key="dark">{t("dark")}</T></span>
      </Range>
    </div>
    <div class="range-group">
      <div class="range-group-item">
        <Range name="aroma" min="6" max="10" value={review?.aroma}>
          <span slot="title"><T namespace="you.collections.item.review.geek-zone.locales" key="fragrance-aroma">{t("fragrance-aroma")}</T></span>
          <span slot="min">{6}</span>
          <span slot="max">{10}</span>
        </Range>
      </div>
      <div class="range-group-item">
        <Range name="dry" min="1" max="5" excludeFromSum value={review?.dry}>
          <span slot="title"><T namespace="you.collections.item.review.geek-zone.locales" key="dry">{t("dry")}</T></span>
          <span slot="min">{1}</span>
          <span slot="max">{5}</span>
        </Range>
        <Range
          name="break"
          min="1"
          max="5"
          excludeFromSum
          value={review?.break}
        >
          <span slot="title"><T namespace="you.collections.item.review.geek-zone.locales" key="break">{t("break")}</T></span>
          <span slot="min">{1}</span>
          <span slot="max">{5}</span>
        </Range>
      </div>
    </div>
    <div class="range-group">
      <Range name="flavour" min="6" max="10" value={review?.flavour}>
        <span slot="title"><T namespace="you.collections.item.review.geek-zone.locales" key="flavour">{t("flavour")}</T></span>
        <span slot="min">{6}</span>
        <span slot="max">{10}</span>
      </Range>
      <Range name="aftertaste" min="6" max="10" value={review?.aftertaste}>
        <span slot="title"><T namespace="you.collections.item.review.geek-zone.locales" key="aftertaste">{t("aftertaste")}</T></span>
        <span slot="min">{6}</span>
        <span slot="max">{10}</span>
      </Range>
    </div>
    <div class="range-group">
      <Range
        name="intensity"
        min="1"
        max="5"
        excludeFromSum
        value={review?.intensity}
      >
        <span slot="title"><T namespace="you.collections.item.review.geek-zone.locales" key="intensity">{t("intensity")}</T></span>
        <span slot="min"><T namespace="you.collections.item.review.geek-zone.locales" key="low">{t("low")}</T></span>
        <span slot="max"><T namespace="you.collections.item.review.geek-zone.locales" key="high">{t("high")}</T></span>
      </Range>
    </div>
    <div class="range-group">
      <Range name="body" min="6" max="10" value={review?.body}>
        <span slot="title"><T namespace="you.collections.item.review.geek-zone.locales" key="body">{t("body")}</T></span>
        <span slot="min">{6}</span>
        <span slot="max">{10}</span>
      </Range>
      <Range name="level" min="1" max="5" excludeFromSum value={review?.level}>
        <span slot="title"><T namespace="you.collections.item.review.geek-zone.locales" key="level">{t("level")}</T></span>
        <span slot="min"><T namespace="you.collections.item.review.geek-zone.locales" key="thin">{t("thin")}</T></span>
        <span slot="max"><T namespace="you.collections.item.review.geek-zone.locales" key="heavy">{t("heavy")}</T></span>
      </Range>
    </div>
    <div class="range-group">
      <Range name="uniformity" min="6" max="10" value={review?.uniformity}>
        <span slot="title"><T namespace="you.collections.item.review.geek-zone.locales" key="uniformity">{t("uniformity")}</T></span>
        <span slot="min">{6}</span>
        <span slot="max">{10}</span>
      </Range>
      <Range name="balance" min="6" max="10" value={review?.balance}>
        <span slot="title"><T namespace="you.collections.item.review.geek-zone.locales" key="balance">{t("balance")}</T></span>
        <span slot="min">{6}</span>
        <span slot="max">{10}</span>
      </Range>
    </div>
    <div class="range-group">
      <Range name="clean-cup" min="6" max="10" value={review?.["clean-cup"]}>
        <span slot="title"><T namespace="you.collections.item.review.geek-zone.locales" key="clean-cup">{t("clean-cup")}</T></span>
        <span slot="min">{6}</span>
        <span slot="max">{10}</span>
      </Range>
    </div>
    <div class="range-group">
      <Range name="overall" min="6" max="10" value={review?.overall}>
        <span slot="title"><T namespace="you.collections.item.review.geek-zone.locales" key="overall">{t("overall")}</T></span>
        <span slot="min">{6}</span>
        <span slot="max">{10}</span>
      </Range>
      <fieldset class="range-group-item-container">
        <legend><T namespace="you.collections.item.review.geek-zone.locales" key="defects">{t("defects")}</T></legend>
        <div class="range-group-item-container">
          <Label>
            <span><T namespace="you.collections.item.review.geek-zone.locales" key="number-of-cups">{t("number-of-cups")}</T></span>
            <Input
              name="number-of-cups"
              data-negative
              type="number"
              value={review?.["number-of-cups"]}
            />
          </Label>
          <span class="times-sign">x</span>
          <Label>
            <span><T namespace="you.collections.item.review.geek-zone.locales" key="intensity">{t("intensity")}</T></span>
            <Input
              name="defects-intensity"
              data-multiplier="number-of-cups"
              type="number"
              value={review?.["defects-intensity"]}
            />
          </Label>
        </div>
      </fieldset>
    </div>
    <Label>
      <span><T namespace="you.collections.item.review.geek-zone.locales" key="notes">{t("notes")}</T></span>
      <Input name="notes" type="text" />
    </Label>
    <div class="final-score-container">
      <span><T namespace="you.collections.item.review.geek-zone.locales" key="final-score">{t("final-score")}</T></span>
      <span class="final-score" data-sum="geek-zone"></span>
    </div>
  </div>
</Toggle>
