---
import Button from "../../../../form/button/button.astro";
import GeekZone from "./geek-zone/geek-zone.astro";
import Form from "../../../../form/form.astro";
import Icon from "../../../../icon/icon.astro";
import RadioList from "../../../../form/radio/radio-list.astro";
import Radio from "../../../../form/radio/radio.astro";
import Range from "../../../../form/range/range.astro";

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

import "./review.css";

const t = await getTranslator({
  filePath: "you/collections/item/review",
  locale: Astro.currentLocale,
});

const {
  collectionItem: { id, review },
} = Astro.locals;
---

<section>
  <h1><T namespace="you.collections.item.review.locales" key="review">{t("review")}</T></h1>
  <Form
    class="review-form"
    name={`${id}.review`}
    data-storage="api"
    data-save-endpoint="/api/storage/save-form-data"
    data-save-on-input
    data-sum-group-name="geek-zone"
  >
    <RadioList>
      <Radio name="like" value="like" checked={review?.like === "like"}>
        <Icon type="thumbs-up--filled" />
        <T namespace="you.collections.item.review.locales" key="like">{t("like")}</T>
      </Radio>
      <Radio name="like" value="dislike" checked={review?.like === "dislike"}>
        <Icon type="thumbs-down--filled" />
        <T namespace="you.collections.item.review.locales" key="dislike">{t("dislike")}</T>
      </Radio>
    </RadioList>
    <Range name="acidity" min="6" max="10" value={review?.acidity}>
      <span slot="title"><T namespace="you.collections.item.review.locales" key="acidity">{t("acidity")}</T></span>
      <span slot="min"><T namespace="you.collections.item.review.locales" key="bitter">{t("bitter")}</T></span>
      <span slot="max"><T namespace="you.collections.item.review.locales" key="acidic">{t("acidic")}</T></span>
    </Range>
    <Range name="sweetness" min="6" max="10" value={review?.sweetness}>
      <span slot="title"><T namespace="you.collections.item.review.locales" key="sweetness">{t("sweetness")}</T></span>
      <span slot="min"><T namespace="you.collections.item.review.locales" key="sour">{t("sour")}</T></span>
      <span slot="max"><T namespace="you.collections.item.review.locales" key="sweet">{t("sweet")}</T></span>
    </Range>
    <Range name="strength" excludeFromSum value={review?.strength}>
      <span slot="min"><T namespace="you.collections.item.review.locales" key="weak">{t("weak")}</T></span>
      <span slot="max"><T namespace="you.collections.item.review.locales" key="strong">{t("strong")}</T></span>
    </Range>
    <GeekZone />
  </Form>
</section>
