---
import { titleCase } from "../../../../../utils/string.js";
import Label from "../../../../form/label/label.astro";
import Select from "../../../../form/select/select.astro";

import originRegions from "../../../../../../data/originRegions.json" with { type: "json" };

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

const t = await getTranslator({
  filePath: "you/collections/item/details",
  locale: Astro.currentLocale,
});

const { selected } = Astro.props;
---

<Label>
  <div class="name">
    <T namespace="you.collections.item.details.locales" key="originRegion">{t("originRegion")}</T>
  </div>
  <Select name="originRegion" showEmpty>
    {
      originRegions
        .filter(({ language_code }) => language_code === Astro.currentLocale)
        .map(({ origin_region_id, name }) => (
          <option
            value={origin_region_id}
            selected={String(origin_region_id) === String(selected)}
          >
            {titleCase(name)}
          </option>
        ))
    }
  </Select>
</Label>
