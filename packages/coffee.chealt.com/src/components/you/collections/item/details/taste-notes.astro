---
import { getRelativeLocaleUrl } from "astro:i18n";

import tasteNotes from "../../../../../../data/tasteNotes.json" with { type: "json" };

import Button from "../../../../form/button/button.astro";
import Checkbox from "../../../../form/checkbox/checkbox.astro";
import Dialog from "../../../../dialog/dialog.astro";
import Icon from "../../../../icon/icon.astro";
import Input from "../../../../form/input/input.astro";
import Label from "../../../../form/label/label.astro";
import TasteNotes from "../../../../taste-notes/taste-notes.astro";

import { getTasteNoteGroupByNoteId } from "../../../../taste-notes/utils.js";

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

const t = await getTranslator({
  filePath: "you/collections/item/details",
  locale: Astro.currentLocale,
});

const { selected } = Astro.props;

const selectedTasteNotes = tasteNotes
  .filter(
    ({ taste_note_id: id, language_code: languageCode }) =>
      selected?.map((selectedId) => String(selectedId)).includes(String(id)) &&
      languageCode === Astro.currentLocale,
  )
  .map((tasteNote) => ({
    ...tasteNote,
    group: getTasteNoteGroupByNoteId(tasteNote.taste_note_id),
  }));
const notSelectedTasteNotes = tasteNotes
  .filter(
    ({ language_code: languageCode }) => languageCode === Astro.currentLocale,
  )
  .filter(
    ({ taste_note_id: id, language_code: languageCode }) =>
      !selected?.includes(String(id)),
  )
  .map((tasteNote) => ({
    ...tasteNote,
    group: getTasteNoteGroupByNoteId(tasteNote.taste_note_id),
  }));
---

<Label class="taste-notes-section">
  <div class="name">
    <T namespace="you.collections.item.details.locales" key="tasteNotes">{t("tasteNotes")}</T>
  </div>
  <Button data-dialog-id="edit-taste-notes" class="column input">
    <Icon type="edit" />
    <T namespace="you.collections.item.details.locales" key="select">{t("select")}</T>
  </Button>
  <div
    data-update-keys="[name='tasteNoteIds[]']"
    data-api-endpoint={getRelativeLocaleUrl(
      Astro.currentLocale,
      "/taste-notes",
    )}
  >
    {
      (selectedTasteNotes.length && (
        <TasteNotes tasteNotes={selectedTasteNotes} />
      )) ||
        null
    }
  </div>
</Label>
<Dialog class="drawer fixed" id="edit-taste-notes">
  <chealt-filter data-filter-selector="li:has(input[name='tasteNoteIds[]'])">
    <Input name="taste-note-filter" placeholder={t("search")} data-exclude />
  </chealt-filter>
  <ul>
    {
      selectedTasteNotes.map(({ taste_note_id: id, name, group }) => (
        <li
          style={
            group?.color
              ? `border-left: 4px solid ${group.color}`
              : "border-left: 4px solid transparent"
          }
        >
          <Checkbox name="tasteNoteIds[]" value={id} checked>
            {name}
          </Checkbox>
        </li>
      ))
    }
    {
      notSelectedTasteNotes.map(({ taste_note_id: id, name, group }) => (
        <li
          style={
            group?.color
              ? `border-left: 4px solid ${group.color}`
              : "border-left: 4px solid transparent"
          }
        >
          <Checkbox name="tasteNoteIds[]" value={id}>
            {name}
          </Checkbox>
        </li>
      ))
    }
  </ul>
</Dialog>

<script src="../../../../chealt-filter.js"></script>
