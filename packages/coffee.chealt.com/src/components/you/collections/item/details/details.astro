---
import Button from '../../../../form/button/button.astro';
import Form from '../../../../form/form.astro';

import BrewingMethods from './brewing-methods.astro';
import Decaf from './decaf.astro';
import OriginCountries from './origin-countries.astro';
import OriginRegions from './origin-regions.astro';
import ProcessingMethods from './processing-methods.astro';
import Roasters from './roasters.astro';
import RoastingDate from './roasting-date.astro';
import RoastingLevels from './roasting-levels.astro';
import TasteNotes from './taste-notes.astro';
import Varieties from './varieties.astro';

import allLocaleTranslations from './locales.json';

const t = allLocaleTranslations[Astro.currentLocale];

const {
  collectionItem: { id, details, extractedDetails }
} = Astro.locals;
console.log(extractedDetails);
---

<section>
  <h1>{t.details}</h1>
  <Form name={`${id}.details`} data-storage="api" data-save-endpoint="/api/storage/save-form-data" data-save-on-input>
    <Roasters selected={details?.roaster || extractedDetails?.roaster} />
    <RoastingLevels selected={details?.roastingLevel} />
    <RoastingDate value={details?.roastingDate} />
    <OriginCountries selected={details?.originCountry || extractedDetails?.originCountry} />
    <OriginRegions selected={details?.originRegion || extractedDetails?.originRegion} />
    <Varieties selected={details?.['varieties[]'] || extractedDetails?.['varieties[]']} />
    <ProcessingMethods selected={details?.processingMethod || extractedDetails?.processingMethod} />
    <BrewingMethods selected={details?.brewingMethod || extractedDetails?.brewingMethod} />
    <TasteNotes selected={details?.['tasteNoteIds[]'] || extractedDetails?.['tasteNoteIds[]']} />
    <Decaf checked={details?.isDecaf} />
  </Form>
</section>
