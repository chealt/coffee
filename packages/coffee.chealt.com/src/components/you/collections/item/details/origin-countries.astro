---
import { capitalize } from "../../../../../utils/string.js";
import Label from "../../../../form/label/label.astro";
import Select from "../../../../form/select/select.astro";

import originCountries from "../../../../../../data/originCountries.json" with { type: "json" };

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

const t = await getTranslator({
  filePath: "you/collections/item/details",
  locale: Astro.currentLocale,
});

const { selected } = Astro.props;
---

<Label>
  <div class="name">
    <T namespace="you.collections.item.details.locales" key="originCountry">{t("originCountry")}</T>
  </div>
  <Select name="originCountry" showEmpty>
    {
      originCountries
        .filter(({ language_code }) => language_code === Astro.currentLocale)
        .map(({ origin_country_id, name }) => (
          <option
            value={origin_country_id}
            selected={String(origin_country_id) === String(selected)}
          >
            {capitalize(name)}
          </option>
        ))
    }
  </Select>
</Label>
