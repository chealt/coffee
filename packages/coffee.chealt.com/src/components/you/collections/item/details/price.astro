---
import exchangeRates from "@data/exchangeRates.json" with { type: "json" };

import Input from "../../../../form/input/input.astro";
import Label from "../../../../form/label/label.astro";
import Select from "../../../../form/select/select.astro";

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

const t = await getTranslator({
  filePath: "you/collections/item/details",
  locale: Astro.currentLocale,
});

const { price, selectedCurrency } = Astro.props;
const { currency: profileCurrency } = Astro.locals;

const currencies = exchangeRates.map(({ currency_code }) => currency_code);
---

<Label>
  <div class="name">
    <T namespace="you.collections.item.details.locales" key="price">{t("price")}</T>
  </div>
  <div class="inputs">
    <Input name="price" type="number" value={price} />
    <Select name="currency">
      {
        currencies.map((currency) => (
          <option
            value={currency}
            selected={currency === (selectedCurrency || profileCurrency)}
          >
            {currency}
          </option>
        ))
      }
    </Select>
  </div>
</Label>
