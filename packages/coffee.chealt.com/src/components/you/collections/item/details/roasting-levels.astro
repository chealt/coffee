---
import Label from "../../../../form/label/label.astro";
import Select from "../../../../form/select/select.astro";

import roastingLevels from "../../../../../../data/roastingLevels.json" with { type: "json" };

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

const t = await getTranslator({
  filePath: "you/collections/item/details",
  locale: Astro.currentLocale,
});

const { selected } = Astro.props;
---

<Label>
  <div class="name">
    <T namespace="you.collections.item.details.locales" key="roastingLevel">{t("roastingLevel")}</T>
  </div>
  <Select name="roastingLevel" showEmpty>
    {
      roastingLevels
        .filter(({ language_code }) => language_code === Astro.currentLocale)
        .map(({ roasting_level_id, name }) => (
          <option
            value={roasting_level_id}
            selected={String(roasting_level_id) === selected}
          >
            {name}
          </option>
        ))
    }
  </Select>
</Label>
