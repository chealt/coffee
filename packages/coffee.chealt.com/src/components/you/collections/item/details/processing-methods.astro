---
import Label from '../../../../form/label/label.astro';
import Select from '../../../../form/select/select.astro';

import processingMethods from '../../../../../../data/processingMethods.json';
import originRegions from '../../../../../../data/originRegions.json';

import allLocaleTranslations from './locales.json';

const t = allLocaleTranslations[Astro.currentLocale];

const { selected } = Astro.props;
---

<Label>
  <div class="name">
    {t.processingMethod}
  </div>
  <Select name="processingMethod" showEmpty>
    {
      processingMethods
        .filter(({ language_code }) => language_code === Astro.currentLocale)
        .map(({ processing_method_id, name }) => (
          <option value={processing_method_id} selected={String(processing_method_id) === selected}>
            {name}
          </option>
        ))
    }
  </Select>
</Label>
