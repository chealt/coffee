---
import Label from "../../../../form/label/label.astro";
import Select from "../../../../form/select/select.astro";

import roasters from "../../../../../../data/roasters.json" with { type: "json" };

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

const t = await getTranslator({
  filePath: "you/collections/item/details",
  locale: Astro.currentLocale,
});

const { selected } = Astro.props;

const selectedRoaster = roasters.find(
  (roaster) => roaster.id === Number(selected),
);
---

<Label for="roaster">
  <div class="name"><T namespace="you.collections.item.details.locales" key="roaster">{t("roaster")}</T></div>
</Label>
<Select
  id="roaster"
  name="roaster"
  showEmpty
  searchable
  selectedValue={selectedRoaster?.id}
  selectedLabel={selectedRoaster?.name}
>
  {
    roasters.map((roaster) => (
      <li
        role="option"
        aria-selected={selectedRoaster?.id === roaster.id}
        tabindex="0"
        name="roaster[]"
        data-input-name="roaster"
        data-input-value={roaster.id}
        data-input-label={roaster.name}
      >
        <div class="label">
          <div class="name">{roaster.name}</div>
        </div>
      </li>
    ))
  }
</Select>
