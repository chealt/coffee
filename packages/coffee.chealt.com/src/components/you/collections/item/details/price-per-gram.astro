---
import { getConvertedPrice } from "../../../../coffees/utils.js";
import Label from "../../../../form/label/label.astro";

import { getTranslator } from "@components/i18n/t.js";

const { pricePerGram } = Astro.props;

const { currency } = Astro.locals;

const t = await getTranslator({
  filePath: "you/collections/item/details",
  locale: Astro.currentLocale,
});

const pricePerGramInCurrency = getConvertedPrice({
  price: pricePerGram,
  currency,
});
---

<Label>
  <div class="name">
    <span>{t("pricePerGram")}:</span>
    <span
      data-price-per-gram
      data-static-values={JSON.stringify({ locale: Astro.currentLocale })}
      data-update-keys="[name=currency],[name=price],[name=weight]"
      data-api-endpoint="/api/price-per-gram.json"
    >
      {
        pricePerGramInCurrency &&
          Intl.NumberFormat(Astro.currentLocale, {
            style: "currency",
            currency,
            currencyDisplay: "narrowSymbol",
            maximumFractionDigits: 2,
          }).format(pricePerGramInCurrency)
      }
    </span>
  </div>
</Label>
