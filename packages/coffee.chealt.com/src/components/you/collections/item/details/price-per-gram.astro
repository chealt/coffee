---
import { convertToUSD, getConvertedPrice } from '../../../../coffees/utils.js';
import Input from '../../../../form/input/input.astro';
import Label from '../../../../form/label/label.astro';

import allLocaleTranslations from './locales.json';

const { pricePerGram } = Astro.props;

const { currency } = Astro.locals;

const t = allLocaleTranslations[Astro.currentLocale];
---

<Label>
  <div class="name">
    {t.pricePerGram}
  </div>
  <Input
    data-exclude-from-storage
    name="pricePerGram"
    readonly
    value={Intl.NumberFormat(Astro.currentLocale, {
      style: 'decimal',
      currency,
      maximumFractionDigits: 2
    }).format(getConvertedPrice({ price: pricePerGram, currency }))}
  />
</Label>
