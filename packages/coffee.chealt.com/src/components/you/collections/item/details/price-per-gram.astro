---
import { convertToUSD, getConvertedPrice } from '../../../../coffees/utils.js';
import Input from '../../../../form/input/input.astro';
import Label from '../../../../form/label/label.astro';

import allLocaleTranslations from './locales.json';

const { currency, price, weight } = Astro.props;

const { currency: profileCurrency } = Astro.locals;

let parsedPrice = Number(price);

if (isNaN(parsedPrice)) {
  logger.error(`Invalid price: ${price}`);

  parsedPrice = 0;
}
const pricePerGramInUSD = parsedPrice ? convertToUSD({ currency, price: parsedPrice / weight }) : undefined;

const t = allLocaleTranslations[Astro.currentLocale];
---

<Label>
  <div class="name">
    {t.pricePerGram}
  </div>
  <Input
    data-exclude-from-storage
    name="pricePerGram"
    readonly
    value={pricePerGramInUSD
      ? Intl.NumberFormat(Astro.currentLocale, {
          style: 'decimal',
          currency,
          maximumFractionDigits: 2
        }).format(getConvertedPrice({ price: pricePerGramInUSD, currency: profileCurrency }))
      : ''}
  />
</Label>
