---
import { getConvertedPrice } from '../../../../coffees/utils.js';
import Label from '../../../../form/label/label.astro';

import allLocaleTranslations from './locales.json' with { type: 'json' };

const { chartData, pricePerGram, priceIndex } = Astro.props;

const { currency } = Astro.locals;

const t = allLocaleTranslations[Astro.currentLocale];

const priceIndexPercentage = priceIndex && Math.round(priceIndex * 100);
---

<Label>
  <coffee-price-per-gram data-percentage={priceIndexPercentage} data-chart-data={chartData}>
    <div class="name">
      {
        `${t.pricePerGram}: ${Intl.NumberFormat(Astro.currentLocale, {
          style: 'currency',
          currency,
          currencyDisplay: 'narrowSymbol',
          maximumFractionDigits: 2
        }).format(getConvertedPrice({ price: pricePerGram, currency }))}`
      }
    </div>
    <div data-chart></div>
  </coffee-price-per-gram>
</Label>

<script src="./price-per-gram.js"></script>
