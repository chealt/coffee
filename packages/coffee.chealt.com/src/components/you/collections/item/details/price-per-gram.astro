---
import logger from '../../../../errors/utils.js';
import { convertToUSD, getConvertedPrice } from '../../../../coffees/utils.js';
import Input from '../../../../form/input/input.astro';
import Label from '../../../../form/label/label.astro';

import allLocaleTranslations from './locales.json';

const { pricePerGram, priceIndex } = Astro.props;

const { currency } = Astro.locals;

const t = allLocaleTranslations[Astro.currentLocale];

const priceIndexPercentage = priceIndex && Math.round(priceIndex * 100);
logger.info({ pricePerGram });
---

<Label>
  <div class="name">
    {t.pricePerGram}
    {priceIndexPercentage && <span class="price-index-percentage">({priceIndexPercentage}%)</span>}
  </div>
  <Input
    style={`background-size: 100% 6px; background-repeat: no-repeat; background-position: bottom; background-image: linear-gradient(
      to right,
      var(--color-primary) 0%,
      var(--color-primary) ${priceIndexPercentage}%,
      var(--color-background--alternative) ${priceIndexPercentage}%,
      var(--color-background--alternative) 100%
    ); border-color: var(--color-background)`}
    data-exclude
    name="pricePerGram"
    readonly
    value={Intl.NumberFormat(Astro.currentLocale, {
      style: 'decimal',
      currency,
      maximumFractionDigits: 2
    }).format(getConvertedPrice({ price: pricePerGram, currency }))}
  />
</Label>
