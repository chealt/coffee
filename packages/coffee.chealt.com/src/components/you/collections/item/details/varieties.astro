---
import Checkbox from '../../../../form/checkbox/checkbox.astro';
import Label from '../../../../form/label/label.astro';
import Select from '../../../../form/select/select.astro';
import Varieties from '../../../../varieties/list.astro';

import varieties from '../../../../../../data/varieties.json';

import allLocaleTranslations from './locales.json';

const t = allLocaleTranslations[Astro.currentLocale];

const { selected } = Astro.props;

const selectedVarieties =
  selected?.map((id) => varieties.find(({ id: varietyId }) => String(varietyId) === String(id))) || [];
---

<Label for="varieties">
  <div class="name">
    {t.varieties}
  </div>
</Label>
<Select id="varieties" name="varieties" multiple>
  {
    varieties.map(({ id, name }) => (
      <li>
        <Checkbox name="varieties[]" value={id} checked={selected?.map((id) => String(id)).includes(String(id))}>
          {name}
        </Checkbox>
      </li>
    ))
  }
</Select>
{(selected?.length > 0 && <Varieties varieties={selectedVarieties} />) || null}
