---
import { getRelativeLocaleUrl } from "astro:i18n";

import Checkbox from "../../../../form/checkbox/checkbox.astro";
import Label from "../../../../form/label/label.astro";
import Select from "../../../../form/select/select.astro";
import Varieties from "../../../../varieties/list.astro";

import varieties from "../../../../../../data/varieties.json" with { type: "json" };

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

const t = await getTranslator({
  filePath: "you/collections/item/details",
  locale: Astro.currentLocale,
});

const { selected } = Astro.props;

const selectedVarieties =
  selected
    ?.map((id) =>
      varieties.find(({ id: varietyId }) => String(varietyId) === String(id)),
    )
    .filter(Boolean) || [];
---

<Label for="varieties">
  <div class="name">
    <T namespace="you.collections.item.details.locales" key="varieties">{t("varieties")}</T>
  </div>
</Label>
<Select id="varieties" name="varieties" multiple>
  {
    varieties.map(({ id, name, alias }) => (
      <li>
        <Checkbox
          name="varieties[]"
          value={id}
          checked={selected?.map((id) => String(id)).includes(String(id))}
        >
          {name}
          {alias && ` (${alias})`}
        </Checkbox>
      </li>
    ))
  }
</Select>
<div
  data-update-keys="[name='varieties[]']"
  data-api-endpoint={getRelativeLocaleUrl(Astro.currentLocale, "/varieties")}
>
  {
    (selected?.length > 0 && <Varieties varieties={selectedVarieties} />) ||
      null
  }
</div>
