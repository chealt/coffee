---
import Label from "../../../../form/label/label.astro";
import Input from "../../../../form/input/input.astro";

import allLocaleTranslations from "./locales.json" with { type: "json" };

const t =
  allLocaleTranslations[Astro.currentLocale] || allLocaleTranslations["en"];

const { value } = Astro.props;
---

<Label>
  <div class="name">
    {t.roastingDate}
  </div>
  <Input name="roastingDate" type="date" value={value} />
</Label>
