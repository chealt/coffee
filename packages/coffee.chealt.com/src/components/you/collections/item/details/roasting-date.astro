---
import Label from "../../../../form/label/label.astro";
import Input from "../../../../form/input/input.astro";

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

const t = await getTranslator({
  filePath: "you/collections/item/details",
  locale: Astro.currentLocale,
});

const { value } = Astro.props;
---

<Label>
  <div class="name">
    <T namespace="you.collections.item.details.locales" key="roastingDate">{t("roastingDate")}</T>
  </div>
  <Input name="roastingDate" type="date" value={value} />
</Label>
