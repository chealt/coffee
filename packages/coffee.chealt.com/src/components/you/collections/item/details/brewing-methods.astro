---
import Label from "../../../../form/label/label.astro";
import Select from "../../../../form/select/select.astro";

import brewingMethods from "../../../../../../data/brewingMethods.json" with { type: "json" };

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

const t = await getTranslator({
  filePath: "you/collections/item/details",
  locale: Astro.currentLocale,
});

const { selected } = Astro.props;
---

<Label>
  <div class="name">
    <T namespace="you.collections.item.details.locales" key="brewingMethod">{t("brewingMethod")}</T>
  </div>
  <Select name="brewingMethod" showEmpty>
    {
      brewingMethods
        .filter(({ language_code }) => language_code === Astro.currentLocale)
        .map(({ brewing_method_id, name }) => (
          <option
            value={brewing_method_id}
            selected={String(brewing_method_id) === String(selected)}
          >
            {name}
          </option>
        ))
    }
  </Select>
</Label>
