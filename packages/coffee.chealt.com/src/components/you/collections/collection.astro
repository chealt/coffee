---
import Add from "./add.astro";
import Button from "../../form/button/button.astro";
import CoffeeDetails from "./coffee-details.astro";
import CoffeeControls from "./coffee-controls.astro";
import Icon from "../../icon/icon.astro";

import './collection.css';

import allLocaleTranslations from "./locales.json";

const t = allLocaleTranslations[Astro.currentLocale];

const { name, isBuiltIn, items, ...props } = Astro.props;

const contentEditable = isBuiltIn ? "contenteditable" : undefined;
---

<li {...props}>
  <coffee-collection>
    <header>
      <h3 data-db-attr-name {contentEditable} class="name">{name}</h3>
      {!isBuiltIn && (
        <Button data-delete-trigger class="button ghost" data-confirm-text={t.deleteCollection.confirm}>
          <Icon type="delete" />
          <span class="visually-hidden">{t.deleteCollection.buttonLabel}</span>
        </Button>
      )}
    </header>
    <Add />
  </coffee-collection>
  {items?.length && (
    <ul data-db-type="items">
      {items.map(({ id, images }) => (
        <li class="picture-collection" data-item-id={id}>
          <coffee-details id={id}>
            {images.length && (
              <div class="carousel images-container">
                {images.map(({ src, filename }) => (
                  <img src={src} data-file-name={filename} />
                ))}
              </div>
            ) || undefined}
            <CoffeeDetails />
          </coffee-details>
          <CoffeeControls />
        </li>
      ))}
    </ul>
  ) || undefined}
</li>

<script src="./coffee-collection.js"></script>
