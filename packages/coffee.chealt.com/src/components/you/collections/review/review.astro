---
import Button from "../../../form/button/button.astro";
import GeekZone from "./geek-zone/geek-zone.astro";
import Dialog from "../../../dialog/dialog.astro";
import Form from "../../../form/form.astro";
import Icon from "../../../icon/icon.astro";
import RadioList from "../../../form/radio/radio-list.astro";
import Radio from "../../../form/radio/radio.astro";
import Range from "../../../form/range/range.astro";

import "./review.css";

import allLocaleTranslations from "./locales.json";

const t = allLocaleTranslations[Astro.currentLocale];
---

<coffee-review>
  <Dialog id="review" class="fading" showClose>
    <h1>{t["review"]}</h1>
    <div class="review-form-container">
      <Form data-storage="localStorage" data-save-on-input data-sum-group-name="geek-zone">
        <RadioList>
          <Radio name="like" value="like">
            <Icon type="thumbs-up--filled" />
            {t["like"]}
          </Radio>
          <Radio name="like" value="dislike">
            <Icon type="thumbs-down--filled" />
            {t["dislike"]}
          </Radio>
        </RadioList>
        <Range name="acidity" min="6" max="10">
          <span slot="title">{t["acidity"]}</span>
          <span slot="min">{t["bitter"]}</span>
          <span slot="max">{t["acidic"]}</span>
        </Range>
        <Range name="sweetness" min="6" max="10">
          <span slot="title">{t["sweetness"]}</span>
          <span slot="min">{t["sour"]}</span>
          <span slot="max">{t["sweet"]}</span>
        </Range>
        <Range name="strength" excludeFromSum>
          <span slot="min">{t["weak"]}</span>
          <span slot="max">{t["strong"]}</span>
        </Range>
        <GeekZone />
      </Form>
    </div>
  </Dialog>
</coffee-review>

<script src="./review.js"></script>
