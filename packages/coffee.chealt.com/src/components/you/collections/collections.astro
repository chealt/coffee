---
import { getRelativeLocaleUrl } from "astro:i18n";

import Button from "../../form/button/button.astro";
import Checkbox from "../../form/checkbox/checkbox.astro";
import CoffeeImageUpload from "@components/common/coffee-image-upload.astro";
import Common from "../../common/common.astro";
import Dialog from "../../dialog/dialog.astro";
import Icon from "../../icon/icon.astro";
import Header from "./header/header.astro";
import NewCollection from "./new-collection.astro";
import NewItem from "./new-item.astro";

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

import "./collections.css";

const t = await getTranslator({
  filePath: "you/collections",
  locale: Astro.currentLocale,
});

const { collections, shouldAuthenticate, username } = Astro.locals;
---

<Common
  class="collections-page"
  shouldAuthenticate={shouldAuthenticate}
  redirectUrl={getRelativeLocaleUrl(Astro.currentLocale, "/you/collections")}
>
  <header class="title">
    <h1><T namespace="you.collections.locales" key="title">{t("title")}</T></h1>
    <Button
      class="round bordered small profile"
      href={getRelativeLocaleUrl(Astro.currentLocale, "/you/profile")}
    >
      <Icon type="user" />
      <span class="visually-hidden">{username}</span>
    </Button>
  </header>
  <coffee-collection>
    <ul
      class="collections-list"
      data-delete-confirm-message={t("deleteCollection.confirm")}
    >
      {
        collections?.map(
          ({ id: collectionId, name, items, isBuiltIn }, index) => (
            <li id={collectionId} data-type="collection">
              <Header
                collectionId={collectionId}
                name={t(collectionId) || name}
                isBuiltIn={isBuiltIn}
                isFirst={index === 0}
                isLast={index === collections.length - 1}
              />
              <ul class="tiles items-list">
                {items.length ? (
                  items.map(({ id: itemId, cover }) => (
                    <li>
                      <a
                        href={`${getRelativeLocaleUrl(
                          Astro.currentLocale,
                          `/you/collections/${collectionId}/items/${itemId}`,
                        )}?from=collections`}
                        id={`item-id-${itemId}`}
                      >
                        <picture>
                          <source
                            srcset={cover.srcSmall}
                            media="(max-width: 1023px)"
                          />
                          <source
                            srcset={cover.srcMedium}
                            media="(max-width: 1800px)"
                          />
                          <img src={cover.src} loading="lazy" />
                        </picture>
                      </a>
                    </li>
                  ))
                ) : (
                  <NewItem collectionId={collectionId} />
                )}
              </ul>
            </li>
          ),
        )
      }
    </ul>
    <div class="drawer top" id="batch-update" popover="manual">
      <ul>
        <li>
          <Button class="ghost column" data-dialog-id="edit-collections">
            <Icon type="edit" />
            <T namespace="you.collections.locales" key="editCollection"
              >{t("editCollection")}</T
            >
          </Button>
        </li>
        <li>
          <Button class="ghost column warning" data-clear-trigger>
            <Icon type="close" />
            <T namespace="you.collections.locales" key="clearSelection"
              >{t("clearSelection")}</T
            >
          </Button>
        </li>
      </ul>
    </div>
    <Dialog class="drawer" id="edit-collections" reloadOnChange>
      <ul>
        {
          collections?.map(({ id, name }) => (
            <li>
              <Checkbox name={id} value={id}>
                {name}
              </Checkbox>
            </li>
          ))
        }
      </ul>
    </Dialog>
  </coffee-collection>
  <NewCollection />
  <CoffeeImageUpload data-unnamed-title={t("unnamedTitle")}>
    <Button class="triggerButton bottom right floating primary">
      <Icon class="icon" type="capture" />
      <span class="visually-hidden">
        <T namespace="common.nav.locales" key="capture">
          {t("capture")}
        </T>
      </span>
    </Button>
  </CoffeeImageUpload>
</Common>

<script src="./coffee-collection.js"></script>
