---
import CoffeeDetails from "./coffee-details.astro";
import CoffeeControls from "./coffee-controls.astro";
import Add from "./add.astro";

import "./coffee-gallery.css";

import allLocaleTranslations from "./locales.json";

const t = allLocaleTranslations[Astro.currentLocale];
---

<h2>
  {t["title"]}
</h2>
<coffee-gallery>
  <CoffeeDetails />
  <CoffeeControls />
  <chealt-ocr>
    <ul data-type="collections">
      <li data-collection-id="whishList" data-is-built-in>
        <h3 data-name>{t["wishList"]}</h3>
        <Add />
      </li>
      <li data-collection-id="favorites" data-is-built-in>
        <h3 data-name>{t["favorites"]}</h3>
        <Add />
      </li>
    </ul>
  </chealt-ocr>
</coffee-gallery>

<script src="../../chealt-ocr.js"></script>
<script src="./coffee-gallery.js"></script>
