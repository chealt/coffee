---
import ChealtOCR from "../../chealt-ocr.astro";
import CoffeeDetailsTemplate from "./coffee-details.template.astro";
import CoffeeControlsTemplate from "./coffee-controls.template.astro";
import Collection from "./collection.astro";
import CollectionTemplate from "./collection.template.astro";
import Review from "./review/review.astro";

import "./coffee-gallery.css";

import allLocaleTranslations from "./locales.json";

const t = allLocaleTranslations[Astro.currentLocale];
---

<h2>
  {t["title"]}
</h2>
<coffee-gallery>
  <CoffeeDetailsTemplate />
  <CoffeeControlsTemplate />
  <CollectionTemplate />
  <Review />
  <chealt-ocr>
    <ul data-db-list data-db-type="collections">
      <Collection data-db-id="favorites" name={t["favorites"]} data-db-is-built-in data-db-item />
      <Collection data-db-id="wishList" name={t["wishList"]} data-db-is-built-in data-db-item />
    </ul>
  </chealt-ocr>
</coffee-gallery>

{Astro.locals.clientSideOCR && <ChealtOCR />}
<script src="./coffee-gallery.js"></script>
