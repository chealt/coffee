---
import Dialog from "../../dialog/dialog.astro";
import Icon from "../../icon/icon.astro";
import Form from "../../form/form.astro";
import RadioList from "../../form/radio/radio-list.astro";
import Radio from "../../form/radio/radio.astro";

import "./review.css";

import allLocaleTranslations from "./locales.json";

const t = allLocaleTranslations[Astro.currentLocale];
---

<coffee-review>
  <Dialog id="review" class="fading" showClose>
    <h1>{t["review"]}</h1>
    <div class="review-form-container">
      <Form data-storage="localStorage" data-save-on-input>
        <RadioList>
          <Radio name="like" value="like">
            <Icon type="thumbs-up--filled" />
            {t["like"]}
          </Radio>
          <Radio name="like" value="dislike">
            <Icon type="thumbs-down--filled" />
            {t["dislike"]}
          </Radio>
        </RadioList>
      </Form>
    </div>
  </Dialog>
</coffee-review>

<script src="./review.js"></script>
