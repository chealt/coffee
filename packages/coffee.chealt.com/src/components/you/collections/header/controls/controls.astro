---
import { getRelativeLocaleUrl } from "astro:i18n";

import Button from "../../../../form/button/button.astro";
import CoffeeImageUpload from "../../../../common/coffee-image-upload.astro";
import Dialog from "../../../../dialog/dialog.astro";
import Icon from "../../../../icon/icon.astro";

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

import "./controls.css";

const t = await getTranslator({
  filePath: "you/collections/header/controls",
  locale: Astro.currentLocale,
});

const { collectionId, isBuiltIn, isFirst, isLast } = Astro.props;
---

<div class="controls">
  <CoffeeImageUpload data-collection-id={collectionId}>
    <Button
      class="triggerButton ghost small"
      href={getRelativeLocaleUrl(Astro.currentLocale, "/you/collections")}
      aria-label={t("add")}
    >
      <Icon type="add" />
    </Button>
  </CoffeeImageUpload>
  <Button
    class="ghost small triggerButton"
    data-dialog-id={`collection-menu-${collectionId}`}
  >
    <Icon type="menu" />
  </Button>
  <Dialog class="drawer" id={`collection-menu-${collectionId}`}>
    <ul>
      <li>
        {
          !isFirst && (
            <Button class="ghost column" data-move-up-trigger>
              <Icon type="arrow-up" />
              <T namespace="you.collections.header.controls.locales" key="moveUp">{t("moveUp")}</T>
            </Button>
          )
        }
      </li>
      <li>
        {
          !isLast && (
            <Button class="ghost column" data-move-down-trigger>
              <Icon type="arrow-down" />
              <T namespace="you.collections.header.controls.locales" key="moveDown">{t("moveDown")}</T>
            </Button>
          )
        }
      </li>
      <li>
        <Button class="ghost column" disabled={isBuiltIn} data-rename-trigger>
          <Icon type="edit" />
          <T namespace="you.collections.header.controls.locales" key="rename">{t("rename")}</T>
        </Button>
      </li>
      <li>
        <Button
          class="ghost column danger"
          data-delete-trigger
          for={collectionId}
        >
          <Icon type="delete" />
          <T namespace="you.collections.header.controls.locales" key="delete">{t("delete")}</T>
        </Button>
      </li>
    </ul>
  </Dialog>
</div>
