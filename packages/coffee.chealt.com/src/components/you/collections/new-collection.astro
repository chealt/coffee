---
import { getRelativeLocaleUrl } from "astro:i18n";

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";
import Button from "../../form/button/button.astro";
import Icon from "../../icon/icon.astro";

const t = await getTranslator({
  filePath: "you/collections",
  locale: Astro.currentLocale,
});
---

<section>
  <coffee-collection-controls>
    <Button
      class="triggerButton column bordered dashed"
      href={getRelativeLocaleUrl(Astro.currentLocale, "/you/collections")}
      data-name={t("unnamed")}
    >
      <Icon type="add" />
      <T namespace="you.collections.locales" key="addCollection">{t("addCollection")}</T>
    </Button>
  </coffee-collection-controls>
</section>

<script src="./collection-controls.js"></script>
