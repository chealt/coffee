---
import { getRelativeLocaleUrl } from "astro:i18n";

import Button from "../../form/button/button.astro";
import Common from "../../common/common.astro";
import Label from "../../form/label/label.astro";
import Form from "../../form/form.astro";
import Textarea from "../../form/input/textarea.astro";

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

const t = await getTranslator({
  filePath: "you/feedback",
  locale: Astro.currentLocale,
});

const { shouldAuthenticate, feedback } = Astro.locals;
---

<Common
  shouldAuthenticate={shouldAuthenticate}
  redirectUrl={getRelativeLocaleUrl(Astro.currentLocale, "/you/feedback")}
>
  <h1><T namespace="you.feedback.locales" key="title">{t("title")}</T></h1>
  <section>
    <Form
      name="feedback"
      data-storage="api"
      data-save-endpoint="/api/storage/save-form-data"
      data-exclude-from-local-storage
    >
      <Label>
        <div class="name"><T namespace="you.feedback.locales" key="liked">{t("liked")}</T></div>
        <Textarea name="liked" value={feedback?.liked} />
      </Label>
      <Label>
        <div class="name"><T namespace="you.feedback.locales" key="disliked">{t("disliked")}</T></div>
        <Textarea name="disliked" value={feedback?.disliked} />
      </Label>
      <Button class="primary" type="submit"><T namespace="you.feedback.locales" key="submit">{t("submit")}</T></Button>
    </Form>
  </section>
</Common>
