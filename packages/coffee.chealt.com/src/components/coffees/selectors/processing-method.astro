---
import processingMethods from '../../../../data/processingMethods.json';

import Button from '../../form/button/button.astro';
import Dialog from '../../dialog/dialog.astro';

import { getSafeUrl } from '../../utils/url.js';

const {
  brewingMethod,
  brewingMethodGroup,
  country,
  originCountry,
  processingMethod,
  processingMethodId,
  roaster,
  tasteNote,
  tasteNoteGroup,
  variety
} = Astro.props;
---

{
  processingMethodId && (
    <Button class="filter-dialog-title ghost inline" data-dialog-id="processingMethod">
      {processingMethod.name}
    </Button>
  )
}
<Dialog class="drawer" id="processingMethod">
  <ul>
    {
      processingMethods
        .filter(({ language_code }) => language_code === Astro.currentLocale)
        .map(({ processing_method_id, name }) => (
          <li>
            <Button
              href={getSafeUrl({
                locale: Astro.currentLocale,
                brewingMethod: brewingMethod?.name,
                country: country?.name,
                originCountry: originCountry?.name,
                processingMethod: processingMethodId === processing_method_id ? undefined : name,
                roaster: roaster?.name,
                tasteNote: tasteNote?.name,
                tasteNoteGroup: tasteNoteGroup?.name,
                variety: variety?.name
              })}
              class={processingMethodId === processing_method_id ? 'primary' : ''}
            >
              {name}
            </Button>
          </li>
        ))
    }
  </ul>
</Dialog>
