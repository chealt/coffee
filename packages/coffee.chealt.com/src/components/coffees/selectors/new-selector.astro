---
import { getTranslator } from "@components/i18n/t.js";
import Button from "../../form/button/button.astro";
import Dialog from "../../dialog/dialog.astro";

import "./new-selector.css";

const t = await getTranslator({
  filePath: "coffees",
  locale: Astro.currentLocale,
});

const types = [
  "brewingMethod",
  "brewingMethodGroup",
  "country",
  "originCountry",
  "processingMethod",
  "roaster",
  // 'tasteNote',
  "tasteNoteGroup",
  "variety",
];
const { selected = {} } = Astro.props;
const availableTypes = types.filter(
  (type) =>
    !selected[type] &&
    !selected[type.replace("Group", "")] &&
    !selected[`${type}Group`],
);
---

{
  availableTypes.length > 0 ? (
    <Fragment>
      <Button
        class="new-selector-button ghost inline"
        data-dialog-id="new-selector"
      >
        & ...
      </Button>
      <Dialog class="drawer" id="new-selector">
        <ul>
          {availableTypes.map((type) => (
            <li>
              <Button class="block" data-dialog-id={type}>
                {t(type)}
              </Button>
            </li>
          ))}
        </ul>
      </Dialog>
    </Fragment>
  ) : null
}
