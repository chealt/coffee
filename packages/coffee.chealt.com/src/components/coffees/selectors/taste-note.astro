---
import tasteNotes from '@data/tasteNotes.json';

import Button from '../../form/button/button.astro';
import Dialog from '../../dialog/dialog.astro';

import { getSafeUrl } from '../../utils/url.js';

const {
  brewingMethod,
  brewingMethodGroup,
  country,
  originCountry,
  processingMethod,
  roaster,
  tasteNote,
  tasteNoteId,
  tasteNoteGroup,
  variety
} = Astro.props;
---

{
  tasteNoteId && (
    <Button class="filter-dialog-title ghost inline" data-dialog-id="tasteNote">
      {tasteNote.name}
    </Button>
  )
}
<Dialog class="drawer" id="tasteNote">
  <ul>
    {
      tasteNotes
        .filter(({ language_code }) => language_code === Astro.currentLocale)
        .map(({ taste_note_id, name }) => (
          <li>
            <Button
              href={getSafeUrl({
                locale: Astro.currentLocale,
                brewingMethod: brewingMethod?.name,
                brewingMethodGroup: brewingMethodGroup?.name,
                country: country?.name,
                originCountry: originCountry?.name,
                processingMethod: processingMethod?.name,
                roaster: roaster?.name,
                tasteNote: taste_note_id === tasteNoteId ? undefined : name,
                tasteNoteGroup: tasteNoteGroup?.name,
                variety: variety?.name
              })}
              class={tasteNoteId === taste_note_id ? 'primary' : ''}
            >
              {name}
            </Button>
          </li>
        ))
    }
  </ul>
</Dialog>
