---
import countries from "@data/countries.json" with { type: "json" };
import supportedLanguages from "@data/supportedLanguages.json" with { type: "json" };

import Button from "../../form/button/button.astro";
import Dialog from "../../dialog/dialog.astro";

import { getSafeUrl } from "../../utils/url.js";

const {
  brewingMethod,
  brewingMethodGroup,
  country,
  countryId,
  originCountry,
  processingMethod,
  roaster,
  tasteNote,
  tasteNoteGroup,
  variety,
} = Astro.props;

let countriesLocale = countries.filter(
  ({ language_code }) => language_code === Astro.currentLocale,
);

if (!countriesLocale.length) {
  const defaultLocale =
    supportedLanguages.find(({ isDefault }) => isDefault)?.locale || "en";

  countriesLocale = countries.filter(
    ({ language_code }) => language_code === defaultLocale,
  );
}
---

{
  countryId && (
    <Button class="filter-dialog-title ghost inline" data-dialog-id="country">
      {country.name}
    </Button>
  )
}
<Dialog id="country" class="drawer">
  <ul class="selector-list">
    {
      countriesLocale.map(({ name, country_id }) => (
        <li>
          <Button
            href={getSafeUrl({
              locale: Astro.currentLocale,
              brewingMethod: brewingMethod?.name,
              brewingMethodGroup: brewingMethodGroup?.name,
              country: countryId === country_id ? undefined : name,
              originCountry: originCountry?.name,
              processingMethod: processingMethod?.name,
              roaster: roaster?.name,
              tasteNote: tasteNote?.name,
              tasteNoteGroup: tasteNoteGroup?.name,
              variety: variety?.name,
            })}
            class={country_id === countryId ? "primary" : ""}
          >
            {name}
          </Button>
        </li>
      ))
    }
  </ul>
</Dialog>
