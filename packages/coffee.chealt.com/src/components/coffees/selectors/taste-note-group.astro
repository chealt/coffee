---
import tasteNoteGroups from "@data/tasteNoteGroups.json" with { type: "json" };
import supportedLanguages from "@data/supportedLanguages.json" with { type: "json" };

import Button from "../../form/button/button.astro";
import Dialog from "../../dialog/dialog.astro";

import { getSafeUrl } from "../../utils/url.js";

const {
  brewingMethod,
  brewingMethodGroup,
  country,
  originCountry,
  processingMethod,
  roaster,
  tasteNote,
  tasteNoteGroup,
  tasteNoteGroupId,
  variety,
} = Astro.props;

let tasteNoteGroupsLocale = tasteNoteGroups.filter(
  ({ language_code }) => language_code === Astro.currentLocale,
);

if (!tasteNoteGroupsLocale.length) {
  const defaultLocale =
    supportedLanguages.find(({ isDefault }) => isDefault)?.locale || "en";

  tasteNoteGroupsLocale = tasteNoteGroups.filter(
    ({ language_code }) => language_code === defaultLocale,
  );
}
---

{
  tasteNoteGroupId && (
    <Button
      class="filter-dialog-title ghost inline"
      data-dialog-id="tasteNoteGroup"
    >
      {tasteNoteGroup.name}
    </Button>
  )
}
<Dialog class="drawer" id="tasteNoteGroup">
  <ul class="selector-list">
    {
      tasteNoteGroupsLocale.map(({ taste_note_group_id, name }) => (
        <li>
          <Button
            href={getSafeUrl({
              locale: Astro.currentLocale,
              brewingMethod: brewingMethod?.name,
              brewingMethodGroup: brewingMethodGroup?.name,
              country: country?.name,
              originCountry: originCountry?.name,
              processingMethod: processingMethod?.name,
              roaster: roaster?.name,
              tasteNote: tasteNote?.name,
              tasteNoteGroup:
                taste_note_group_id === tasteNoteGroupId ? undefined : name,
              variety: variety?.name,
            })}
            class={tasteNoteGroupId === taste_note_group_id ? "primary" : ""}
          >
            {name}
          </Button>
        </li>
      ))
    }
  </ul>
</Dialog>
