---
import varieties from '../../../../data/varieties.json';

import Button from '../../form/button/button.astro';
import Dialog from '../../dialog/dialog.astro';

import { getSafeUrl } from '../../utils/url.js';

const {
  brewingMethod,
  brewingMethodGroup,
  country,
  originCountry,
  processingMethod,
  roaster,
  tasteNote,
  tasteNoteGroup,
  variety,
  varietyId
} = Astro.props;
---

{
  varietyId && (
    <Button class="filter-dialog-title ghost inline" data-dialog-id="variety">
      {variety.name}
    </Button>
  )
}
<Dialog class="drawer" id="variety">
  <ul class="selector-list">
    {
      varieties.map(({ id, name }) => (
        <li>
          <Button
            href={getSafeUrl({
              locale: Astro.currentLocale,
              brewingMethod: brewingMethod?.name,
              brewingMethodGroup: brewingMethodGroup?.name,
              country: country?.name,
              originCountry: originCountry?.name,
              processingMethod: processingMethod?.name,
              roaster: roaster?.name,
              tasteNote: tasteNote?.name,
              tasteNoteGroup: tasteNoteGroup?.name,
              variety: varietyId === id ? undefined : name
            })}
            class={id === varietyId ? 'primary' : ''}
          >
            {name}
          </Button>
        </li>
      ))
    }
  </ul>
</Dialog>
