---
import originCountries from '../../../../data/originCountries.json';

import Button from '../../form/button/button.astro';
import Dialog from '../../dialog/dialog.astro';

import { getSafeUrl } from '../../utils/url.js';

const {
  brewingMethod,
  brewingMethodGroup,
  country,
  originCountry,
  originCountryId,
  processingMethod,
  roaster,
  variety
} = Astro.props;
---

<span data-dialog-id="origin-countries">{originCountry.name}</span>
<Dialog class="drawer" id="origin-countries">
  <ul>
    {
      originCountries
        .filter(({ language_code }) => language_code === Astro.currentLocale)
        .map(({ origin_country_id, name }) => (
          <li>
            <Button
              href={getSafeUrl({
                locale: Astro.currentLocale,
                brewingMethod: brewingMethod?.name,
                brewingMethodGroup: brewingMethodGroup?.name,
                country: country?.name,
                originCountry: name,
                processingMethod: processingMethod?.name,
                roaster: roaster?.name,
                variety: variety?.name
              })}
              class={originCountryId === origin_country_id ? 'primary' : ''}
            >
              {name}
            </Button>
          </li>
        ))
    }
  </ul>
</Dialog>
