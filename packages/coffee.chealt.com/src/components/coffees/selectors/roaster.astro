---
import roasters from '../../../../data/roasters.json';

import Button from '../../form/button/button.astro';
import Dialog from '../../dialog/dialog.astro';

import { getSafeUrl } from '../../utils/url.js';

const { brewingMethod, brewingMethodGroup, country, originCountry, processingMethod, roaster, roasterId, variety } =
  Astro.props;
---

<span data-dialog-id="roasters">{roaster.name}</span>
<Dialog class="drawer" id="roasters">
  <ul>
    {
      roasters.map(({ id, name }) => (
        <li>
          <Button
            href={getSafeUrl({
              locale: Astro.currentLocale,
              brewingMethod: brewingMethod?.name,
              country: country?.name,
              originCountry: originCountry?.name,
              processingMethod: processingMethod?.name,
              roaster: name,
              variety: variety?.name
            })}
            class={id === roasterId ? 'primary' : ''}
          >
            {name}
          </Button>
        </li>
      ))
    }
  </ul>
</Dialog>
