---
import roasters from '../../../../data/roasters.json' with { type: 'json' };

import Button from '../../form/button/button.astro';
import Dialog from '../../dialog/dialog.astro';

import { getSafeUrl } from '../../utils/url.js';

const {
  brewingMethod,
  brewingMethodGroup,
  country,
  originCountry,
  processingMethod,
  roaster,
  roasterId,
  tasteNote,
  tasteNoteGroup,
  variety
} = Astro.props;
---

{
  roasterId && (
    <Button class="filter-dialog-title ghost inline" data-dialog-id="roaster">
      {roaster.name}
    </Button>
  )
}
<Dialog class="drawer" id="roaster">
  <ul class="selector-list">
    {
      roasters.map(({ id, name }) => (
        <li>
          <Button
            href={getSafeUrl({
              locale: Astro.currentLocale,
              brewingMethod: brewingMethod?.name,
              brewingMethodGroup: brewingMethodGroup?.name,
              country: country?.name,
              originCountry: originCountry?.name,
              processingMethod: processingMethod?.name,
              roaster: roasterId === id ? undefined : name,
              tasteNote: tasteNote?.name,
              tasteNoteGroup: tasteNoteGroup?.name,
              variety: variety?.name
            })}
            class={id === roasterId ? 'primary' : ''}
          >
            {name}
          </Button>
        </li>
      ))
    }
  </ul>
</Dialog>
