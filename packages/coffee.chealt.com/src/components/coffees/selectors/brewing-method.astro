---
import brewingMethods from '../../../../data/brewingMethods.json' with { type: 'json' };

import Button from '../../form/button/button.astro';
import Dialog from '../../dialog/dialog.astro';

import { getSafeUrl } from '../../utils/url.js';

const {
  brewingMethod,
  brewingMethodId,
  brewingMethodGroup,
  country,
  originCountry,
  processingMethod,
  roaster,
  tasteNote,
  tasteNoteGroup,
  variety
} = Astro.props;
---

{
  brewingMethodId && (
    <Button class="filter-dialog-title ghost inline" data-dialog-id="brewingMethod">
      {brewingMethod.name}
    </Button>
  )
}
<Dialog class="drawer" id="brewingMethod">
  <ul class="selector-list">
    {
      brewingMethods
        .filter(({ language_code }) => language_code === Astro.currentLocale)
        .map(({ brewing_method_id, name }) => (
          <li>
            <Button
              href={getSafeUrl({
                locale: Astro.currentLocale,
                brewingMethod: brewingMethodId === brewing_method_id ? undefined : name,
                brewingMethodGroup: brewingMethodGroup?.name,
                country: country?.name,
                originCountry: originCountry?.name,
                processingMethod: processingMethod?.name,
                roaster: roaster?.name,
                tasteNote: tasteNote?.name,
                tasteNoteGroup: tasteNoteGroup?.name,
                variety: variety?.name
              })}
              class={brewingMethodId === brewing_method_id ? 'primary' : ''}
            >
              {name}
            </Button>
          </li>
        ))
    }
  </ul>
</Dialog>
