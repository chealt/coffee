---
import { getRelativeLocaleUrl } from 'astro:i18n';

import allCoffees from '@data/coffees.json';
import coffeeTasteNotes from '@data/coffeeTasteNotes.json';
import coffeeVarieties from '@data/coffeeVarieties.json';
import countries from '@data/countries.json';
import brewingMethods from '@data/brewingMethods.json';
import brewingMethodGroups from '@data/brewingMethodGroups.json';
import originCountries from '@data/originCountries.json';
import processingMethods from '@data/processingMethods.json';
import roasters from '@data/roasters.json';
import tasteNotes from '@data/tasteNotes.json';
import tasteNoteGroups from '@data/tasteNoteGroups.json';
import varieties from '@data/varieties.json';

import BrewingMethodGroupSelector from './selectors/brewing-method-group.astro';
import BrewingMethodSelector from './selectors/brewing-method.astro';
import CountrySelector from './selectors/country.astro';
import OriginCountrySelector from './selectors/origin-country.astro';
import ProcessingMethodSelector from './selectors/processing-method.astro';
import RoasterSelector from './selectors/roaster.astro';
import TasteNoteGroupSelector from './selectors/taste-note-group.astro';
import TasteNoteSelector from './selectors/taste-note.astro';
import VarietySelector from './selectors/variety.astro';
import NewSelector from './selectors/new-selector.astro';
import { convertToUSD } from './utils.js';
import Button from '../form/button/button.astro';
import Coffees from './list.astro';
import Common from '../common/common.astro';
import Dialog from '../dialog/dialog.astro';
import Icon from '../icon/icon.astro';
import { capitalize, encodeSafeURL } from '../../utils/string.js';
import { getSafeUrl, getSafeUrlWithStats } from '../utils/url.js';
import { getTasteNoteGroupByNoteId } from '../taste-notes/utils.js';

import './filtered-list.css';

import allLocaleTranslationsCommon from '../common/common.json';
import allLocaleTranslations from './locales.json';

const t = allLocaleTranslations[Astro.currentLocale];
const tc = allLocaleTranslationsCommon[Astro.currentLocale];

const { loggedInUser } = Astro.locals;
const {
  brewingMethodId,
  brewingMethodGroupId,
  countryId,
  originCountryId,
  processingMethodId,
  roasterId,
  tasteNoteGroupId,
  tasteNoteId,
  varietyId
} = Astro.props;

const brewingMethodGroup = brewingMethodGroupId && brewingMethodGroups.find(({ id }) => id === brewingMethodGroupId);
const brewingMethodIdsInGroup =
  brewingMethodGroupId &&
  brewingMethods
    .filter(
      ({ brewing_method_group_id }) => !brewing_method_group_id || brewing_method_group_id === brewingMethodGroupId
    )
    .map(({ brewing_method_id }) => brewing_method_id);
const brewingMethod =
  brewingMethodId &&
  brewingMethods.find(
    ({ brewing_method_id, language_code }) =>
      brewing_method_id === brewingMethodId && language_code === Astro.currentLocale
  );
const country =
  countryId &&
  countries.find(({ country_id, language_code }) => country_id === countryId && language_code === Astro.currentLocale);
const originCountry =
  originCountryId &&
  originCountries.find(
    ({ origin_country_id, language_code }) =>
      origin_country_id === originCountryId && language_code === Astro.currentLocale
  );
const processingMethod =
  processingMethodId &&
  processingMethods.find(
    ({ processing_method_id, language_code }) =>
      processing_method_id === processingMethodId && language_code === Astro.currentLocale
  );
const roaster = roasterId && roasters.find(({ id }) => id === roasterId);
const tasteNote = tasteNoteId && tasteNotes.find(({ taste_note_id }) => taste_note_id === tasteNoteId);
const tasteNoteGroup =
  tasteNoteGroupId && tasteNoteGroups.find(({ taste_note_group_id }) => taste_note_group_id === tasteNoteGroupId);
const variety = varietyId && varieties.find(({ id }) => id === varietyId);

const coffees = allCoffees
  .filter(({ brewing_method_id }) => (brewingMethodId ? brewing_method_id === brewingMethodId : true))
  .filter(({ brewing_method_id }) =>
    brewingMethodGroupId ? brewingMethodIdsInGroup.includes(brewing_method_id) : true
  )
  .filter(({ origin_country_id }) => (originCountryId ? origin_country_id === originCountryId : true))
  .filter(({ roaster_id: roasterId }) =>
    countryId ? roasters.find((roaster) => roaster.id === roasterId).country_id === countryId : true
  )
  .filter(({ processing_method_id }) => (processingMethodId ? processing_method_id === processingMethodId : true))
  .filter(({ roaster_id }) => (roasterId ? roaster_id === roasterId : true))
  .filter(({ id: coffeeId }) =>
    varietyId
      ? coffeeVarieties
          .filter(({ coffee_id }) => coffee_id === coffeeId)
          .some(({ variety_id }) => variety_id === varietyId)
      : true
  )
  .filter(({ id: coffeeId }) =>
    tasteNoteId
      ? coffeeTasteNotes
          .filter(({ coffee_id }) => coffee_id === coffeeId)
          .some(({ taste_note_id }) => taste_note_id === tasteNoteId)
      : true
  )
  .filter(({ id: coffeeId }) =>
    tasteNoteGroupId
      ? coffeeTasteNotes
          .filter(({ coffee_id }) => coffee_id === coffeeId)
          .some(
            ({ taste_note_id }) => getTasteNoteGroupByNoteId(taste_note_id).taste_note_group_id === tasteNoteGroupId
          )
      : true
  );
const priciestCoffees = coffees
  .sort(
    (a, b) =>
      convertToUSD({ currency: b.currency, price: b.price_per_gram }) -
      convertToUSD({ currency: a.currency, price: a.price_per_gram })
  )
  .slice(0, 10);
const cheapestCoffees = coffees
  .sort(
    (a, b) =>
      convertToUSD({ currency: a.currency, price: a.price_per_gram }) -
      convertToUSD({ currency: b.currency, price: b.price_per_gram })
  )
  .slice(0, 10);

const statsLink = getSafeUrlWithStats({
  locale: Astro.currentLocale,
  brewingMethod: brewingMethod?.name,
  brewingMethodGroup: brewingMethodGroup?.name,
  country: country?.name,
  originCountry: originCountry?.name,
  processingMethod: processingMethod?.name,
  roaster: roaster?.name,
  tasteNote: tasteNote?.name,
  tasteNoteGroup: tasteNoteGroup?.name,
  variety: variety?.name
});
---

<Common
  title={`${t.coffeeFrom} ${capitalize(brewingMethod?.name || brewingMethodGroup?.name || country?.name || originCountry?.name || processingMethod?.name || roaster?.name || tasteNote?.name || tasteNoteGroup?.name || variety?.name)}`}
>
  <h1 class="title">
    <div>
      <BrewingMethodSelector
        brewingMethod={brewingMethod}
        brewingMethodId={brewingMethodId}
        brewingMethodGroup={brewingMethodGroup}
        country={country}
        originCountry={originCountry}
        processingMethod={processingMethod}
        roaster={roaster}
        tasteNote={tasteNote}
        tasteNoteGroup={tasteNoteGroup}
        variety={variety}
      />
      <BrewingMethodGroupSelector
        brewingMethod={brewingMethod}
        brewingMethodGroup={brewingMethodGroup}
        brewingMethodGroupId={brewingMethodGroupId}
        country={country}
        originCountry={originCountry}
        processingMethod={processingMethod}
        roaster={roaster}
        tasteNote={tasteNote}
        tasteNoteGroup={tasteNoteGroup}
        variety={variety}
      />
      <CountrySelector
        country={country}
        countryId={countryId}
        brewingMethod={brewingMethod}
        brewingMethodGroup={brewingMethodGroup}
        originCountry={originCountry}
        processingMethod={processingMethod}
        roaster={roaster}
        tasteNote={tasteNote}
        tasteNoteGroup={tasteNoteGroup}
        variety={variety}
      />
      <OriginCountrySelector
        brewingMethod={brewingMethod}
        brewingMethodGroup={brewingMethodGroup}
        country={country}
        originCountry={originCountry}
        originCountryId={originCountryId}
        processingMethod={processingMethod}
        roaster={roaster}
        tasteNote={tasteNote}
        tasteNoteGroup={tasteNoteGroup}
        variety={variety}
      />
      <ProcessingMethodSelector
        brewingMethod={brewingMethod}
        brewingMethodGroup={brewingMethodGroup}
        country={country}
        originCountry={originCountry}
        processingMethod={processingMethod}
        processingMethodId={processingMethodId}
        roaster={roaster}
        tasteNote={tasteNote}
        tasteNoteGroup={tasteNoteGroup}
        variety={variety}
      />
      <RoasterSelector
        brewingMethod={brewingMethod}
        brewingMethodGroup={brewingMethodGroup}
        country={country}
        originCountry={originCountry}
        roaster={roaster}
        roasterId={roasterId}
        processingMethod={processingMethod}
        tasteNote={tasteNote}
        tasteNoteGroup={tasteNoteGroup}
        variety={variety}
      />
      <!-- <TasteNoteSelector
        brewingMethod={brewingMethod}
        brewingMethodGroup={brewingMethodGroup}
        country={country}
        originCountry={originCountry}
        processingMethod={processingMethod}
        roaster={roaster}
        tasteNote={tasteNote}
        tasteNoteId={tasteNoteId}
        tasteNoteGroup={tasteNoteGroup}
        variety={variety}
      /> -->
      <TasteNoteGroupSelector
        brewingMethod={brewingMethod}
        brewingMethodGroup={brewingMethodGroup}
        country={country}
        originCountry={originCountry}
        processingMethod={processingMethod}
        roaster={roaster}
        tasteNote={tasteNote}
        tasteNoteGroupId={tasteNoteGroupId}
        tasteNoteGroup={tasteNoteGroup}
        variety={variety}
      />
      <VarietySelector
        brewingMethod={brewingMethod}
        brewingMethodGroup={brewingMethodGroup}
        country={country}
        originCountry={originCountry}
        processingMethod={processingMethod}
        roaster={roaster}
        tasteNote={tasteNote}
        tasteNoteGroup={tasteNoteGroup}
        variety={variety}
        varietyId={varietyId}
      />
      <NewSelector
        selected={{
          brewingMethod: brewingMethod?.name,
          brewingMethodGroup: brewingMethodGroup?.name,
          country: country?.name,
          originCountry: originCountry?.name,
          processingMethod: processingMethod?.name,
          roaster: roaster?.name,
          tasteNote: tasteNote?.name,
          tasteNoteGroup: tasteNoteGroup?.name,
          variety: variety?.name
        }}
      />
    </div>
    {
      loggedInUser && (
        <Button class="ghost small" href={statsLink}>
          <Icon type="chart" />
          <span class="visually-hidden">{tc.chart}</span>
        </Button>
      )
    }
  </h1>
  {
    (roasterId && (
      <div class="roaster-container">
        <section>
          <div class="image roaster" style={`view-transition-name: roaster-${roaster.id}`}>
            <img src={`/roasters/${roaster.logo}`} alt={roaster.name} />
          </div>
        </section>
        <section class="links">
          {roaster.instagram && (
            <Button href={`https://instagram.com/${roaster.instagram}`} target="_blank" rel="noopener noreferrer">
              <Icon type="instagram" />
            </Button>
          )}
          {roaster.website && (
            <Button href={roaster.website} target="_blank" rel="noopener noreferrer">
              <Icon type="home" />
            </Button>
          )}
        </section>
      </div>
    )) ||
      null
  }
  {
    (priciestCoffees.length && (
      <section>
        <h2>{tc.priciestCoffees}</h2>
        <Coffees coffees={priciestCoffees} />
      </section>
    )) ||
      null
  }
  {
    (cheapestCoffees.length && (
      <section>
        <h2>{tc.cheapestCoffees}</h2>
        <Coffees coffees={cheapestCoffees} />
      </section>
    )) ||
      null
  }
  {
    (coffees.length && (
      <section>
        <h2>{tc.allCoffees}</h2>
        <Coffees coffees={coffees} />
      </section>
    )) || <section>{tc.noCoffees}</section>
  }
</Common>
