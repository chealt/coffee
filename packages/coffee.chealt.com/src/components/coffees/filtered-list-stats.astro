---
import { getRelativeLocaleUrl } from 'astro:i18n';

import allCoffees from '@data/coffees.json';
import coffeeTasteNotes from '@data/coffeeTasteNotes.json';
import coffeeVarieties from '@data/coffeeVarieties.json';
import brewingMethods from '@data/brewingMethods.json';
import brewingMethodGroups from '@data/brewingMethodGroups.json';
import countries from '@data/countries.json';
import originCountries from '@data/originCountries.json';
import processingMethods from '@data/processingMethods.json';
import roasters from '@data/roasters.json';
import tasteNotes from '@data/tasteNotes.json';
import tasteNoteGroups from '@data/tasteNoteGroups.json';
import varieties from '@data/varieties.json';

import Button from '../form/button/button.astro';
import Icon from '../icon/icon.astro';
import Common from '../common/common.astro';
import Coffees from '../coffees/list.astro';
import { convertToUSD, getDetails } from '../coffees/utils.js';
import { getTasteNoteGroup, getTasteNoteGroupByNoteId } from '../taste-notes/utils.js';
import { getSafeUrl } from '../utils/url';

import '../stats/stats.css';

import allLocaleTranslations from '../common/common.json';

const t = allLocaleTranslations[Astro.currentLocale];

const { currency, loggedInUser, shouldAuthenticate } = Astro.locals;
const {
  brewingMethodId,
  brewingMethodGroupId,
  countryId,
  originCountryId,
  processingMethodId,
  roasterId,
  tasteNoteGroupId,
  tasteNoteId,
  varietyId
} = Astro.props;

const brewingMethod =
  brewingMethodId && brewingMethods.find(({ brewing_method_id }) => brewing_method_id === brewingMethodId);
const brewingMethodIdsInGroup =
  brewingMethodGroupId &&
  brewingMethods
    .filter(
      ({ brewing_method_group_id }) => !brewing_method_group_id || brewing_method_group_id === brewingMethodGroupId
    )
    .map(({ brewing_method_id }) => brewing_method_id);
const brewingMethodGroup = brewingMethodGroupId && brewingMethodGroups.find(({ id }) => id === brewingMethodGroupId);
const country = countryId && countries.find(({ country_id }) => country_id === countryId);
const originCountry =
  originCountryId && originCountries.find(({ origin_country_id }) => origin_country_id === originCountryId);
const processingMethod =
  processingMethodId &&
  processingMethods.find(({ processing_method_id }) => processing_method_id === processingMethodId);
const roaster = roasterId && roasters.find(({ id }) => id === roasterId);
const tasteNote = tasteNoteId && tasteNotes.find(({ taste_note_id }) => taste_note_id === tasteNoteId);
const tasteNoteGroup =
  tasteNoteGroupId && tasteNoteGroups.find(({ taste_note_group_id }) => taste_note_group_id === tasteNoteGroupId);
const variety = varietyId && varieties.find(({ id }) => id === varietyId);

const coffees = allCoffees
  .filter(({ brewing_method_id }) => (brewingMethodId ? brewing_method_id === brewingMethodId : true))
  .filter(({ brewing_method_id }) =>
    brewingMethodGroupId ? brewingMethodIdsInGroup.includes(brewing_method_id) : true
  )
  .filter(({ origin_country_id }) => (originCountryId ? origin_country_id === originCountryId : true))
  .filter(({ roaster_id: roasterId }) =>
    countryId ? roasters.find((roaster) => roaster.id === roasterId).country_id === countryId : true
  )
  .filter(({ processing_method_id }) => (processingMethodId ? processing_method_id === processingMethodId : true))
  .filter(({ roaster_id }) => (roasterId ? roaster_id === roasterId : true))
  .filter(({ id: coffeeId }) =>
    varietyId
      ? coffeeVarieties
          .filter(({ coffee_id }) => coffee_id === coffeeId)
          .some(({ variety_id }) => variety_id === varietyId)
      : true
  )
  .filter(({ id: coffeeId }) =>
    tasteNoteId
      ? coffeeTasteNotes
          .filter(({ coffee_id }) => coffee_id === coffeeId)
          .some(({ taste_note_id }) => taste_note_id === tasteNoteId)
      : true
  )
  .filter(({ id: coffeeId }) =>
    tasteNoteGroupId
      ? coffeeTasteNotes
          .filter(({ coffee_id }) => coffee_id === coffeeId)
          .some(
            ({ taste_note_id }) => getTasteNoteGroupByNoteId(taste_note_id).taste_note_group_id === tasteNoteGroupId
          )
      : true
  )
  .map(getDetails({ locale: Astro.currentLocale }))
  .map(({ pricePerGram, ...coffee }) => ({
    ...coffee,
    pricePerGram: convertToUSD({ price: pricePerGram, currency })
  }))
  .sort((a, b) => a.pricePerGram - b.pricePerGram);
const maxPricePerGram = coffees[coffees.length - 1].pricePerGram;
const roastersWithCoffee = Array.from(new Set(allCoffees.map(({ roaster_id }) => roaster_id)))
  .map((roasterId) => roasters.find(({ id }) => id === roasterId))
  .map((roaster) => ({
    ...roaster,
    coffees: coffees.filter(({ roaster: { id: roasterId } }) => roasterId === roaster.id)
  }))
  .filter(({ coffees }) => coffees.length)
  .map((roaster) => ({
    ...roaster,
    tasteNoteGroups: roaster.coffees.reduce((stats, { tasteNotes }) => {
      tasteNotes.forEach(({ taste_note_id: tasteNoteId }) => {
        const { taste_note_group_id: tasteNoteGroupId } = getTasteNoteGroupByNoteId(tasteNoteId);

        if (!stats[tasteNoteGroupId]) {
          stats[tasteNoteGroupId] = 1;
        } else {
          stats[tasteNoteGroupId]++;
        }
      });

      return stats;
    }, {})
  }));
const tasteNoteGroupsLocale = tasteNoteGroups
  .filter(({ name, language_code: languageCode }) => languageCode === Astro.currentLocale && name !== 'other')
  .map(({ name, taste_note_group_id: tasteNoteGroupId, ...rest }) =>
    name.includes('/') ? { tasteNoteGroupId, name: name.split(' / ')[0], ...rest } : { tasteNoteGroupId, name, ...rest }
  )
  .map(({ tasteNoteGroupId, ...rest }) => ({
    ...rest,
    tasteNoteGroupId,
    roasters: roastersWithCoffee
      .filter(({ tasteNoteGroups }) => tasteNoteGroups[tasteNoteGroupId])
      .map(({ id, name, tasteNoteGroups }) => ({
        id,
        name,
        count: tasteNoteGroups[tasteNoteGroupId]
      }))
      .sort((a, b) => b.count - a.count)
  }))
  .filter(({ roasters }) => roasters.length);
const maxTasteNoteGroupCount = tasteNoteGroupsLocale.reduce((max, { roasters }) => Math.max(max, roasters[0].count), 0);
---

<Common shouldAuthenticate={shouldAuthenticate}>
  <h1 class="title">
    <div>
      {brewingMethodId && <span class="filter-title">{brewingMethod?.name}</span>}
      {brewingMethodGroupId && <span class="filter-title">{brewingMethodGroup?.name}</span>}
      {countryId && <span class="filter-title">{country?.name}</span>}
      {originCountryId && <span class="filter-title">{originCountry?.name}</span>}
      {processingMethodId && <span class="filter-title">{processingMethod?.name}</span>}
      {roasterId && <span class="filter-title">{roaster?.name}</span>}
      {tasteNoteId && <span class="filter-title">{tasteNote?.name}</span>}
      {tasteNoteGroupId && <span class="filter-title">{tasteNoteGroup?.name}</span>}
      {varietyId && <span class="filter-title">{variety?.name}</span>}
    </div>
    {
      loggedInUser && (
        <Button
          class="ghost small"
          href={getSafeUrl({
            locale: Astro.currentLocale,
            brewingMethod: brewingMethod?.name,
            brewingMethodGroup: brewingMethodGroup?.name,
            country: country?.name,
            originCountry: originCountry?.name,
            processingMethod: processingMethod?.name,
            roaster: roaster?.name,
            tasteNote: tasteNote?.name,
            tasteNoteGroup: tasteNoteGroup?.name,
            variety: variety?.name
          })}
        >
          <Icon type="back" />
          <span class="visually-hidden">{t.back}</span>
        </Button>
      )
    }
  </h1>
  <section>
    <h2>{t.prices}</h2>
    <div class="card">
      <coffee-stats>
        <div class="stats">
          <div class="chart-inner">
            <div class="dots">
              {
                roastersWithCoffee.map(({ id: roasterId, name: roasterName, coffees }) =>
                  coffees.map(
                    ({ pricePerGram, originCountry: { name: originCountryName }, webshopItemLink }, coffeeIndex) => (
                      <a
                        class="part dot"
                        style={`bottom: ${pricePerGram / (maxPricePerGram / 100)}%; left: ${coffeeIndex / (coffees.length / 100)}%`}
                        data-label={roasterId}
                        aria-label={`${roasterName} ${originCountryName}`}
                        href={webshopItemLink}
                        target="_blank"
                        rel="noopener noreferrer"
                      />
                    )
                  )
                )
              }
            </div>
            <div class="labels">
              {
                roastersWithCoffee.map(({ id: roasterId, name, coffees }) => (
                  <Fragment>
                    <div class="label x" data-part={roasterId}>
                      {name}
                    </div>
                  </Fragment>
                ))
              }
            </div>
          </div>
        </div>
      </coffee-stats>
    </div>
  </section>
  <section>
    <h2>{t.tasteNotes}</h2>
    <div class="card">
      <coffee-stats>
        <div class="stats">
          <div class="chart-inner">
            <ul class="bars">
              {
                tasteNoteGroupsLocale.map(({ name, color, tasteNoteGroupId, roasters }) => (
                  <li class="bar-container">
                    {roasters.map(({ id: roasterId, name, count }) => (
                      <div
                        class="part bar"
                        style={`height: ${count / (maxTasteNoteGroupCount / 100)}%`}
                        data-label={roasterId}
                      />
                    ))}
                    <div class="bar-label" style={`color: ${color}`}>
                      {name}
                    </div>
                  </li>
                ))
              }
            </ul>
            <div class="labels">
              {
                tasteNoteGroupsLocale.map(({ name, color, tasteNoteGroupId, roasters }) =>
                  roasters.map(({ id: roasterId, name, count }) => (
                    <div class="label x" data-part={roasterId}>
                      {name}
                    </div>
                  ))
                )
              }
            </div>
          </div>
        </div>
      </coffee-stats>
    </div>
  </section>
</Common>

<script src="../stats/stats.js"></script>
