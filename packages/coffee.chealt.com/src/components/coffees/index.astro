---
import { getRelativeLocaleUrl } from "astro:i18n";

import Button from "../form/button/button.astro";
import coffees from "../../../data/coffees.json" with { type: "json" };
import Common from "../common/common.astro";
import Coffees from "./list.astro";
import Icon from "../icon/icon.astro";

import allLocaleTranslations from "./locales.json" with { type: "json" };
import allLocaleCommonTranslations from "../common/locales.json" with { type: "json" };

const t =
  allLocaleTranslations[Astro.currentLocale] || allLocaleTranslations["en"];
const tc =
  allLocaleCommonTranslations[Astro.currentLocale] ||
  allLocaleCommonTranslations["en"];

const { loggedInUser } = Astro.locals;
---

<Common>
  <h1 class="title">
    <div>{t.coffees}</div>
    {
      loggedInUser && (
        <Button
          class="ghost small"
          href={getRelativeLocaleUrl(Astro.currentLocale, `/coffees/stats`)}
        >
          <Icon type="chart" />
          <span class="visually-hidden">{tc.chart}</span>
        </Button>
      )
    }
  </h1>
  <section>
    <Coffees coffees={coffees} />
  </section>
</Common>
