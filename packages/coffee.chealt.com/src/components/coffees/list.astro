---
import { getDetails } from "./utils.js";
import Item from "./item.astro";

const { coffees, isRecommendedList } = Astro.props;

await import.meta.glob("/public/coffees/*.*", { eager: true });

const coffeesWithDetails = coffees.map(
  getDetails({ locale: Astro.currentLocale }),
);
---

<div class="list-container">
  <ul class="list">
    {
      coffeesWithDetails.map((details, index) => (
        <li class="item" itemtype="https://schema.org/Product" itemscope>
          <Item
            {...details}
            highPriority={index < 1 && isRecommendedList}
            isRecommendedList={isRecommendedList}
          />
        </li>
      ))
    }
  </ul>
</div>
