---
import { getDetails } from './utils.js';
import Item from './item.astro';

const { coffees, isRecommendedList } = Astro.props;

await import.meta.glob('/public/coffees/*.*', { eager: true });

const { recommended } = Astro.locals;

const coffeesWithDetails = coffees.map(getDetails({ locale: Astro.currentLocale })).map(({ id, ...rest }) => ({
  id,
  isRecommended: !isRecommendedList && recommended?.coffees?.some(({ id: coffeeId }) => coffeeId === id),
  ...rest
}));
---

<div class="list-container">
  <ul class="list">
    {
      coffeesWithDetails.map((details, index) => (
        <li class="item">
          <Item {...details} highPriority={index < 3} />
        </li>
      ))
    }
  </ul>
</div>
