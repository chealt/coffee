---
import { getRelativeLocaleUrl } from "astro:i18n";

import { getConvertedPrice } from "./utils.js";
import TasteNotes from "../taste-notes/taste-notes.astro";
import Varieties from "../varieties/list.astro";
import { encodeSafeURL } from "../../utils/string.js";
import newCoffeeIds from "../../../data/newCoffeeIds.json" with { type: "json" };

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

import "./item.css";

const t = await getTranslator({
  filePath: "coffees",
  locale: Astro.currentLocale,
});
const tc = await getTranslator({
  filePath: "common",
  locale: Astro.currentLocale,
});

const brewingMethodImages = await import.meta.glob(
  "/public/icons/brewing-methods/*.*",
  {
    eager: true,
    query: "?raw",
    import: "default",
  },
);

const {
  id,
  brewingMethod,
  highPriority,
  images,
  isDecaf,
  isRecommendedList,
  originCountry,
  originFarm,
  originRegion,
  roaster,
  roastingDate,
  price,
  pricePerGram,
  processingMethod,
  tasteNotes,
  varieties,
  webshopItemLink,
  weight,
} = Astro.props;
const isNew = newCoffeeIds.includes(id);

const { currency } = Astro.locals;
---

<meta
  itemprop="name"
  content={`${roaster.name} ${originCountry?.name}${originRegion ? ` ${originRegion.name}` : ""}${originFarm ? ` ${originFarm.name}` : ""}${varieties?.length ? ` ${varieties.map(({ name }) => name).join(", ")}` : ""}${processingMethod?.name ? ` ${processingMethod.name}` : ""}`}
/>
<meta
  itemprop="description"
  content={`${roaster.name} ${originCountry?.name}${originRegion ? ` ${originRegion.name}` : ""}${originFarm ? ` ${originFarm.name}` : ""}${varieties?.length ? ` ${varieties.map(({ name }) => name).join(", ")}` : ""}${processingMethod?.name ? ` ${processingMethod.name}` : ""}${brewingMethod?.name ? ` ${brewingMethod.name}` : ""}${tasteNotes?.length ? ` ${tasteNotes.map(({ name }) => name).join(", ")}` : ""}`}
/>
<a
  href={webshopItemLink}
  class="card"
  target="_blank"
  name={t("webshopLinkName")}
  itemprop="url"
>
  <div class="image">
    <img
      src={`https://centralbeans.com/images/600/${images[0]}`}
      alt={`${t("coffeeFrom")} ${originCountry?.name}`}
      loading={highPriority ? undefined : "lazy"}
      fetchpriority={highPriority ? "high" : undefined}
      itemprop="image"
    />
  </div>
  {
    isNew && (
      <span class="tag good left">
        <T namespace="common.locales" key="new">
          {tc("new")}
        </T>
      </span>
    )
  }
  {
    !isNew && !isRecommendedList && (
      <span
        class="tag primary left hidden"
        data-recommendation-key={`coffees-${id}`}
      >
        <T namespace="common.locales" key="recommended">
          {tc("recommended")}
        </T>
      </span>
    )
  }
  {
    isDecaf && (
      <span class="decaf-tag">
        <T namespace="coffees.locales" key="decaf">
          {t("decaf")}
        </T>
      </span>
    )
  }
</a>
<section class="not-padded coffee-details">
  <dl>
    <dt><T namespace="coffees.locales" key="roaster">{t("roaster")}</T></dt>
    <dd itemtype="https://schema.org/Brand" itemprop="brand" itemscope>
      <meta itemprop="name" content={roaster.name} />
      {roaster.website && <meta itemprop="url" content={roaster.website} />}
      <a
        href={getRelativeLocaleUrl(
          Astro.currentLocale,
          `/roasters/${encodeSafeURL(roaster.name)}`,
        )}
        class="chip bordered"
        data-astro-prefetch="viewport"
      >
        {roaster.name}
      </a>
      <span>{" - "}</span>
      <a
        href={getRelativeLocaleUrl(
          Astro.currentLocale,
          `/countries/${encodeSafeURL(roaster.country.name)}`,
        )}
        class="chip bordered"
        data-astro-prefetch="viewport"
      >
        {roaster.country.code.toUpperCase()}
      </a>
    </dd>
    <dt>
      <T namespace="coffees.locales" key="originCountry">{t("originCountry")}</T
      >
    </dt>
    <dd>
      {
        (originCountry?.name && (
          <a
            href={getRelativeLocaleUrl(
              Astro.currentLocale,
              `/origin-countries/${encodeSafeURL(originCountry.name)}`,
            )}
            class="chip bordered"
            data-astro-prefetch="viewport"
          >
            {originCountry.name}
          </a>
        )) ||
          null
      }
      {(originRegion?.name && <span> - {originRegion.name}</span>) || null}
      {(originFarm?.name && <span> - {originFarm.name}</span>) || null}
    </dd>
    {
      ((brewingMethod?.name || processingMethod?.name) && (
        <Fragment>
          <dt>
            <T namespace="coffees.locales" key="brewingMethod">
              {t("brewingMethod")}
            </T>{" "}
            {(processingMethod?.name && (
              <>
                {" - "}
                <T namespace="coffees.locales" key="processingMethod">
                  {t("processingMethod")}
                </T>
              </>
            )) ||
              ""}
          </dt>
          <dd>
            <Fragment>
              {(brewingMethod?.name && (
                <a
                  href={getRelativeLocaleUrl(
                    Astro.currentLocale,
                    brewingMethod.group?.name
                      ? `/brewing-method-groups/${encodeSafeURL(brewingMethod.group.name)}`
                      : `/brewing-methods/${encodeSafeURL(brewingMethod.name)}`,
                  )}
                  class="chip"
                  data-astro-prefetch="viewport"
                >
                  {(brewingMethodImages[
                    `/public/icons/brewing-methods/${brewingMethod.name}.svg`
                  ] && (
                    <Fragment
                      set:html={
                        brewingMethodImages[
                          `/public/icons/brewing-methods/${brewingMethod.name}.svg`
                        ]
                      }
                    />
                  )) ||
                    null}
                  {brewingMethod.name}
                </a>
              )) ||
                null}
              {(processingMethod?.name && (
                <a
                  href={getRelativeLocaleUrl(
                    Astro.currentLocale,
                    `/processing-methods/${encodeSafeURL(processingMethod.name)}`,
                  )}
                  class="chip"
                  data-astro-prefetch="viewport"
                >
                  {processingMethod.name}
                </a>
              )) ||
                null}
            </Fragment>
          </dd>
        </Fragment>
      )) ||
        null
    }
    {
      roastingDate && (
        <Fragment>
          <dt>
            <T namespace="coffees.locales" key="roastingDate">
              {t("roastingDate")}
            </T>
          </dt>
          <dd>
            {Intl.DateTimeFormat(Astro.currentLocale).format(
              new Date(roastingDate),
            )}
          </dd>
        </Fragment>
      )
    }
    {
      (varieties?.length && (
        <Fragment>
          <dt>
            <T namespace="coffees.locales" key="varieties">
              {t("varieties")}
            </T>
          </dt>
          <dd>
            <Varieties varieties={varieties} />
          </dd>
        </Fragment>
      )) ||
        null
    }
    {
      (tasteNotes?.length && (
        <Fragment>
          <dt>
            <T namespace="coffees.locales" key="tasteNotes">
              {t("tasteNotes")}
            </T>
          </dt>
          <dd>{<TasteNotes tasteNotes={tasteNotes} />}</dd>
        </Fragment>
      )) ||
        null
    }
    {
      (weight && price && (
        <Fragment>
          <dt
            itemtype="https://schema.org/QuantitativeValue"
            itemprop="weight"
            itemscope
          >
            <meta itemprop="value" content={weight} />
            <meta itemprop="unitCode" content="GRM" />
            <T namespace="coffees.locales" key="weight">
              {t("weight")}
            </T>{" "}
            {" - "}
            <T namespace="coffees.locales" key="price">
              {t("price")}
            </T>
          </dt>
          <dd itemtype="https://schema.org/Offer" itemprop="offers" itemscope>
            <link itemprop="availability" href="https://schema.org/InStock" />
            <meta itemprop="url" content={webshopItemLink} />
            <meta itemprop="priceCurrency" content={currency} />
            <meta itemprop="price" content={price} />
            <span>
              {`${Intl.NumberFormat(Astro.currentLocale, {
                style: "currency",
                currency,
              }).format(
                getConvertedPrice({ price, currency }),
              )} - ${Intl.NumberFormat(Astro.currentLocale).format(weight)} g`}
            </span>
            <span class="price-per-gram">
              {`(${Intl.NumberFormat(Astro.currentLocale, {
                style: "decimal",
                currency,
                maximumFractionDigits: 2,
              }).format(
                getConvertedPrice({ price: pricePerGram, currency }),
              )} ${t("pricePerGram")})`}
            </span>
          </dd>
        </Fragment>
      )) ||
        null
    }
  </dl>
</section>
