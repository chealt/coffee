---
import { getRelativeLocaleUrl } from 'astro:i18n';

import { getConvertedPrice } from './utils.js';
import TasteNotes from '../taste-notes/taste-notes.astro';
import Varieties from '../varieties/list.astro';
import { encodeSafeURL } from '../../utils/string.js';
import newCoffeeIds from '../../../data/newCoffeeIds.json';

import './item.css';

import allLocaleTranslations from './locales.json';
import allLocaleCommonTranslations from '../common/common.json';

const t = allLocaleTranslations[Astro.currentLocale];
const tc = allLocaleCommonTranslations[Astro.currentLocale];

const brewingMethodImages = await import.meta.glob('/public/icons/brewing-methods/*.*', {
  eager: true,
  query: '?raw',
  import: 'default'
});

const {
  id,
  brewingMethod,
  highPriority,
  images,
  isDecaf,
  isRecommended,
  originCountry,
  originFarm,
  originRegion,
  roaster,
  roastingDate,
  price,
  pricePerGram,
  processingMethod,
  tasteNotes,
  varieties,
  webshopItemLink,
  weight
} = Astro.props;
const isNew = newCoffeeIds.includes(id);

const { currency } = Astro.locals;
---

<meta
  itemprop="name"
  content={`${roaster.name} ${originCountry?.name}${originRegion ? ` ${originRegion.name}` : ''}${originFarm ? ` ${originFarm.name}` : ''}${varieties?.length ? ` ${varieties.map(({ name }) => name).join(', ')}` : ''}${processingMethod?.name ? ` ${processingMethod.name}` : ''}`}
/>
<meta
  itemprop="description"
  content={`${roaster.name} ${originCountry?.name}${originRegion ? ` ${originRegion.name}` : ''}${originFarm ? ` ${originFarm.name}` : ''}${varieties?.length ? ` ${varieties.map(({ name }) => name).join(', ')}` : ''}${processingMethod?.name ? ` ${processingMethod.name}` : ''}${brewingMethod?.name ? ` ${brewingMethod.name}` : ''}${tasteNotes?.length ? ` ${tasteNotes.map(({ name }) => name).join(', ')}` : ''}`}
/>
<a
  href={webshopItemLink}
  class="card"
  target="_blank"
  rel="noopener noreferrer"
  name={t.webshopLinkName}
  itemprop="url"
>
  <div class="image">
    <img
      src={`https://centralbeans.com/images/600/${images[0]}`}
      alt={`${t.coffeeFrom} ${originCountry?.name}`}
      loading={highPriority ? undefined : 'lazy'}
      fetchpriority={highPriority ? 'high' : undefined}
      itemprop="image"
    />
  </div>
  {isNew && <span class="tag good left">{tc.new}</span>}
  {!isNew && isRecommended && <span class="tag primary left">{tc.recommended}</span>}
  {isDecaf && <span class="decaf-tag">{t.decaf}</span>}
</a>
<section class="not-padded coffee-details">
  <dl>
    <dt>{t.roaster}</dt>
    <dd itemtype="https://schema.org/Brand" itemprop="brand" itemscope>
      <meta itemprop="name" content={roaster.name} />
      {roaster.website && <meta itemprop="url" content={roaster.website} />}
      <a
        href={getRelativeLocaleUrl(Astro.currentLocale, `/roasters/${encodeSafeURL(roaster.name)}`)}
        class="chip bordered"
      >
        {roaster.name}
      </a>
      <span>{' - '}</span>
      <a
        href={getRelativeLocaleUrl(Astro.currentLocale, `/countries/${encodeURIComponent(roaster.country.name)}`)}
        class="chip bordered"
      >
        {roaster.country.code.toUpperCase()}
      </a>
    </dd>
    <dt>{t.originCountry}</dt>
    <dd>
      {
        (originCountry?.name && (
          <a
            href={getRelativeLocaleUrl(
              Astro.currentLocale,
              `/origin-countries/${encodeURIComponent(originCountry.name)}`
            )}
            class="chip bordered"
          >
            {originCountry.name}
          </a>
        )) ||
          null
      }
      {(originRegion?.name && <span> - {originRegion.name}</span>) || null}
      {(originFarm?.name && <span> - {originFarm.name}</span>) || null}
    </dd>
    {
      ((brewingMethod?.name || processingMethod?.name) && (
        <Fragment>
          <dt>
            {t.brewingMethod} {processingMethod?.name ? ` - ${t.processingMethod}` : ''}
          </dt>
          <dd>
            <Fragment>
              {(brewingMethod?.name && (
                <a
                  href={getRelativeLocaleUrl(
                    Astro.currentLocale,
                    brewingMethod.group?.name
                      ? `/brewing-method-groups/${brewingMethod.group.name}`
                      : `/brewing-methods/${encodeURIComponent(brewingMethod.name)}`
                  )}
                  class="chip"
                >
                  {(brewingMethodImages[`/public/icons/brewing-methods/${brewingMethod.name}.svg`] && (
                    <Fragment
                      set:html={brewingMethodImages[`/public/icons/brewing-methods/${brewingMethod.name}.svg`]}
                    />
                  )) ||
                    null}
                  {brewingMethod.name}
                </a>
              )) ||
                null}
              {(processingMethod?.name && (
                <a
                  href={getRelativeLocaleUrl(
                    Astro.currentLocale,
                    `/processing-methods/${encodeURIComponent(processingMethod.name)}`
                  )}
                  class="chip"
                >
                  {processingMethod.name}
                </a>
              )) ||
                null}
            </Fragment>
          </dd>
        </Fragment>
      )) ||
        null
    }
    {
      roastingDate && (
        <Fragment>
          <dt>{t.roastingDate}</dt>
          <dd>{Intl.DateTimeFormat(Astro.currentLocale).format(new Date(roastingDate))}</dd>
        </Fragment>
      )
    }
    {
      (varieties?.length && (
        <Fragment>
          <dt>{t.varieties}</dt>
          <dd>
            <Varieties varieties={varieties} />
          </dd>
        </Fragment>
      )) ||
        null
    }
    {
      (tasteNotes?.length && (
        <Fragment>
          <dt>{t.tasteNotes}</dt>
          <dd>{<TasteNotes tasteNotes={tasteNotes} />}</dd>
        </Fragment>
      )) ||
        null
    }
    {
      (weight && price && (
        <Fragment>
          <dt itemtype="https://schema.org/QuantitativeValue" itemprop="weight" itemscope>
            <meta itemprop="value" content={weight} />
            <meta itemprop="unitCode" content="GRM" />
            {t.weight} - {t.price}
          </dt>
          <dd itemtype="https://schema.org/Offer" itemprop="offers" itemscope>
            <link itemprop="availability" href="https://schema.org/InStock" />
            <meta itemprop="url" content={webshopItemLink} />
            <meta itemprop="priceCurrency" content={currency} />
            <meta itemprop="price" content={price} />
            <span>
              {`${Intl.NumberFormat(Astro.currentLocale, {
                style: 'currency',
                currency
              }).format(
                getConvertedPrice({ price, currency })
              )} - ${Intl.NumberFormat(Astro.currentLocale).format(weight)} g`}
            </span>
            <span class="price-per-gram">
              {`(${Intl.NumberFormat(Astro.currentLocale, {
                style: 'decimal',
                currency,
                maximumFractionDigits: 2
              }).format(getConvertedPrice({ price: pricePerGram, currency }))} ${t.pricePerGram})`}
            </span>
          </dd>
        </Fragment>
      )) ||
        null
    }
  </dl>
</section>
