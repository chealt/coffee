---
import { getRelativeLocaleUrl } from 'astro:i18n';

import { getConvertedPrice } from './utils';
import TasteNotes from '../taste-notes/taste-notes.astro';
import Varieties from '../varieties/list.astro';

import './item.css';

import allLocaleTranslations from './locales.json';
import allLocaleCommonTranslations from '../common/common.json';

const t = allLocaleTranslations[Astro.currentLocale];
const tc = allLocaleCommonTranslations[Astro.currentLocale];

const brewingMethodImages = await import.meta.glob('/public/icons/brewing-methods/*.*', {
  eager: true,
  query: '?raw',
  import: 'default'
});

const {
  id,
  brewingMethod,
  highPriority,
  images,
  isDecaf,
  isRecommended,
  originCountry,
  originFarm,
  originRegion,
  roaster,
  roastingDate,
  price,
  pricePerGram,
  processingMethod,
  tasteNotes,
  varieties,
  webshopItemLink,
  weight
} = Astro.props;

const { currency } = Astro.locals;
---

<a href={webshopItemLink} class="card" target="_blank" rel="noopener noreferrer" name={t.webshopLinkName}>
  <div class="image large">
    <img
      src={`https://coffee-images.centralbeans.com/${images[0]}`}
      alt={`${t.coffeeFrom} ${originCountry?.name}`}
      loading={highPriority ? undefined : 'lazy'}
      fetchpriority={highPriority ? 'high' : undefined}
    />
  </div>
  {
    (isRecommended && <span class="tag primary left">{tc.recommended}</span>) ||
      (isDecaf && <span class="decaf-tag">{t.decaf}</span>)
  }
</a>
<section class="not-padded coffee-details">
  <dl>
    <dt>{t.roaster}</dt>
    <dd>
      <a
        href={getRelativeLocaleUrl(Astro.currentLocale, `/roasters/${encodeURIComponent(roaster.name)}`)}
        class="chip bordered"
      >
        {roaster.name}
      </a>
      <span>{' - '}</span>
      <a
        href={getRelativeLocaleUrl(Astro.currentLocale, `/countries/${encodeURIComponent(roaster.country.name)}`)}
        class="chip bordered"
      >
        {roaster.country.code.toUpperCase()}
      </a>
    </dd>
    <dt>{t.originCountry}</dt>
    <dd>
      {
        (originCountry?.name && (
          <a
            href={getRelativeLocaleUrl(
              Astro.currentLocale,
              `/origin-countries/${encodeURIComponent(originCountry.name)}`
            )}
            class="chip bordered"
          >
            {originCountry.name}
          </a>
        )) ||
          null
      }
      {(originRegion?.name && <span> - {originRegion.name}</span>) || null}
    </dd>
    {
      (originFarm?.name && (
        <Fragment>
          <dt>{t.originFarm}</dt>
          <dd>{originFarm.name}</dd>
        </Fragment>
      )) ||
        null
    }
    {
      (brewingMethod?.name && (
        <Fragment>
          <dt>{t.brewingMethod}</dt>
          <dd class="brewing-method">
            <a
              href={getRelativeLocaleUrl(
                Astro.currentLocale,
                `/brewing-methods/${encodeURIComponent(brewingMethod.name)}`
              )}
              class="chip"
            >
              {(brewingMethodImages[`/public/icons/brewing-methods/${brewingMethod.name}.svg`] && (
                <Fragment set:html={brewingMethodImages[`/public/icons/brewing-methods/${brewingMethod.name}.svg`]} />
              )) ||
                null}
              {brewingMethod.name}
            </a>
          </dd>
        </Fragment>
      )) ||
        null
    }
    {
      (processingMethod?.name && (
        <Fragment>
          <dt>{t.processingMethod}</dt>
          <dd>
            <a
              href={getRelativeLocaleUrl(
                Astro.currentLocale,
                `/processing-methods/${encodeURIComponent(processingMethod.name)}`
              )}
              class="chip"
            >
              {processingMethod.name}
            </a>
          </dd>
        </Fragment>
      )) ||
        null
    }
    {
      roastingDate && (
        <Fragment>
          <dt>{t.roastingDate}</dt>
          <dd>{Intl.DateTimeFormat(Astro.currentLocale).format(new Date(roastingDate))}</dd>
        </Fragment>
      )
    }
    {
      (varieties?.length && (
        <Fragment>
          <dt>{t.varieties}</dt>
          <dd>
            <Varieties varieties={varieties} />
          </dd>
        </Fragment>
      )) ||
        null
    }
    {
      (tasteNotes?.length && (
        <Fragment>
          <dt>{t.tasteNotes}</dt>
          <dd>{<TasteNotes tasteNotes={tasteNotes} />}</dd>
        </Fragment>
      )) ||
        null
    }
    {
      originFarm?.height && (
        <Fragment>
          <dt>{t.height}</dt>
          <dd>{`${Intl.NumberFormat(Astro.currentLocale).format(originFarm.height)} m`}</dd>
        </Fragment>
      )
    }
    {
      (weight && price && (
        <Fragment>
          <dt>
            {t.weight} - {t.price}
          </dt>
          <dd>
            <span>
              {`${Intl.NumberFormat(Astro.currentLocale, {
                style: 'currency',
                currency
              }).format(
                getConvertedPrice({ price, currency })
              )} - ${Intl.NumberFormat(Astro.currentLocale).format(weight)} g`}
            </span>
            <span class="price-per-gram">
              {`(${Intl.NumberFormat(Astro.currentLocale, {
                style: 'decimal',
                currency,
                maximumFractionDigits: 2
              }).format(getConvertedPrice({ price: pricePerGram, currency }))} ${t.pricePerGram})`}
            </span>
          </dd>
        </Fragment>
      )) ||
        null
    }
  </dl>
</section>
