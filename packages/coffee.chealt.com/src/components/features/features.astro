---
import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

const t = await getTranslator({
  filePath: "features",
  locale: Astro.currentLocale,
});
---

<h2><T namespace="features.locales" key="title">{t("title")}</T></h2>
<section class="card">
  <div class="columns">
    <div class="sixty">
      <h2 style="margin: 0; font-size: 20px; margin-bottom: 10px;">
        <T namespace="features.locales" key="settingsTitle">{t("settingsTitle")}</T>
      </h2>
      <p>
        <Fragment set:html={t("settingsDescription")} />
      </p>
    </div>
    <div class="forty">
      <img src="/screenshots/features/profile-page.png" alt="Profile page" />
    </div>
  </div>
</section>
<section class="card">
  <div class="columns">
    <div class="forty">
      <img src="/screenshots/features/lists.png" alt="Collections page" />
    </div>
    <div class="sixty">
      <h2 style="margin: 0; font-size: 20px; margin-bottom: 10px;">
        <T namespace="features.locales" key="collectionsTitle">{t("collectionsTitle")}</T>
      </h2>
      <p>
        <Fragment set:html={t("collectionsDescription")} />
      </p>
    </div>
  </div>
</section>
<section class="card">
  <div class="columns">
    <div class="sixty">
      <h2 style="margin: 0; font-size: 20px; margin-bottom: 10px;">
        <T namespace="features.locales" key="detailsTitle">{t("detailsTitle")}</T>
      </h2>
      <p>
        <Fragment set:html={t("detailsDescription")} />
      </p>
    </div>
    <div class="forty">
      <img src="/screenshots/features/details.png" alt="Coffee details page" />
    </div>
  </div>
</section>
<section class="card">
  <div class="columns">
    <div class="forty">
      <img src="/screenshots/features/review.png" alt="Coffee review page" />
    </div>
    <div class="sixty">
      <h2 style="margin: 0; font-size: 20px; margin-bottom: 10px;">
        <T namespace="features.locales" key="recommendationsTitle">{t("recommendationsTitle")}</T>
      </h2>
      <p>
        <Fragment set:html={t("recommendationsDescription")} />
      </p>
    </div>
  </div>
</section>
<section class="card">
  <div class="columns">
    <div class="sixty">
      <h2 style="margin: 0; font-size: 20px; margin-bottom: 10px;">
        <T namespace="features.locales" key="newCoffeesTitle">{t("newCoffeesTitle")}</T>
      </h2>
      <p>
        <Fragment set:html={t("newCoffeesDescription")} />
      </p>
    </div>
    <div class="forty">
      <img src="/screenshots/features/new-coffees.png" alt="New Coffees" />
    </div>
  </div>
</section>
