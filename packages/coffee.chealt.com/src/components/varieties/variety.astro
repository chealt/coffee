---
import allCoffees from '../../../data/coffees.json';
import coffeeVarieties from '../../../data/coffeeVarieties.json';
import varieties from '../../../data/varieties.json';

import { getConvertedPricePerGram, getDetails } from '../coffees/utils.js';
import Coffees from '../coffees/list.astro';
import Common from '../common/common.astro';

import allLocaleTranslations from '../common/common.json';

const t = allLocaleTranslations[Astro.currentLocale];

const { id } = Astro.props;

const { name } = varieties.find((variety) => variety.id === id);
const coffees = allCoffees.filter((coffee) =>
  coffeeVarieties.some(({ variety_id: varietyId, coffee_id: coffeeId }) => varietyId === id && coffeeId === coffee.id)
);

const priciestCoffees = coffees
  .sort(
    (a, b) =>
      getConvertedPricePerGram({ currency: b.currency, pricePerGram: b.price_per_gram }) -
      getConvertedPricePerGram({ currency: a.currency, pricePerGram: a.price_per_gram })
  )
  .slice(0, 10);
const cheapestCoffees = coffees
  .sort(
    (a, b) =>
      getConvertedPricePerGram({ currency: a.currency, pricePerGram: a.price_per_gram }) -
      getConvertedPricePerGram({ currency: b.currency, pricePerGram: b.price_per_gram })
  )
  .slice(0, 10);
---

<Common>
  <h1>{name}</h1>
  {
    (priciestCoffees.length && coffees.length > 9 && (
      <section>
        <h2>{t.priciestCoffees}</h2>
        <Coffees coffees={priciestCoffees} />
      </section>
    )) ||
      null
  }
  {
    (cheapestCoffees.length && coffees.length > 9 && (
      <section>
        <h2>{t.cheapestCoffees}</h2>
        <Coffees coffees={cheapestCoffees} />
      </section>
    )) ||
      null
  }
  {
    (coffees.length && (
      <section>
        <h2>{t.allCoffees}</h2>
        <Coffees coffees={coffees} />
      </section>
    )) ||
      null
  }
</Common>
