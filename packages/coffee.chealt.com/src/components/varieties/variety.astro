---
import { getRelativeLocaleUrl } from "astro:i18n";

import allCoffees from "../../../data/coffees.json" with { type: "json" };
import coffeeVarieties from "../../../data/coffeeVarieties.json" with { type: "json" };
import varieties from "../../../data/varieties.json" with { type: "json" };

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";
import { convertToUSD, getDetails } from "../coffees/utils.js";
import Button from "../form/button/button.astro";
import Coffees from "../coffees/list.astro";
import Common from "../common/common.astro";
import Icon from "../icon/icon.astro";

const t = await getTranslator({
  filePath: "common",
  locale: Astro.currentLocale,
});

const { loggedInUser } = Astro.locals;
const { id } = Astro.props;

const { name } = varieties.find((variety) => variety.id === id);
const coffees = allCoffees.filter((coffee) =>
  coffeeVarieties.some(
    ({ variety_id: varietyId, coffee_id: coffeeId }) =>
      varietyId === id && coffeeId === coffee.id,
  ),
);

const priciestCoffees = coffees
  .sort(
    (a, b) =>
      convertToUSD({ currency: b.currency, price: b.price_per_gram }) -
      convertToUSD({ currency: a.currency, price: a.price_per_gram }),
  )
  .slice(0, 10);
const cheapestCoffees = coffees
  .sort(
    (a, b) =>
      convertToUSD({ currency: a.currency, price: a.price_per_gram }) -
      convertToUSD({ currency: b.currency, price: b.price_per_gram }),
  )
  .slice(0, 10);
---

<Common>
  <h1 class="title">
    <div>
      {name}
    </div>
    {
      loggedInUser && (
        <Button
          class="ghost small"
          href={getRelativeLocaleUrl(
            Astro.currentLocale,
            `/varieties/${encodeURIComponent(name.toLowerCase())}/stats`,
          )}
        >
          <Icon type="chart" />
          <span class="visually-hidden"><T namespace="common.locales" key="chart">{t("chart")}</T></span>
        </Button>
      )
    }
  </h1>
  {
    (priciestCoffees.length && coffees.length > 9 && (
      <section>
        <h2><T namespace="common.locales" key="priciestCoffees">{t("priciestCoffees")}</T></h2>
        <Coffees coffees={priciestCoffees} />
      </section>
    )) ||
      null
  }
  {
    (cheapestCoffees.length && coffees.length > 9 && (
      <section>
        <h2><T namespace="common.locales" key="cheapestCoffees">{t("cheapestCoffees")}</T></h2>
        <Coffees coffees={cheapestCoffees} />
      </section>
    )) ||
      null
  }
  {
    (coffees.length && (
      <section>
        <h2><T namespace="common.locales" key="allCoffees">{t("allCoffees")}</T></h2>
        <Coffees coffees={coffees} />
      </section>
    )) ||
      null
  }
</Common>
