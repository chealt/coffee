---
import { getRelativeLocaleUrl } from 'astro:i18n';

import { getTasteNoteGroupByNoteId } from './utils.js';

const { tasteNotes } = Astro.props;

const tasteNotesWithGroup = tasteNotes.map((tasteNote) => ({
  ...tasteNote,
  group: getTasteNoteGroupByNoteId(tasteNote.taste_note_id)
}));
---

<ul class="taste-notes">
  {
    tasteNotesWithGroup.map(({ name, group }) => (
      <li class="chip" style={group?.color ? `background-color: ${group.color}` : 'border: 1px dashed'}>
        {(group && (
          <a
            href={getRelativeLocaleUrl(Astro.currentLocale, `/taste-note-groups/${encodeURIComponent(group.name)}`)}
            style={group.color === '#ebb40d' ? 'color: #4f4b43' : ''}
          >
            {name}
          </a>
        )) ||
          name}
      </li>
    ))
  }
</ul>
