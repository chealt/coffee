---
import roasters from "../../../data/roasters.json";
import Label from "../label.astro";
import Select from "../select.astro";
import allLocaleTranslations from "../../../locales/collections/collections.json";

const t = allLocaleTranslations[Astro.currentLocale];
---

<Label>{t["roaster"]}</Label>
<Select name="roaster" showEmpty>
  {
    roasters.map((roaster) => (
      <option value={`${roaster.id}`}>{roaster.name}</option>
    ))
  }
</Select>
