---
import originCountries from '../../../../data/originCountriesWithCoffees.json';

const countries = originCountries.filter(({ language_code }) => language_code === Astro.currentLocale);
---

<ul class="list">
  {
    countries.map(({ origin_country_id, name }) => (
      <li class="item">
        <a href={`/origin-countries/${name}`}>
          <div class="image">
            <img src={`/origin-countries/${origin_country_id}.svg`} alt={name} loading="lazy" />
          </div>
          <div class="name">{name}</div>
        </a>
      </li>
    ))
  }
</ul>
