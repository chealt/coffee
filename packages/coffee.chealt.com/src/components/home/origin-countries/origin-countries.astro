---
import { getRelativeLocaleUrl } from "astro:i18n";

import "./origin-countries.css";

import originCountries from "../../../../data/originCountriesWithCoffees.json" with { type: "json" };

import allLocaleTranslations from "./locales.json" with { type: "json" };
import allLocaleCommonTranslations from "../../common/common.json" with { type: "json" };

const t = allLocaleTranslations[Astro.currentLocale];
const tc = allLocaleCommonTranslations[Astro.currentLocale];

const countries = originCountries.filter(
  ({ language_code }) => language_code === Astro.currentLocale,
);
---

<div class="list-container">
  <ul class="list origin-countries">
    {
      countries.map(({ origin_country_id: id, name }, index) => (
        <li class="item">
          <a
            href={getRelativeLocaleUrl(
              Astro.currentLocale,
              `/origin-countries/${name}`,
            )}
          >
            <div class="image card">
              <img
                src={`/origin-countries/${id}.svg`}
                alt={`${t.originCountry} ${name}`}
                loading="lazy"
              />
            </div>
            <div class="name">{name}</div>
            <span
              class="tag primary left hidden"
              data-recommendation-key={`originCountries-${id}`}
            >
              {tc.recommended}
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</div>
