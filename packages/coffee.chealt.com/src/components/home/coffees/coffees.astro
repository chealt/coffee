---
import brewingMethods from '../../../../data/brewingMethods.json';
import coffees from '../../../../data/coffees.json';
import coffeeImages from '../../../../data/coffeeImages.json';
import countries from '../../../../data/countries.json';
import originCountries from '../../../../data/originCountries.json';
import originFarms from '../../../../data/originFarms.json';
import originRegions from '../../../../data/originRegions.json';
import roastingLevels from '../../../../data/roastingLevels.json';
import roasters from '../../../../data/roasters.json';

import allLocaleTranslations from './locales.json';

const t = allLocaleTranslations[Astro.currentLocale];

const coffeesDetails = coffees.map((coffee) => ({
  id: coffee.id,
  images: coffeeImages.filter(({ coffee_id }) => coffee_id === coffee.id).map((coffeeImage) => coffeeImage.url),
  roastingDate: coffee.roasting_date,
  webshopItemLink: coffee.webshop_item_link,
  pricePerGram: coffee.price_per_gram,
  weight: coffee.weight,
  price: coffee.price,
  roastingLevel: roastingLevels.find(
    (roastingLevel) =>
      roastingLevel.roasting_level_id === coffee.roasting_level_id &&
      roastingLevel.language_code === Astro.currentLocale
  ),
  isDecaf: Boolean(coffee.is_decaf),
  roaster: roasters.find((roaster) => roaster.id === coffee.roaster_id),
  originCountry: originCountries.find(
    (originCountry) =>
      originCountry.origin_country_id === coffee.origin_country_id &&
      originCountry.language_code === Astro.currentLocale
  ),
  originRegion: originRegions.find(
    (originRegion) =>
      originRegion.origin_region_id === coffee.origin_region_id && originRegion.language_code === Astro.currentLocale
  ),
  brewingMethod: brewingMethods.find(
    (brewingMethod) =>
      brewingMethod.brewing_method_id === coffee.brewing_method_id &&
      brewingMethod.language_code === Astro.currentLocale
  ),
  originFarm: originFarms.find((originFarm) => originFarm.id === coffee.origin_farm_id)
}));

await import.meta.glob('/public/coffees/*.*', { eager: true });
---

<ul class="list">
  {
    coffeesDetails.map(
      ({
        id,
        images,
        roastingDate,
        brewingMethod,
        originCountry,
        originRegion,
        originFarm,
        webshopItemLink,
        pricePerGram,
        price,
        weight
      }) => (
        <li class="item">
          <a href={webshopItemLink} target="_blank" rel="noopener noreferrer">
            <div class="image large">
              <img src={`/coffees/${images[0]}.webp`} loading="lazy" />
            </div>
            <section>
              <dl>
                <dt>{t.originCountry}</dt>
                <dd>{originCountry?.name}</dd>
                {originRegion?.name && (
                  <Fragment>
                    <dt>{t.originRegion}</dt>
                    <dd>{originRegion?.name}</dd>
                  </Fragment>
                )}
                {originFarm?.name && (
                  <Fragment>
                    <dt>{t.originFarm}</dt>
                    <dd>{originFarm?.name}</dd>
                  </Fragment>
                )}
                {brewingMethod?.name && (
                  <Fragment>
                    <dt>{t.brewingMethod}</dt>
                    <dd>{brewingMethod?.name}</dd>
                  </Fragment>
                )}
                {roastingDate && (
                  <Fragment>
                    <dt>{t.roastingDate}</dt>
                    <dd>{Intl.DateTimeFormat(Astro.currentLocale).format(new Date(roastingDate))}</dd>
                  </Fragment>
                )}
                {originFarm?.height && (
                  <Fragment>
                    <dt>{t.height}</dt>
                    <dd>{`${Intl.NumberFormat(Astro.currentLocale).format(originFarm.height)} m`}</dd>
                  </Fragment>
                )}
                {weight && (
                  <Fragment>
                    <dt>{t.weight}</dt>
                    <dd>{`${Intl.NumberFormat(Astro.currentLocale).format(weight)} g`}</dd>
                  </Fragment>
                )}
                {price && (
                  <Fragment>
                    <dt>{t.price}</dt>
                    <dd>{`${Intl.NumberFormat(Astro.currentLocale, {
                      style: 'currency',
                      currency: 'PLN'
                    }).format(price)}`}</dd>
                  </Fragment>
                )}
                {pricePerGram && (
                  <Fragment>
                    <dt>{t.pricePerGram}</dt>
                    <dd>{`${Intl.NumberFormat(Astro.currentLocale, {
                      style: 'currency',
                      currency: 'PLN'
                    }).format(pricePerGram)}`}</dd>
                  </Fragment>
                )}
              </dl>
            </section>
          </a>
        </li>
      )
    )
  }
</ul>
