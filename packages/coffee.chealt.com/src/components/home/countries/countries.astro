---
import { getRelativeLocaleUrl } from 'astro:i18n';

import './countries.css';

import allCountries from '../../../../data/countriesWithCoffees.json';

import allLocaleTranslations from './locales.json';
import allLocaleCommonTranslations from '../../common/common.json';

const t = allLocaleTranslations[Astro.currentLocale];
const tc = allLocaleCommonTranslations[Astro.currentLocale];

const countries = allCountries.filter(({ language_code }) => language_code === Astro.currentLocale);
---

<div class="list-container">
  <ul class="list countries">
    {
      countries.map(({ country_id: id, name }, index) => (
        <li class="item">
          <a href={getRelativeLocaleUrl(Astro.currentLocale, `/countries/${name}`)}>
            <div class="image card">
              <img
                src={`/countries/${id}.svg`}
                alt={`${t.country} ${name}`}
                loading={index >= 2 ? 'lazy' : undefined}
                fetchpriority={index >= 2 ? undefined : 'high'}
              />
            </div>
            <div class="name">{name}</div>
          </a>
        </li>
      ))
    }
  </ul>
</div>
