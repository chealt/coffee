---
import { getRelativeLocaleUrl } from "astro:i18n";

import "./countries.css";

import allCountries from "../../../../data/countriesWithCoffees.json" with { type: "json" };

import allLocaleTranslations from "./locales.json" with { type: "json" };
import allLocaleCommonTranslations from "../../common/locales.json" with { type: "json" };

const t =
  allLocaleTranslations[Astro.currentLocale] || allLocaleTranslations["en"];
const tc =
  allLocaleCommonTranslations[Astro.currentLocale] ||
  allLocaleCommonTranslations["en"];

const countries = allCountries.filter(
  ({ language_code }) => language_code === Astro.currentLocale,
);
---

<div class="list-container">
  <ul class="list countries">
    {
      countries.map(({ country_id: id, name }, index) => (
        <li class="item">
          <a
            href={getRelativeLocaleUrl(
              Astro.currentLocale,
              `/countries/${name}`,
            )}
          >
            <div class="image card">
              <img
                src={`/countries/${id}.svg`}
                alt={`${t.country} ${name}`}
                loading="lazy"
              />
            </div>
            <div class="name">{name}</div>
          </a>
        </li>
      ))
    }
  </ul>
</div>
