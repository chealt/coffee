---
import { getRelativeLocaleUrl } from "astro:i18n";

import "./countries.css";

import { getTranslator } from "@components/i18n/t.js";

import allCountries from "../../../../data/countriesWithCoffees.json" with { type: "json" };

const t = await getTranslator({
  filePath: "home/countries",
  locale: Astro.currentLocale,
});

const countries = allCountries.filter(
  ({ language_code }) => language_code === Astro.currentLocale,
);
---

<div class="list-container">
  <ul class="list countries">
    {
      countries.map(({ country_id: id, name }, index) => (
        <li class="item">
          <a
            href={getRelativeLocaleUrl(
              Astro.currentLocale,
              `/countries/${name}`,
            )}
          >
            <div class="image card">
              <img
                src={`/countries/${id}.svg`}
                alt={`${t("country")} ${name}`}
                loading="lazy"
              />
            </div>
            <div class="name">{name}</div>
          </a>
        </li>
      ))
    }
  </ul>
</div>
