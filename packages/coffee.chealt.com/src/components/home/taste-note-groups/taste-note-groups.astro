---
import { getRelativeLocaleUrl } from "astro:i18n";

import "./taste-note-groups.css";
import { encodeSafeURL } from "../../../utils/string.js";
import allLocaleCommonTranslations from "../../common/common.json" with { type: "json" };

const tc = allLocaleCommonTranslations[Astro.currentLocale];

const { groups } = Astro.props;
---

<div class="list-container">
  <ul class="list">
    {
      groups.map(({ taste_note_group_id: id, name, color, text_color }) => (
        <li class="item">
          <a
            href={getRelativeLocaleUrl(
              Astro.currentLocale,
              `/taste-note-groups/${encodeSafeURL(name)}`,
            )}
            class="card"
          >
            <div
              class="name"
              style={`background-color: ${color}; color: ${text_color}`}
            >
              {name}
            </div>
            <span
              class="tag primary left hidden"
              data-recommendation-key={`tasteNoteGroups-${id}`}
            >
              {tc.recommended}
            </span>
          </a>
        </li>
      ))
    }
  </ul>
</div>
