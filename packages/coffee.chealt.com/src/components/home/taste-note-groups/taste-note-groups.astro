---
import { getRelativeLocaleUrl } from 'astro:i18n';

import './taste-note-groups.css';

const { groups } = Astro.props;
---

<ul class="list">
  {
    groups.map(({ name, color }) => (
      <li class="item">
        <a
          href={getRelativeLocaleUrl(Astro.currentLocale, `/taste-note-groups/${encodeURIComponent(name)}`)}
          class="color"
          style={`background-color: ${color}; ${color === '#ebb40d' ? 'color: #4f4b43' : ''}`}
        >
          <div class="name">{name}</div>
        </a>
      </li>
    ))
  }
</ul>
