---
import Button from "../form/button/button.astro";
import Checkbox from "../form/checkbox/checkbox.astro";
import Icon from "../icon/icon.astro";

import countries from "../../../data/countries.json";

import "./coffee-filters.css";

import allLocaleTranslations from "./locales.json";

const t = allLocaleTranslations[Astro.currentLocale];
---

<coffee-filters>
  <div class="filters">
    <Button class="toggle-button">
      <Icon type="filter" />
      <span class="toggle-text">{t["filters"]}<sup>0</sup></span>
    </Button>
    <ul class="countries">
      {
        countries
          .filter(({ language_code }) => language_code === Astro.currentLocale)
          .map(({ country_id, name }) => (
            <li>
              <Checkbox
                type="button"
                name={`countryId-${country_id}`}
                value={country_id}
              >
                {name}
              </Checkbox>
            </li>
          ))
      }
    </ul>
    <Button class="clear-button">
      <span>{t["clearFilters"]}</span>
    </Button>
  </div>
</coffee-filters>

<script src="./coffee-filters.js"></script>
