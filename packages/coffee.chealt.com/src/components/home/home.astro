---
import cheapestCoffees from '@data/cheapestCoffees.json' with { type: 'json' };
import priciestCoffees from '@data/priciestCoffees.json' with { type: 'json' };
import tasteNoteGroups from '@data/tasteNoteGroups.json' with { type: 'json' };

import { convertToUSD } from '../coffees/utils.js';
import Coffees from '../coffees/list.astro';
import Common from '../common/common.astro';
import Countries from './countries/countries.astro';
import OriginCountries from './origin-countries/origin-countries.astro';
import Roasters from './roasters/roasters.astro';
import TasteNoteGroups from './taste-note-groups/taste-note-groups.astro';
import Wheel from '../taste-notes/taste-note-groups/wheel.astro';

import allLocaleTranslations from './locales.json' with { type: 'json' };
import allLocaleCommonTranslations from '../common/common.json' with { type: 'json' };

const t = allLocaleTranslations[Astro.currentLocale];
const tc = allLocaleCommonTranslations[Astro.currentLocale];

const groups = tasteNoteGroups.filter(({ language_code }) => language_code === Astro.currentLocale);

const recommendationsData = import.meta.glob('../../../data/recommendations/*.json', { eager: true });
const { loggedInUser } = Astro.locals;
const recommendedKey = Object.keys(recommendationsData).find(
  (key) => key === `../../../data/recommendations/${loggedInUser ? loggedInUser.username : 'anonymous'}.json`
);
const recommended = recommendationsData[recommendedKey] || {};
---

<Common>
  <h1>{t.title}<sup>beta</sup></h1>
  {
    recommended.coffees && (
      <section>
        <h2>{tc.recommended}</h2>
        <Coffees coffees={recommended.coffees} isRecommendedList />
      </section>
    )
  }
  {
    (priciestCoffees.length && (
      <section>
        <h2>{t.priciestCoffees}</h2>
        <Coffees coffees={priciestCoffees} />
      </section>
    )) ||
      null
  }
  {
    (cheapestCoffees.length && (
      <section>
        <h2>{t.cheapestCoffees}</h2>
        <Coffees coffees={cheapestCoffees} />
      </section>
    )) ||
      null
  }
  <section>
    <h2>{t.roasters}</h2>
    <Roasters />
  </section>
  <section>
    <h2>{t.originCountries}</h2>
    <OriginCountries />
  </section>
  <section>
    <h2>{t.countries}</h2>
    <Countries />
  </section>
  {
    (groups.length && (
      <section>
        <h2>{t.tasteNoteGroups}</h2>
        <TasteNoteGroups groups={groups} />
      </section>
    )) ||
      null
  }
  <section class="limit-width">
    <h2>{t.tasteNotesWheel}</h2>
    <Wheel />
  </section>
</Common>
