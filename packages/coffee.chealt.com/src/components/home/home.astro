---
import Coffees from './coffees/coffees.astro';
import Common from '../common/common.astro';
import OriginCountries from './origin-countries/origin-countries.astro';
import Roasters from './roasters/roasters.astro';

import './home.css';

import allLocaleTranslations from './locales.json';

const t = allLocaleTranslations[Astro.currentLocale];
---

<Common>
  <h1>{t.title}</h1>
  <section>
    <h2>{t.roasters}</h2>
    <Roasters />
  </section>
  <section>
    <h2>{t.originCountries}</h2>
    <OriginCountries />
  </section>
  <section>
    <h2>{t.coffees}</h2>
    <Coffees />
  </section>
</Common>
