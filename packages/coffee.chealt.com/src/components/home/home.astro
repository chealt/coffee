---
import { Image } from "astro:assets";
import Common from "../common/common.astro";

import roasters from "../../../data/roasters.json";
import countries from "../../../data/countries.json";

import "./home.css";

import allLocaleTranslations from "./locales.json";

const t = allLocaleTranslations[Astro.currentLocale];
const roasterCount = roasters.length || 0;
const roasterCountryCount = countries.filter(
  ({ language_code }) => language_code === Astro.currentLocale,
).length;

const roasterImages = await import.meta.glob(
  "/public/roasters/*.{jpeg,jpg,png,gif,svg,webp}",
  { eager: true },
);
---

<Common>
  <h1>{t["title"]}</h1>
  <section>
    <p>
      More than <span class="emphasized">{roasterCount}</span> roasters, from <span
        class="emphasized">{roasterCountryCount}</span
      > countries.
    </p>
    <ul class="roasters">
      {
        roasters
          .filter(({ logo }) => Boolean(logo))
          .map(({ name, logo }) => (
            <li>
              <div class="image">
                <Image
                  src={roasterImages[`/public/roasters/${logo}`].default}
                  alt={name}
                />
              </div>
              <div class="name">{name}</div>
            </li>
          ))
      }
    </ul>
  </section>
</Common>
