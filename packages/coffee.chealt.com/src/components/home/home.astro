---
import cheapestCoffees from "@data/cheapestCoffees.json" with { type: "json" };
import priciestCoffees from "@data/priciestCoffees.json" with { type: "json" };
import tasteNoteGroups from "@data/tasteNoteGroups.json" with { type: "json" };

import Coffees from "../coffees/list.astro";
import Common from "../common/common.astro";
import Countries from "./countries/countries.astro";
import Header from "./header/header.astro";
import OriginCountries from "./origin-countries/origin-countries.astro";
import Roasters from "./roasters/roasters.astro";
import TasteNoteGroups from "./taste-note-groups/taste-note-groups.astro";
import Wheel from "../taste-notes/taste-note-groups/wheel.astro";

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

const t = await getTranslator({
  filePath: "home",
  locale: Astro.currentLocale,
});
const tc = await getTranslator({
  filePath: "common",
  locale: Astro.currentLocale,
});

const groups = tasteNoteGroups.filter(
  ({ language_code }) => language_code === Astro.currentLocale,
);

const recommendationsData = import.meta.glob(
  "../../../data/recommendations/*.json",
  { eager: true },
);
const { loggedInUser } = Astro.locals;
const recommendedKey = Object.keys(recommendationsData).find(
  (key) =>
    key ===
    `../../../data/recommendations/${loggedInUser ? loggedInUser.username : "anonymous"}.json`,
);
const recommended = recommendationsData[recommendedKey] || {};
---

<Common>
  <Header>
    <h1>{t("title")}<sup>beta</sup></h1>
  </Header>
  {
    recommended.coffees && (
      <section>
        <h2><T namespace="common.locales" key="recommended">{tc("recommended")}</T></h2>
        <Coffees coffees={recommended.coffees} isRecommendedList />
      </section>
    )
  }
  {
    (priciestCoffees.length && (
      <section>
        <h2><T namespace="home.locales" key="priciestCoffees">{t("priciestCoffees")}</T></h2>
        <Coffees coffees={priciestCoffees} />
      </section>
    )) ||
      null
  }
  {
    (cheapestCoffees.length && (
      <section>
        <h2><T namespace="home.locales" key="cheapestCoffees">{t("cheapestCoffees")}</T></h2>
        <Coffees coffees={cheapestCoffees} />
      </section>
    )) ||
      null
  }
  <section>
    <h2><T namespace="home.locales" key="roasters">{t("roasters")}</T></h2>
    <Roasters />
  </section>
  <section>
    <h2><T namespace="home.locales" key="originCountries">{t("originCountries")}</T></h2>
    <OriginCountries />
  </section>
  <section>
    <h2><T namespace="home.locales" key="countries">{t("countries")}</T></h2>
    <Countries />
  </section>
  {
    (groups.length && (
      <section>
        <h2><T namespace="home.locales" key="tasteNoteGroups">{t("tasteNoteGroups")}</T></h2>
        <TasteNoteGroups groups={groups} />
      </section>
    )) ||
      null
  }
  <section class="limit-width">
    <h2><T namespace="home.locales" key="tasteNotesWheel">{t("tasteNotesWheel")}</T></h2>
    <Wheel />
  </section>
</Common>
