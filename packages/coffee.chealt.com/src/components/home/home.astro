---
import { Image } from "astro:assets";

import Button from "../button.astro";
import Common from "../common/common.astro";
import Checkbox from "../checkbox.astro";
import Icon from "../icon.astro";

import roasters from "../../../data/roasters.json";
import countries from "../../../data/countries.json";

import "./home.css";

import allLocaleTranslations from "./locales.json";

const t = allLocaleTranslations[Astro.currentLocale];
const roasterCount = roasters.length || 0;
const roasterCountryCount = countries.filter(
  ({ language_code }) => language_code === Astro.currentLocale,
).length;

const roasterImages = await import.meta.glob(
  "/public/roasters/*.{jpeg,jpg,png,gif,svg,webp}",
  { eager: true },
);
---

<Common>
  <h1>{t["title"]}</h1>
  <section class="roasters-container">
    <p>
      More than <span class="emphasized">{roasterCount}</span> roasters, from <span
        class="emphasized">{roasterCountryCount}</span
      > countries.
    </p>
    <coffee-filters>
      <div class="filters">
        <Button class="toggle-button">
          <Icon type="filter" />
          <span>{t["filters"]}</span>
        </Button>
        <ul class="countries">
          {
            countries.map(({ country_id, name }) => (
              <li>
                <Checkbox
                  type="button"
                  name={`countryId-${country_id}`}
                  value={country_id}
                >
                  {name}
                </Checkbox>
              </li>
            ))
          }
        </ul>
        <Button class="clear-button">
          <span>{t["clearFilters"]}</span>
        </Button>
      </div>
    </coffee-filters>
    <ul class="roasters">
      {
        roasters
          .filter(({ logo }) => Boolean(logo))
          .map(({ name, country_id, logo, website }) => (
            <li data-country-id={country_id} class="roaster">
              <a href={website} target="_blank" rel="noopener noreferrer">
                <div class="image">
                  <Image
                    src={roasterImages[`/public/roasters/${logo}`].default}
                    alt={name}
                  />
                </div>
                <div class="name">{name}</div>
              </a>
            </li>
          ))
      }
    </ul>
  </section>
</Common>

<script src="./coffee-filters.js"></script>
