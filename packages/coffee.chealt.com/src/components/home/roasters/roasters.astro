---
import { getRelativeLocaleUrl } from 'astro:i18n';

import roasters from '../../../../data/roastersWithCoffees.json';
import countries from '../../../../data/countries.json';

const roasterCount = roasters.length || 0;
const roasterCountryCount = countries.filter(({ language_code }) => language_code === Astro.currentLocale).length;

await import.meta.glob('/public/roasters/*.{jpeg,jpg,png,gif,svg,webp}', { eager: true });
---

<ul class="list">
  {
    roasters
      .filter(({ logo }) => Boolean(logo))
      .map(({ id, name, country_id, logo, website, instagram }) => (
        <li data-country-id={country_id} class="item">
          <a href={getRelativeLocaleUrl(Astro.currentLocale, `/roasters/${name}`)}>
            <div class="image card" style={`view-transition-name: roaster-${id}`}>
              <img src={`/roasters/${logo}`} alt={name} loading="lazy" />
            </div>
            <div class="name">{name}</div>
          </a>
        </li>
      ))
  }
</ul>
