---
import { getRelativeLocaleUrl } from "astro:i18n";

import { encodeSafeURL } from "../../utils/string.js";
import Button from "../form/button/button.astro";
import Icon from "../icon/icon.astro";

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

import "./list.css";

const t = await getTranslator({
  filePath: "roasters",
  locale: Astro.currentLocale,
});
const tc = await getTranslator({
  filePath: "common",
  locale: Astro.currentLocale,
});

const { roasters } = Astro.props;
---

<div class="list-container">
  <ul class="list">
    {
      roasters
        .filter(({ logo }) => Boolean(logo))
        .map(
          ({
            id,
            name,
            country_id,
            logo,
            website,
            instagram,
            coffee_count,
          }) => (
            <li data-country-id={country_id} class="item roaster">
              <a
                href={getRelativeLocaleUrl(
                  Astro.currentLocale,
                  `/roasters/${encodeSafeURL(name)}`,
                )}
              >
                <div
                  class="image card"
                  data-view-transition-name={`roaster-${id}`}
                >
                  <img
                    src={`/roasters/${logo}`}
                    alt={`${t("roasterLogo")} ${name}`}
                    loading="lazy"
                  />
                </div>
                <span
                  class="tag primary left hidden"
                  data-recommendation-key={`roasters-${id}`}
                >
                  <T namespace="common.locales" key="recommended">
                    {tc("recommended")}
                  </T>
                </span>
                <span class="bottom right banner">{coffee_count}</span>
              </a>
              <div class="name">
                {website && (
                  <Button class="tight" href={website} target="_blank">
                    <Icon class="icon-only" type="home" />
                    <span class="visually-hidden">
                      <T namespace="common.locales" key="website">
                        {tc("website")}
                      </T>
                    </span>
                  </Button>
                )}
                <span class="text">{name}</span>
                {instagram && (
                  <Button
                    class="tight"
                    href={`https://instagram.com/${instagram}`}
                    target="_blank"
                  >
                    <Icon class="icon-only" type="instagram" />
                    <span class="visually-hidden">
                      <T namespace="common.locales" key="instagram">
                        {tc("instagram")}
                      </T>
                    </span>
                  </Button>
                )}
              </div>
            </li>
          ),
        )
    }
  </ul>
</div>
