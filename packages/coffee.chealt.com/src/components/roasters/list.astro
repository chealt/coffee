---
import { getRelativeLocaleUrl } from 'astro:i18n';

import countries from '@data/countries.json' with { type: 'json' };
import { encodeSafeURL } from '../../utils/string.js';
import Button from '../form/button/button.astro';
import Icon from '../icon/icon.astro';

import './list.css';

import allLocaleTranslations from './locales.json' with { type: 'json' };
import allLocaleCommonTranslations from '../common/common.json' with { type: 'json' };

const t = allLocaleTranslations[Astro.currentLocale];
const tc = allLocaleCommonTranslations[Astro.currentLocale];

const { roasters } = Astro.props;
const recommendationsData = import.meta.glob('../../../data/recommendations/*.json', { eager: true });
const { loggedInUser } = Astro.locals;
const recommendedKey = Object.keys(recommendationsData).find(
  (key) => key === `../../../data/recommendations/${loggedInUser ? loggedInUser.username : 'anonymous'}.json`
);
const recommended = recommendationsData[recommendedKey];
---

<div class="list-container">
  <ul class="list">
    {
      roasters
        .filter(({ logo }) => Boolean(logo))
        .map(({ id, ...rest }) => ({
          id,
          ...rest,
          isRecommended: recommended?.roasters?.includes(id)
        }))
        .map(({ id, name, country_id, isRecommended, logo, website, instagram }, index) => (
          <li data-country-id={country_id} class="item roaster">
            <a href={getRelativeLocaleUrl(Astro.currentLocale, `/roasters/${encodeSafeURL(name)}`)}>
              <div class="image card" style={`view-transition-name: roaster-${id}`}>
                <img src={`/roasters/${logo}`} alt={`${t.roasterLogo} ${name}`} loading="lazy" />
              </div>
              {isRecommended && <span class="tag primary left">{tc.recommended}</span>}
            </a>
            <div class="name">
              {website && (
                <Button class="tight" href={website} target="_blank" rel="noopener noreferrer">
                  <Icon class="icon-only" type="home" />
                </Button>
              )}
              <span class="text">{name}</span>
              {instagram && (
                <Button
                  class="tight"
                  href={`https://instagram.com/${instagram}`}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Icon class="icon-only" type="instagram" />
                </Button>
              )}
            </div>
          </li>
        ))
    }
  </ul>
</div>
