---
import { getRelativeLocaleUrl } from 'astro:i18n';

import allCoffees from '../../../data/coffees.json';
import roasters from '../../../data/roasters.json';

import Button from '../form/button/button.astro';
import Icon from '../icon/icon.astro';
import Common from '../common/common.astro';
import Coffees from '../coffees/list.astro';
import { getConvertedPrice, getDetails } from '../coffees/utils.js';

import './roaster.css';
import '../stats/stats.css';

import allLocaleTranslations from './locales.json';

const t = allLocaleTranslations[Astro.currentLocale];

const { currency, loggedInUser } = Astro.locals;
const { id } = Astro.props;

const { name, logo, instagram, website } = roasters.find((roaster) => roaster.id === id);
const coffees = allCoffees
  .map(getDetails({ locale: Astro.currentLocale }))
  .map(({ pricePerGram, ...coffee }) => ({
    ...coffee,
    pricePerGram: getConvertedPrice({ price: pricePerGram, currency })
  }))
  .sort((a, b) => a.pricePerGram - b.pricePerGram);
const maxPricePerGram = coffees[coffees.length - 1].pricePerGram;
const roastersWithCoffee = Array.from(new Set(allCoffees.map(({ roaster_id }) => roaster_id)))
  .map((roasterId) => roasters.find(({ id }) => id === roasterId))
  .map((roaster) => ({
    ...roaster,
    coffees: coffees.filter(({ roaster: { id: roasterId } }) => roasterId === roaster.id)
  }));
---

<Common>
  <h1>
    <div>{name}</div>
    {
      loggedInUser && (
        <Button class="ghost" href={getRelativeLocaleUrl(Astro.currentLocale, `/roasters/${name}`)}>
          <Icon type="back" />
          <span class="visually-hidden">{t.back}</span>
        </Button>
      )
    }
  </h1>
  <section>
    <h2>{t.pricesPerGram}</h2>
    <div class="card">
      <coffee-stats data-default-label={id}>
        <div class="stats">
          <div class="chart-inner">
            <div class="dots">
              {
                roastersWithCoffee.map(({ id: roasterId, coffees }) =>
                  coffees.map(({ pricePerGram }, coffeeIndex) => (
                    <Fragment>
                      <div
                        class={`dot ${roasterId === id ? 'active' : ''}`}
                        style={`bottom: ${pricePerGram / (maxPricePerGram / 100)}%; left: ${coffeeIndex / (coffees.length / 100)}%`}
                        data-label={roasterId}
                      />
                    </Fragment>
                  ))
                )
              }
            </div>
            <div class="labels">
              {
                roastersWithCoffee.map(({ id, name, coffees }) => (
                  <Fragment>
                    <div class="label x" data-dot={id}>
                      {name}
                    </div>
                  </Fragment>
                ))
              }
            </div>
          </div>
        </div>
      </coffee-stats>
    </div>
  </section>
</Common>

<script src="./stats.js"></script>
