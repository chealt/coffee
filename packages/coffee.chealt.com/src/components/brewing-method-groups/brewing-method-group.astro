---
import { getRelativeLocaleUrl } from "astro:i18n";

import brewingMethodGroups from "../../../data/brewingMethodGroups.json" with { type: "json" };
import brewingMethods from "../../../data/brewingMethods.json" with { type: "json" };
import allCoffees from "../../../data/coffees.json" with { type: "json" };

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";
import { convertToUSD } from "../coffees/utils.js";
import Button from "../form/button/button.astro";
import Coffees from "../coffees/list.astro";
import Common from "../common/common.astro";
import Icon from "../icon/icon.astro";

const t = await getTranslator({
  filePath: "common",
  locale: Astro.currentLocale,
});

const { loggedInUser } = Astro.locals;
const { id } = Astro.props;

const { name } = brewingMethodGroups.find((group) => group.id === id);
const brewingMethodIdsInGroup = brewingMethods
  .filter(
    ({ brewing_method_group_id }) =>
      !brewing_method_group_id || brewing_method_group_id === id,
  )
  .map(({ brewing_method_id }) => brewing_method_id);
const coffees = allCoffees.filter(
  ({ brewing_method_id }) =>
    brewing_method_id && brewingMethodIdsInGroup.includes(brewing_method_id),
);
const priciestCoffees = coffees
  .sort(
    (a, b) =>
      convertToUSD({ currency: b.currency, price: b.price_per_gram }) -
      convertToUSD({ currency: a.currency, price: a.price_per_gram }),
  )
  .slice(0, 10);
const cheapestCoffees = coffees
  .sort(
    (a, b) =>
      convertToUSD({ currency: a.currency, price: a.price_per_gram }) -
      convertToUSD({ currency: b.currency, price: b.price_per_gram }),
  )
  .slice(0, 10);
---

<Common>
  <h1 class="title">
    <div>{name}</div>
    {
      loggedInUser && (
        <Button
          class="ghost small"
          href={getRelativeLocaleUrl(
            Astro.currentLocale,
            `/brewing-method-groups/${name}/stats`,
          )}
        >
          <Icon type="chart" />
          <span class="visually-hidden"><T namespace="common.locales" key="chart">{t("chart")}</T></span>
        </Button>
      )
    }
  </h1>
  {
    (priciestCoffees.length && (
      <section>
        <h2><T namespace="common.locales" key="priciestCoffees">{t("priciestCoffees")}</T></h2>
        <Coffees coffees={priciestCoffees} />
      </section>
    )) ||
      null
  }
  {
    (cheapestCoffees.length && (
      <section>
        <h2><T namespace="common.locales" key="cheapestCoffees">{t("cheapestCoffees")}</T></h2>
        <Coffees coffees={cheapestCoffees} />
      </section>
    )) ||
      null
  }
  {
    (coffees.length && (
      <section>
        <h2><T namespace="common.locales" key="allCoffees">{t("allCoffees")}</T></h2>
        <Coffees coffees={coffees} />
      </section>
    )) ||
      null
  }
</Common>
