---
import Analytics from "./analytics.astro";
import IosPolyfills from "./ios-polyfills.astro";
import Login from "../login/login.astro";
import Nav from "./nav/nav.astro";
import TranslationBanner from "../i18n/banner.astro";
import I18NContainer from "../i18n/container.astro";

import loaderImage from "./loader.svg";

import { getTranslator } from "@components/i18n/t.js";

import "./common.css";

const t = await getTranslator({
  filePath: "common",
  locale: Astro.currentLocale,
});

const { shouldAuthenticate, redirectUrl, title, hideNav = false } = Astro.props;
const { isTranslating } = Astro.locals;

const isProd = import.meta.env.PROD;
---

<!doctype html>
<html lang={Astro.currentLocale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="theme-color" content="#e1a76d" />
    <meta name="description" content={t("description")} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/favicons/favicon-192x192.svg" />
    <title>{title ? `${title} | ${t("title")}` : t("title")}</title>
    {Astro.locals.isIOS && <IosPolyfills />}
  </head>
  <body>
    {isTranslating && <I18NContainer locale={Astro.currentLocale} />}
    <chealt-data>
      {isTranslating && <TranslationBanner />}
      <coffee-recommendations
        data-recommendations-url="/api/recommendations/all.json"
      >
        <main class={Astro.props.class}>
          {shouldAuthenticate ? <Login redirectUrl={redirectUrl} /> : <slot />}
        </main>
      </coffee-recommendations>
      {!hideNav && <Nav />}
    </chealt-data>
    <img src={loaderImage.src} class="visually-hidden" aria-hidden="true" />
    {isProd && <Analytics />}
  </body>
</html>

<script src="./service-worker-init.js"></script>
<script src="../chealt-data.js"></script>
<script src="./recommendations.js"></script>
