---
import Nav from "./nav.astro";
import IosPolyfills from "./ios-polyfills.astro";

import "./common.css";

import allLocaleTranslations from "./common.json";

const t = allLocaleTranslations[Astro.currentLocale];
---

<!doctype html>
<html lang={Astro.currentLocale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="theme-color" content="#e1a76d" />
    <meta name="description" content={t["description"]} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="apple-touch-icon" href="/favicons/favicon-192x192.svg" />
    <title>{t.title}</title>
    {Astro.locals.isIOS && <IosPolyfills />}
  </head>
  <body>
    <main>
      <slot />
    </main>
    <Nav />
  </body>
</html>
