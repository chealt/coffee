---
import { getRelativeLocaleUrl } from "astro:i18n";

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";
import Icon from "@components/icon/icon.astro";

import "./nav.css";

const t = await getTranslator({
  filePath: "common/nav",
  locale: Astro.currentLocale,
});

const isActivePage = (pageName) => {
  const { pathname } = Astro.url;
  const firstPathParam = pathname
    .replace(`${Astro.currentLocale}`, "")
    .slice(1);

  return pageName === ""
    ? firstPathParam === "" ||
        firstPathParam === "/" ||
        !pathname.includes("/you")
    : firstPathParam.includes(pageName);
};

const items = [
  {
    name: "home",
    href: getRelativeLocaleUrl(Astro.currentLocale, "/"),
    textKey: "explore",
    isActive: isActivePage(""),
  },
  {
    name: "you",
    href: getRelativeLocaleUrl(Astro.currentLocale, "/you/collections"),
    textKey: "you",
    isActive: isActivePage("you"),
  },
];
---

<nav style={"view-transition-name: main-nav"}>
  {
    items.map(({ name, href, textKey, isActive }) => (
      <a href={href} class={isActive ? "active" : ""}>
        <Icon class="icon" type={name} />
        <span class="title">
          <T namespace="common.nav.locales" key={textKey}>
            {t(textKey)}
          </T>
        </span>
      </a>
    ))
  }
</nav>
