---
import { getRelativeLocaleUrl } from 'astro:i18n';
import CoffeeImageUpload from './coffee-image-upload.astro';
import Icon from '../icon/icon.astro';
import allLocaleTranslations from './nav.json';

import './nav.css';

const t = allLocaleTranslations[Astro.currentLocale];

const isActivePage = (pageName) => {
  const { pathname } = Astro.url;
  const firstPathParam = pathname.replace(`${Astro.currentLocale}`, '').slice(1);

  return pageName === ''
    ? firstPathParam === '' || firstPathParam === '/' || !pathname.includes('/you')
    : firstPathParam.includes(pageName);
};

const items = [
  {
    name: 'home',
    href: getRelativeLocaleUrl(Astro.currentLocale, '/'),
    text: t.explore,
    isActive: isActivePage('')
  },
  {
    name: 'capture',
    href: getRelativeLocaleUrl(Astro.currentLocale, '/you/collections'),
    text: t.capture
  },
  {
    name: 'you',
    href: getRelativeLocaleUrl(Astro.currentLocale, '/you/collections'),
    text: t.you,
    isActive: isActivePage('you')
  }
];

const shouldSync = Boolean(Astro.locals.loggedInUser);
---

<nav style={'view-transition-name: main-nav'}>
  {
    items.map(({ name, href, text, isActive }) =>
      name === 'capture' ? (
        <CoffeeImageUpload data-should-sync={shouldSync} data-unnamed-title={t.unnamedTitle}>
          <a href={href} class="triggerButton">
            <Icon class="icon" type={name} />
            <span class="title">{text}</span>
          </a>
        </CoffeeImageUpload>
      ) : (
        <a href={href} class={isActive ? 'active' : ''}>
          <Icon class="icon" type={name} />
          <span class="title">{text}</span>
        </a>
      )
    )
  }
</nav>
