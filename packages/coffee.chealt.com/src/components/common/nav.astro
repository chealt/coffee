---
import { getRelativeLocaleUrl } from "astro:i18n";
import CoffeeImageUpload from "./coffee-image-upload.astro";
import Icon from "../icon.astro";
import allLocaleTranslations from "./nav.json";

import "./nav.css";

const t = allLocaleTranslations[Astro.currentLocale];

const isActivePage = (pageName) => {
  const firstPathParam = Astro.url.pathname
    .replace(`${Astro.currentLocale}`, "")
    .slice(1);

  return (
    firstPathParam === `/${pageName}` ||
    firstPathParam === `/${pageName}/` ||
    firstPathParam === `${pageName}` ||
    firstPathParam === `${pageName}/`
  );
};

const items = [
  {
    name: "home",
    href: getRelativeLocaleUrl(Astro.currentLocale, "/"),
    text: t["explore"],
    isActive: isActivePage(""),
  },
  {
    name: "capture",
    href: getRelativeLocaleUrl(Astro.currentLocale, "/collections"),
    text: t["capture"],
  },
  {
    name: "collections",
    href: getRelativeLocaleUrl(Astro.currentLocale, "/collections"),
    text: t["collections"],
    isActive: isActivePage("collections"),
  },
  {
    name: "settings",
    href: getRelativeLocaleUrl(Astro.currentLocale, "/settings"),
    text: t["settings"],
    isActive: isActivePage("settings"),
  },
];
---

<nav>
  {
    items.map(({ name, href, text, isActive }) =>
      name === "capture" ? (
        <CoffeeImageUpload>
          <a href={href} class="triggerButton">
            <Icon class="icon" type={name} />
            <span class="title">{text}</span>
          </a>
        </CoffeeImageUpload>
      ) : (
        <a href={href} class={isActive ? "active" : ""}>
          <Icon class="icon" type={name} />
          <span class="title">{text}</span>
        </a>
      ),
    )
  }
</nav>
