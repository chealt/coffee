---
const getSignedUrl = Astro.locals.getSignedUrl;
---

<coffee-image-upload {...Astro.props} data-get-signed-url={getSignedUrl}>
  <input type="file" class="visually-hidden" accept="image/*;capture=camera" inert />
  <slot />
</coffee-image-upload>

<script src="./coffee-image-upload.js"></script>
