---
import { getRelativeLocaleUrl } from "astro:i18n";

import Button from "../form/button/button.astro";
import Common from "../common/common.astro";
import Features from "../features/features.astro";
import Form from "../form/form.astro";
import Input from "../form/input/input.astro";
import Label from "../form/label/label.astro";

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

const t = await getTranslator({
  filePath: "registration",
  locale: Astro.currentLocale,
});
---

<Common title={t("title")}>
  <h1><T namespace="registration.locales" key="title">{t("title")}</T></h1>
  <section>
    <Form
      name="new-user.json"
      data-storage="api"
      data-save-endpoint="/api/authentication/registration"
    >
      <Label>
        {t("email")}
        <Input name="email" type="email" required />
      </Label>
      <Button class="primary" type="submit"><T namespace="registration.locales" key="register">{t("register")}</T></Button>
      <p data-error-code="EMAIL_ALREADY_EXISTS" class="error hidden">
        <T namespace="registration.locales" key="emailAlreadyExists">{t("emailAlreadyExists")}</T>
      </p>
      <p data-error-code="RATE_LIMIT_EXCEEDED" class="error hidden">
        <T namespace="registration.locales" key="rateLimitExceeded">{t("rateLimitExceeded")}</T>
      </p>
      <p data-error-code="FAILED_TO_REGISTER" class="error hidden">
        <T namespace="registration.locales" key="failedToRegister">{t("failedToRegister")}</T>
      </p>
      <p data-success class="success hidden"><T namespace="registration.locales" key="success">{t("success")}</T></p>
    </Form>
  </section>
  <section>
    <Button
      class="bordered"
      href={getRelativeLocaleUrl(Astro.currentLocale, `/you/collections`)}
      ><T namespace="registration.locales" key="login">{t("login")}</T></Button
    >
  </section>
  <section>
    <Features />
  </section>
</Common>
