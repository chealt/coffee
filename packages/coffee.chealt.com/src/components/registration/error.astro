---
import Common from "../common/common.astro";

import "./registration.css";

import allLocaleTranslations from "./locales.json" with { type: "json" };

const t =
  allLocaleTranslations[Astro.currentLocale] || allLocaleTranslations["en"];

const errorName = Astro.url.searchParams.get("name");
---

<Common>
  <h1>{t.error.title}</h1>
  <div class="error">
    <p class="error-message">
      {t.error.message[errorName] || t.error.message.default}
    </p>
  </div>
</Common>
