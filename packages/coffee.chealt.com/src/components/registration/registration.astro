---
import { getRelativeLocaleUrl } from "astro:i18n";

import Button from "../form/button/button.astro";
import Common from "../common/common.astro";
import Form from "../form/form.astro";
import Input from "../form/input/input.astro";
import Label from "../form/label/label.astro";

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

import "./registration.css";

const t = await getTranslator({
  filePath: "registration",
  locale: Astro.currentLocale,
});

const { username } = Astro.props;
---

<Common>
  <h1><T namespace="registration.locales" key="title">{t("title")}</T></h1>
  <chealt-auth
    data-registration-options={Astro.locals.registrationOptions}
    data-verify-endpoint="/api/authentication/registration/verify.json"
    data-redirect-url="/"
    data-not-supported-message={t("notSupportedBrowser")}
  >
    <div data-registration-success class="hidden"><T namespace="registration.locales" key="registrationSuccess">{t("registrationSuccess")}</T></div>
    <div data-registration-error class="error hidden">
      <div class="error-message"><T namespace="registration.locales" key="registrationError">{t("registrationError")}</T></div>
    </div>
    <div
      data-registration-error-authenticator-previously-registered
      class="error hidden"
    >
      <div class="error-message">
        <T namespace="registration.locales" key="registrationErrorAuthenticatorPreviouslyRegistered">{t("registrationErrorAuthenticatorPreviouslyRegistered")}</T>
      </div>
      <Button href={getRelativeLocaleUrl(Astro.currentLocale, "/login")}
        ><T namespace="registration.locales" key="login">{t("login")}</T></Button
      >
    </div>
    <Form method="post">
      <section>
        <Label>
          {t("username")}
          <Input
            type="text"
            name="username"
            autocomplete="username"
            value={username}
            readonly={username ? true : false}
            disabled={username ? true : false}
          />
        </Label>
      </section>
      <section>
        <Button type="submit" class="primary"><T namespace="registration.locales" key="register">{t("register")}</T></Button>
      </section>
    </Form>
  </chealt-auth>
</Common>

<script src="../chealt-auth.js"></script>
