---
import { getRelativeLocaleUrl } from "astro:i18n";

import Button from '../form/button/button.astro';
import Common from "../common/common.astro";
import Form from '../form/form.astro';
import Input from '../form/input/input.astro';
import Label from '../form/label/label.astro';

import './registration.css';

import allLocaleTranslations from "./locales.json";

const t = allLocaleTranslations[Astro.currentLocale];

const { username } = Astro.props;
---

<Common>
  <h1>{t["title"]}</h1>
  <chealt-auth
    data-registration-options={Astro.locals.registrationOptions}
    data-verify-endpoint="/api/authentication/registration/verify.json"
    data-redirect-url="/">
    <div data-registration-success class="hidden">{t["registrationSuccess"]}</div>
    <div data-registration-error class="error hidden">
      <div class="error-message">{t["registrationError"]}</div>
    </div>
    <div data-registration-error-authenticator-previously-registered class="error hidden">
      <div class="error-message">{t["registrationErrorAuthenticatorPreviouslyRegistered"]}</div>
      <Button href={getRelativeLocaleUrl(Astro.currentLocale, "/login")}>{t["login"]}</Button>
    </div>
    <Form method="post">
      <Label>
        {t["username"]}
        <Input
        type="text"
        name="username"
        autocomplete="username"
        value={username}
        readonly={username ? true : false}
        disabled={username ? true : false} />
      </Label>
      <Button type="submit" class="primary">{t["register"]}</Button>
    </Form>
  </chealt-auth>
</Common>

<script src="../chealt-auth.js"></script>
