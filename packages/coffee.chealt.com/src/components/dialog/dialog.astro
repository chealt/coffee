---
import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";
import Button from "../form/button/button.astro";
import Icon from "../icon/icon.astro";

import "./dialog.css";

const t = await getTranslator({
  filePath: "dialog",
  locale: Astro.currentLocale,
});

const { reloadOnChange, showClose, ...props } = Astro.props;
---

<coffee-dialog data-reload-on-change={reloadOnChange || undefined}>
  <dialog {...props}>
    {
      showClose && (
        <Button data-close-button class="small bordered round">
          <Icon type="close" class="icon-only" />
          <span class="visually-hidden"><T namespace="dialog.locales" key="close">{t("close")}</T></span>
        </Button>
      )
    }
    <slot />
  </dialog>
</coffee-dialog>

<script src="./dialog.js"></script>
