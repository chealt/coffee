---
import Common from '../../common/common.astro';
import Form from '../../form/form.astro';
import Label from '../../form/label/label.astro';
import Icon from '../../icon/icon.astro';
import Input from '../../form/input/input.astro';
import Radio from '../../form/radio/radio.astro';
import RadioList from '../../form/radio/radio-list.astro';
import Range from '../../form/range/range.astro';
import Textarea from '../../form/input/textarea.astro';

import './cupping.css';

import allLocaleTranslations from './locales.json';

const { locale } = Astro.params;

const t = allLocaleTranslations[locale];
---

<Common title={t.title}>
  <h1>{t.title}</h1>
  <section class="cupping-container">
    <Form
      class="review-form"
      name="cupping"
      data-storage="localStorage"
      data-save-on-input
      data-sum-group-name="cupping"
    >
      <div class="final-score-container primary">
        <span>{t['final-score']}</span>
        <span class="final-score" data-sum="cupping"></span>
      </div>
      <div class="range-group">
        <Range name="roast-level" min="1" max="5" excludeFromSum>
          <span slot="title">{t['roast-level']}</span>
          <span slot="min">{t['light']}</span>
          <span slot="max">{t['dark']}</span>
        </Range>
      </div>
      <div class="range-group">
        <div class="range-group-item">
          <Range name="aroma" min="6" max="10">
            <span slot="title">{t['fragrance-aroma']}</span>
            <span slot="min">{6}</span>
            <span slot="max">{10}</span>
          </Range>
        </div>
        <div class="range-group-item">
          <Range name="dry" min="1" max="5" excludeFromSum>
            <span slot="title">{t['dry']}</span>
            <span slot="min">{1}</span>
            <span slot="max">{5}</span>
          </Range>
          <Range name="break" min="1" max="5" excludeFromSum>
            <span slot="title">{t['break']}</span>
            <span slot="min">{1}</span>
            <span slot="max">{5}</span>
          </Range>
        </div>
      </div>
      <div class="range-group">
        <Range name="flavour" min="6" max="10">
          <span slot="title">{t['flavour']}</span>
          <span slot="min">{6}</span>
          <span slot="max">{10}</span>
        </Range>
        <Range name="aftertaste" min="6" max="10">
          <span slot="title">{t['aftertaste']}</span>
          <span slot="min">{6}</span>
          <span slot="max">{10}</span>
        </Range>
      </div>
      <div class="range-group">
        <Range name="acidity" min="6" max="10">
          <span slot="title">{t.acidity}</span>
          <span slot="min">{t.bitter}</span>
          <span slot="max">{t.acidic}</span>
        </Range>
        <Range name="intensity" min="1" max="5" excludeFromSum>
          <span slot="title">{t['intensity']}</span>
          <span slot="min">{t['low']}</span>
          <span slot="max">{t['high']}</span>
        </Range>
      </div>
      <div class="range-group">
        <Range name="body" min="6" max="10">
          <span slot="title">{t['body']}</span>
          <span slot="min">{6}</span>
          <span slot="max">{10}</span>
        </Range>
        <Range name="level" min="1" max="5" excludeFromSum>
          <span slot="title">{t['level']}</span>
          <span slot="min">{t['thin']}</span>
          <span slot="max">{t['heavy']}</span>
        </Range>
      </div>
      <div class="range-group">
        <Range name="uniformity" min="6" max="10">
          <span slot="title">{t['uniformity']}</span>
          <span slot="min">{6}</span>
          <span slot="max">{10}</span>
        </Range>
        <Range name="balance" min="6" max="10">
          <span slot="title">{t['balance']}</span>
          <span slot="min">{6}</span>
          <span slot="max">{10}</span>
        </Range>
      </div>
      <div class="range-group">
        <Range name="clean-cup" min="6" max="10">
          <span slot="title">{t['clean-cup']}</span>
          <span slot="min">{6}</span>
          <span slot="max">{10}</span>
        </Range>
        <Range name="sweetness" min="6" max="10">
          <span slot="title">{t.sweetness}</span>
          <span slot="min">{t.sour}</span>
          <span slot="max">{t.sweet}</span>
        </Range>
      </div>
      <div class="range-group">
        <Range name="overall" min="6" max="10">
          <span slot="title">{t.overall}</span>
          <span slot="min">{6}</span>
          <span slot="max">{10}</span>
        </Range>
        <section>
          <fieldset class="range-group-item-container">
            <legend>{t.defects}</legend>
            <div class="range-group-item-container">
              <Label>
                <span>{t['number-of-cups']}</span>
                <Input name="number-of-cups" data-negative type="number" />
              </Label>
              <span class="times-sign">x</span>
              <Label>
                <span>{t.intensity}</span>
                <Input name="defects-intensity" data-multiplier="number-of-cups" type="number" />
              </Label>
            </div>
          </fieldset>
        </section>
      </div>
      <Label>
        <span>{t.notes}</span>
        <Textarea name="notes" />
      </Label>
    </Form>
  </section>
</Common>
