---
import Label from "../label.astro";
import Select from "../select.astro";
import originRegions from "../../../data/originRegions.json";
import allLocaleTranslations from "../../../locales/scan/scan.json";

const t = allLocaleTranslations[Astro.currentLocale];
---

<Label>{t["originRegion"]}</Label>
<Select name="originRegion" showEmpty>
  {
    originRegions
      .filter(({ language_code }) => language_code === Astro.currentLocale)
      .map(({ origin_region_id, name }) => (
        <option value={origin_region_id}>{name}</option>
      ))
  }
</Select>
