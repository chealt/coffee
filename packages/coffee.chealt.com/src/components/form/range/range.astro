---
import Label from '../label/label.astro';

import './range.css';
---

<Label class={Astro.props.vertical ? 'vertical' : undefined}>
  <slot name="title" />
  <input
    type="range"
    data-exclude-from-sum={Astro.props.excludeFromSum ? 'true' : undefined}
    name={Astro.props.name}
    min={Astro.props.min || 1}
    max={Astro.props.max || 10}
  />
  <div class="labels-container">
    <span><slot name="min" /></span>
    <span>-</span>
    <span><slot name="max" /></span>
  </div>
</Label>
