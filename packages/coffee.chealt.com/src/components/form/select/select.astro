---
import Button from "../button/button.astro";
import Dialog from "../../dialog/dialog.astro";
import Icon from "../../icon/icon.astro";
import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";
import Input from "../input/input.astro";

import "./select.css";

const t = await getTranslator({
  filePath: "common",
  locale: Astro.currentLocale,
});

const {
  id,
  name,
  multiple,
  reloadOnChange,
  searchable,
  selected,
  selectedValue,
  selectedLabel,
  showEmpty,
  ...props
} = Astro.props;
---

{
  ((multiple || searchable) && (
    <coffee-select data-searchable>
      {searchable && <input type="hidden" name={name} value={selectedValue} />}
      <Button
        id={id}
        data-dialog-id={name}
        class={`column input ${searchable ? "combobox" : ""}`}
        role="combobox"
      >
        {(searchable && (
          <div class="input-value">{selectedLabel || t("unknown")}</div>
        )) || (
          <Fragment>
            <Icon type="edit" />
            <T namespace="common.locales" key="select">{t("select")}</T>
          </Fragment>
        )}
      </Button>
      <Dialog id={name} class="drawer fixed" reloadOnChange={reloadOnChange}>
        <chealt-filter
          data-filter-selector={`${multiple ? `li:has([name='${name}[]'])` : `li[name='${name}[]']`}`}
        >
          <Input name={`${name}-filter`} placeholder={t("search")} data-exclude />
        </chealt-filter>
        <ul role="listbox">
          <slot />
        </ul>
      </Dialog>
    </coffee-select>
  )) || (
    <select {...props} name={name || undefined}>
      {showEmpty && <option value=""><T namespace="common.locales" key="unknown">{t("unknown")}</T></option>}
      <slot />
    </select>
  )
}

<script src="../../chealt-filter.js"></script>
<script src="./select.js"></script>
