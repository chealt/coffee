---
import allLocaleTranslations from '../../common/common.json';

import './select.css';

const t = allLocaleTranslations[Astro.currentLocale];
---

<select {...Astro.props}>
  {
    Astro.props.showEmpty && (
      <option value="" selected>
        {t['unknown']}
      </option>
    )
  }
  <slot />
</select>
