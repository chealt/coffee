---
import './icon.css';

const images = import.meta.glob('/public/icons/*.svg', {
  eager: true,
  query: '?raw',
  import: 'default'
});

const { type } = Astro.props;
const Icon = images[`/public/icons/${type}.svg`];

let className = 'icon';

if (Astro.props.class) {
  className += ` ${Astro.props.class}`;
}

if (!Icon) {
  throw new Error(`"${type}" does not exist in glob: "/public/icons/*.svg"`);
}
---

<span class=`${className}`>
  <Fragment set:html={Icon} />
</span>
