---
import { Image } from "astro:assets";

const images = import.meta.glob("/public/icons/*.svg");

const { type } = Astro.props;
const icon = images[`/public/icons/${type}.svg`];

if (!icon) {
  throw new Error(`"${type}" does not exist in glob: "/public/icons/*.svg"`);
}
---

<span class={Astro.props.class}>
  <Image src={icon()} alt={Astro.props.type} />
</span>
