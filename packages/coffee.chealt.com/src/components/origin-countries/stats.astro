---
import { getRelativeLocaleUrl } from 'astro:i18n';

import allCoffees from '../../../data/coffees.json';
import brewingMethods from '../../../data/brewingMethods.json';
import countries from '../../../data/countries.json';
import originCountries from '../../../data/originCountries.json';
import roasters from '../../../data/roasters.json';
import tasteNoteGroups from '../../../data/tasteNoteGroups.json';

import Button from '../form/button/button.astro';
import Icon from '../icon/icon.astro';
import Common from '../common/common.astro';
import Coffees from '../coffees/list.astro';
import { convertToUSD, getDetails } from '../coffees/utils.js';
import { getTasteNoteGroup, getTasteNoteGroupByNoteId } from '../taste-notes/utils.js';
import { titleCase } from '../../utils/string.js';

import '../stats/stats.css';

import allLocaleTranslations from '../common/common.json';

const t = allLocaleTranslations[Astro.currentLocale];

const { currency, loggedInUser, shouldAuthenticate } = Astro.locals;
const { id, brewingMethodId, countryId } = Astro.props;

const { name } = originCountries.find((originCountry) => originCountry.origin_country_id === id);
const country =
  countryId &&
  countries.find(({ country_id, language_code }) => country_id === countryId && language_code === Astro.currentLocale);
const brewingMethod =
  brewingMethodId &&
  brewingMethods.find(
    ({ brewing_method_id, language_code }) =>
      brewing_method_id === brewingMethodId && language_code === Astro.currentLocale
  );
const coffees = allCoffees
  .map(getDetails({ locale: Astro.currentLocale }))
  .map(({ pricePerGram, ...coffee }) => ({
    ...coffee,
    pricePerGram: convertToUSD({ price: pricePerGram, currency })
  }))
  .sort((a, b) => a.pricePerGram - b.pricePerGram);
const maxPricePerGram = coffees[coffees.length - 1].pricePerGram;
const originCountriesWithCoffee = originCountries
  .filter(({ language_code }) => language_code === Astro.currentLocale)
  .map((originCountry) => ({
    ...originCountry,
    coffees: coffees
      .filter(({ originCountry: { origin_country_id } }) => origin_country_id === originCountry.origin_country_id)
      .filter(
        ({
          roaster: {
            country: { id: roasterCountryId }
          }
        }) => (countryId ? roasterCountryId === countryId : true)
      )
      .filter(({ brewingMethod }) => (brewingMethodId ? brewingMethod?.brewing_method_id === brewingMethodId : true))
  }))
  .filter(({ coffees }) => coffees.length)
  .map((originCountry) => ({
    ...originCountry,
    tasteNoteGroups: originCountry.coffees.reduce((stats, { tasteNotes }) => {
      tasteNotes.forEach(({ taste_note_id: tasteNoteId }) => {
        const { taste_note_group_id: tasteNoteGroupId } = getTasteNoteGroupByNoteId(tasteNoteId);

        if (!stats[tasteNoteGroupId]) {
          stats[tasteNoteGroupId] = 1;
        } else {
          stats[tasteNoteGroupId]++;
        }
      });

      return stats;
    }, {})
  }));
const tasteNoteGroupsLocale = tasteNoteGroups
  .filter(({ name, language_code: languageCode }) => languageCode === Astro.currentLocale && name !== 'other')
  .map(({ name, taste_note_group_id: tasteNoteGroupId, ...rest }) =>
    name.includes('/') ? { tasteNoteGroupId, name: name.split(' / ')[0], ...rest } : { tasteNoteGroupId, name, ...rest }
  )
  .map(({ tasteNoteGroupId, ...rest }) => ({
    ...rest,
    tasteNoteGroupId,
    originCountries: originCountriesWithCoffee
      .filter(({ tasteNoteGroups }) => tasteNoteGroups[tasteNoteGroupId])
      .map(({ origin_country_id, name, tasteNoteGroups }) => ({
        id: origin_country_id,
        name,
        count: tasteNoteGroups[tasteNoteGroupId]
      }))
      .sort((a, b) => b.count - a.count)
  }))
  .filter(({ originCountries }) => originCountries.length);
const maxTasteNoteGroupCount = tasteNoteGroupsLocale.reduce(
  (max, { originCountries }) => Math.max(max, originCountries[0].count),
  0
);

let backLink;
if (!brewingMethod?.name && !country?.name) {
  backLink = getRelativeLocaleUrl(Astro.currentLocale, `/origin-countries/${name}`);
} else if (brewingMethod?.name && country?.name) {
  backLink = getRelativeLocaleUrl(
    Astro.currentLocale,
    `/countries/${country.name}/origin-countries/${name}/brewing-methods/${brewingMethod.name}`
  );
} else if (brewingMethod?.name) {
  backLink = getRelativeLocaleUrl(
    Astro.currentLocale,
    `/origin-countries/${name}/brewing-methods/${brewingMethod.name}`
  );
} else if (country?.name) {
  backLink = getRelativeLocaleUrl(Astro.currentLocale, `/countries/${country.name}/origin-countries/${name}`);
}
---

<Common shouldAuthenticate={shouldAuthenticate}>
  <h1 class="title">
    <div>{name}</div>
    {
      loggedInUser && (
        <Button class="ghost small" href={backLink}>
          <Icon type="back" />
          <span class="visually-hidden">{t.back}</span>
        </Button>
      )
    }
  </h1>
  <section>
    <h2>{t.prices}</h2>
    <div class="card">
      <coffee-stats data-default-label={id}>
        <div class="stats">
          <div class="chart-inner">
            <div class="dots">
              {
                originCountriesWithCoffee.map(
                  ({ origin_country_id: originCountryId, name: originCountryName, coffees }) =>
                    coffees.map(({ pricePerGram, webshopItemLink }, coffeeIndex) => (
                      <a
                        class={`part dot ${originCountryId === id ? 'active' : ''}`}
                        style={`bottom: ${pricePerGram / (maxPricePerGram / 100)}%; left: ${coffeeIndex / (coffees.length / 100)}%`}
                        data-label={originCountryId}
                        aria-label={`${originCountryName}`}
                        href={webshopItemLink}
                        target="_blank"
                        rel="noopener noreferrer"
                      />
                    ))
                )
              }
            </div>
            <div class="labels">
              {
                originCountriesWithCoffee.map(({ origin_country_id: originCountryId, name: originCountryName }) => (
                  <Fragment>
                    <div class={`label x ${originCountryId === id ? 'active' : ''}`} data-part={originCountryId}>
                      {titleCase(originCountryName)}
                    </div>
                  </Fragment>
                ))
              }
            </div>
          </div>
        </div>
      </coffee-stats>
    </div>
  </section>
  <section>
    <h2>{t.tasteNotes}</h2>
    <div class="card">
      <coffee-stats>
        <div class="stats">
          <div class="chart-inner">
            <ul class="bars">
              {
                tasteNoteGroupsLocale.map(({ name, color, tasteNoteGroupId, originCountries }) => (
                  <li class="bar-container">
                    {originCountries.map(({ id: originCountryId, name: originCountryName, count }) => (
                      <div
                        class="part bar"
                        style={`height: ${count / (maxTasteNoteGroupCount / 100)}%`}
                        data-label={originCountryId}
                      />
                    ))}
                    <div class="bar-label" style={`color: ${color}`}>
                      {titleCase(name)}
                    </div>
                  </li>
                ))
              }
            </ul>
            <div class="labels">
              {
                tasteNoteGroupsLocale.map(({ name, color, tasteNoteGroupId, originCountries }) =>
                  originCountries.map(({ id: originCountryId, name: originCountryName, count }) => (
                    <div class="label x" data-part={originCountryId}>
                      {titleCase(originCountryName)}
                    </div>
                  ))
                )
              }
            </div>
          </div>
        </div>
      </coffee-stats>
    </div>
  </section>
</Common>

<script src="../stats/stats.js"></script>
