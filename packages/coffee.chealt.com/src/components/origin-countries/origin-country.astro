---
import originCountries from '../../../data/originCountries.json';
import originRegions from '../../../data/originRegions.json';
import allCoffees from '../../../data/coffees.json';

import { getConvertedPricePerGram } from '../coffees/utils.js';
import Coffees from '../coffees/list.astro';
import Common from '../common/common.astro';

import './origin-country.css';

import allLocaleTranslations from './locales.json';

const t = allLocaleTranslations[Astro.currentLocale];

const { id } = Astro.props;

const { name } = originCountries.find(
  ({ origin_country_id, language_code }) => origin_country_id === id && language_code === Astro.currentLocale
);
const regions = originRegions.filter(
  ({ origin_country_id, language_code }) => origin_country_id === id && language_code === Astro.currentLocale
);
const coffees = allCoffees.filter(({ origin_country_id }) => origin_country_id === id);
const priciestCoffees = coffees
  .sort(
    (a, b) =>
      getConvertedPricePerGram({ currency: b.currency, pricePerGram: b.price_per_gram }) -
      getConvertedPricePerGram({ currency: a.currency, pricePerGram: a.price_per_gram })
  )
  .slice(0, 10);
const cheapestCoffees = coffees
  .sort(
    (a, b) =>
      getConvertedPricePerGram({ currency: a.currency, pricePerGram: a.price_per_gram }) -
      getConvertedPricePerGram({ currency: b.currency, pricePerGram: b.price_per_gram })
  )
  .slice(0, 10);
---

<Common>
  <h1>{name}</h1>
  {
    (regions.length && (
      <section>
        <h2>{t.regions}</h2>
        <ul class="regions">
          {regions.map(({ origin_region_id, name }) => (
            <li>
              <h3>{name}</h3>
            </li>
          ))}
        </ul>
      </section>
    )) ||
      null
  }
  {
    (priciestCoffees.length && (
      <section>
        <h2>{t.priciestCoffees}</h2>
        <Coffees coffees={priciestCoffees} />
      </section>
    )) ||
      null
  }
  {
    (cheapestCoffees.length && (
      <section>
        <h2>{t.cheapestCoffees}</h2>
        <Coffees coffees={cheapestCoffees} />
      </section>
    )) ||
      null
  }
  {
    (coffees.length && (
      <section>
        <h2>{t.allCoffees}</h2>
        <Coffees coffees={coffees} />
      </section>
    )) ||
      null
  }
</Common>
