---
import { getRelativeLocaleUrl } from "astro:i18n";

import allCoffees from "../../../data/coffees.json" with { type: "json" };
import countries from "../../../data/countries.json" with { type: "json" };
import brewingMethods from "../../../data/brewingMethods.json" with { type: "json" };
import originCountries from "../../../data/originCountries.json" with { type: "json" };
import roasters from "../../../data/roasters.json" with { type: "json" };

import { convertToUSD } from "../coffees/utils.js";
import Button from "../form/button/button.astro";
import Coffees from "../coffees/list.astro";
import Common from "../common/common.astro";
import Dialog from "../dialog/dialog.astro";
import Icon from "../icon/icon.astro";
import { capitalize, encodeSafeURL } from "../../utils/string.js";
import { getSafeUrl } from "../utils/url.js";

import T from "@components/i18n/t.astro";
import { getTranslator } from "@components/i18n/t.js";

const t = await getTranslator({
  filePath: "origin-countries",
  locale: Astro.currentLocale,
});
const tc = await getTranslator({
  filePath: "common",
  locale: Astro.currentLocale,
});

const { loggedInUser } = Astro.locals;
const { id, brewingMethodId, countryId } = Astro.props;

const { name } = originCountries.find(
  ({ origin_country_id, language_code }) =>
    origin_country_id === id && language_code === Astro.currentLocale,
);
const country =
  countryId &&
  countries.find(
    ({ country_id, language_code }) =>
      country_id === countryId && language_code === Astro.currentLocale,
  );
const brewingMethod =
  brewingMethodId &&
  brewingMethods.find(
    ({ brewing_method_id, language_code }) =>
      brewing_method_id === brewingMethodId &&
      language_code === Astro.currentLocale,
  );
const coffees = allCoffees
  .filter(({ origin_country_id }) => origin_country_id === id)
  .filter(({ roaster_id: roasterId }) =>
    countryId
      ? roasters.find((roaster) => roaster.id === roasterId).country_id ===
        countryId
      : true,
  )
  .filter(({ brewing_method_id }) =>
    brewingMethodId ? brewing_method_id === brewingMethodId : true,
  );
const priciestCoffees = coffees
  .sort(
    (a, b) =>
      convertToUSD({ currency: b.currency, price: b.price_per_gram }) -
      convertToUSD({ currency: a.currency, price: a.price_per_gram }),
  )
  .slice(0, 10);
const cheapestCoffees = coffees
  .sort(
    (a, b) =>
      convertToUSD({ currency: a.currency, price: a.price_per_gram }) -
      convertToUSD({ currency: b.currency, price: b.price_per_gram }),
  )
  .slice(0, 10);

let statsLink;
if (!brewingMethod?.name && !country?.name) {
  statsLink = getRelativeLocaleUrl(
    Astro.currentLocale,
    `/origin-countries/${encodeSafeURL(name)}/stats`,
  );
} else if (brewingMethod?.name && country?.name) {
  statsLink = getRelativeLocaleUrl(
    Astro.currentLocale,
    `/countries/${encodeSafeURL(country.name)}/origin-countries/${encodeSafeURL(name)}/brewing-methods/${brewingMethod.name}/stats`,
  );
} else if (brewingMethod?.name) {
  statsLink = getRelativeLocaleUrl(
    Astro.currentLocale,
    `/origin-countries/${encodeSafeURL(name)}/brewing-methods/${brewingMethod.name}/stats`,
  );
} else if (country?.name) {
  statsLink = getRelativeLocaleUrl(
    Astro.currentLocale,
    `/countries/${encodeSafeURL(country.name)}/origin-countries/${encodeSafeURL(name)}/stats`,
  );
}
---

<Common title={`${t("title")} ${capitalize(name)}`}>
  <h1 class="title">
    <div>
      <span data-dialog-id="origin-country">{name}</span>
      {country?.name && <span> & {country.name}</span>}
      <Dialog class="drawer" id="origin-country">
        <ul>
          {
            originCountries
              .filter(
                ({ language_code, origin_country_id }) =>
                  language_code === Astro.currentLocale &&
                  origin_country_id !== id,
              )
              .map(({ origin_country_id, name }) => (
                <li>
                  <Button
                    href={getSafeUrl({
                      locale: Astro.currentLocale,
                      brewingMethod: brewingMethod?.name,
                      country: country?.name,
                      originCountry: name,
                    })}
                  >
                    {name}
                  </Button>
                </li>
              ))
          }
        </ul>
      </Dialog>
    </div>
    {
      loggedInUser && (
        <Button class="ghost small" href={statsLink}>
          <Icon type="chart" />
          <span class="visually-hidden"><T namespace="common.locales" key="chart">{tc("chart")}</T></span>
        </Button>
      )
    }
  </h1>
  {
    (priciestCoffees.length && (
      <section>
        <h2><T namespace="common.locales" key="priciestCoffees">{tc("priciestCoffees")}</T></h2>
        <Coffees coffees={priciestCoffees} />
      </section>
    )) ||
      null
  }
  {
    (cheapestCoffees.length && (
      <section>
        <h2><T namespace="common.locales" key="cheapestCoffees">{tc("cheapestCoffees")}</T></h2>
        <Coffees coffees={cheapestCoffees} />
      </section>
    )) ||
      null
  }
  {
    (coffees.length && (
      <section>
        <h2><T namespace="common.locales" key="allCoffees">{tc("allCoffees")}</T></h2>
        <Coffees coffees={coffees} />
      </section>
    )) ||
      null
  }
</Common>
