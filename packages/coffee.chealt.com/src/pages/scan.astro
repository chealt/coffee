---
import Button from "../components/button.astro";
import Common from "../components/common/common.astro";
import Dialog from "../components/dialog.astro";
import Roasters from "../components/scan/roasters.astro";

import "../components/scan/scan.css";
---

<Common>
  <h1>Add your coffee</h1>
  <coffee-gallery>
    <div class="loading-ocr">Loading OCR</div>
    <Roasters />
    <ul id="pictures"></ul>
    <coffee-scanner>
      <div id="controls">
        <Button id="open-camera" class="control">Camera</Button>
        <coffee-image-upload class="control">
          <Button>Upload</Button>
        </coffee-image-upload>
      </div>
      <Dialog>
        <dialog id="camera">
          <video id="video">Video stream not available.</video>
          <div id="capture-button-container">
            <Button id="capture-photo" aria-label="Take a photo" />
          </div>
          <canvas id="photo" class="visually-hidden"></canvas>
        </dialog>
      </Dialog>
    </coffee-scanner>
  </coffee-gallery>
</Common>

<script src="../components/scan/coffee-image-upload.js"></script>
<script src="../components/scan/coffee-gallery.js"></script>
<script src="../components/scan/coffee-scanner.js"></script>
