---
import Common from "../components/common/common.astro";
import Button from "../components/button.astro";

import "../components/scan/scan.css";
---

<Common>
  <h1>Add your coffee</h1>
  <coffee-gallery>
    <ul id="pictures"></ul>
    <Button id="open-camera">Use the camera</Button>
    <coffee-image-upload>
      <Button>Upload an image</Button>
    </coffee-image-upload>
    <div id="camera">
      <video id="video">Video stream not available.</video>
      <Button id="capture-photo">Take a photo</Button>
      <canvas id="photo"></canvas>
    </div>
  </coffee-gallery>
</Common>

<script src="../components/scan/coffee-image-upload.js"></script>
<script src="../components/scan/coffee-gallery.js"></script>
<script src="../components/scan/scan.js"></script>
