---
import FilteredListStats from '@components/coffees/filtered-list-stats.astro';
import brewingMethods from '@data/brewingMethods.json' with { type: 'json' };
import brewingMethodGroups from '@data/brewingMethodGroups.json' with { type: 'json' };
import countries from '@data/countries.json' with { type: 'json' };
import originCountries from '@data/originCountries.json' with { type: 'json' };
import processingMethods from '@data/processingMethods.json' with { type: 'json' };
import roasters from '@data/roasters.json' with { type: 'json' };
import tasteNotes from '@data/tasteNotes.json' with { type: 'json' };
import tasteNoteGroups from '@data/tasteNoteGroups.json' with { type: 'json' };
import varieties from '@data/varieties.json' with { type: 'json' };
import { decodeSafeURL } from '@utils/string.js';

const {
  brewingMethod,
  brewingMethodGroup,
  country,
  originCountry,
  processingMethod,
  roaster,
  tasteNote,
  tasteNoteGroup,
  variety
} = Astro.params;

const brewingMethodId =
  brewingMethod && brewingMethods.find(({ name }) => name === decodeSafeURL(brewingMethod))?.brewing_method_id;
const brewingMethodGroupId =
  brewingMethodGroup && brewingMethodGroups.find(({ name }) => name === decodeSafeURL(brewingMethodGroup))?.id;
const countryId = country && countries.find(({ name }) => name === decodeSafeURL(country))?.country_id;
const originCountryId =
  originCountry && originCountries.find(({ name }) => name === decodeSafeURL(originCountry))?.origin_country_id;
const processingMethodId =
  processingMethod &&
  processingMethods.find(
    ({ name }) => name === decodeSafeURL(processingMethod) || name === processingMethod.toLowerCase()
  )?.processing_method_id;
const roasterId = roaster && roasters.find(({ name }) => name === decodeSafeURL(roaster))?.id;
const tasteNoteId = tasteNote && tasteNotes.find(({ name }) => name === decodeSafeURL(tasteNote))?.taste_note_id;
const tasteNoteGroupId =
  tasteNoteGroup && tasteNoteGroups.find(({ name }) => name === decodeSafeURL(tasteNoteGroup))?.taste_note_group_id;
const varietyId = variety && varieties.find(({ name }) => name.toLowerCase() === variety)?.id;

Astro.response.headers.set('Cache-Control', 'public, max-age=86400');
---

<FilteredListStats
  brewingMethodId={brewingMethodId}
  brewingMethodGroupId={brewingMethodGroupId}
  countryId={countryId}
  originCountryId={originCountryId}
  processingMethodId={processingMethodId}
  roasterId={roasterId}
  tasteNoteGroupId={tasteNoteGroupId}
  tasteNoteId={tasteNoteId}
  varietyId={varietyId}
/>
