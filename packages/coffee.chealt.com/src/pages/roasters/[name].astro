---
export const prerender = false;

import Roaster from '../../components/roasters/roaster.astro';
import roasters from '../../../data/roasters.json';

const { name } = Astro.params;

const id = roasters.find((roaster) => roaster.name === name)?.id;

Astro.response.headers.set('Cache-Control', 'public, max-age=86400');
---

<Roaster id={id} />
