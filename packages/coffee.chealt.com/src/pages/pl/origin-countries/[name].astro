---
export const prerender = false;

import OriginCountry from '../../../components/origin-countries/origin-country.astro';
import originCountries from '../../../../data/originCountries.json';

const { name } = Astro.params;

const id = originCountries.find((country) => country.name === name)?.origin_country_id;
---

<OriginCountry id={id} />
