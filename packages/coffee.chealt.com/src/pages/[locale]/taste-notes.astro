---
export const partial = true;

import tasteNotes from "../../../data/tasteNotes.json" with { type: "json" };
import TasteNotes from "../../components/taste-notes/taste-notes.astro";

const { tasteNoteIds } = await Astro.request.json();

const selectedTasteNotes = tasteNotes.filter(
  ({ taste_note_id: id, language_code: languageCode }) =>
    tasteNoteIds.includes(String(id)) && languageCode === Astro.currentLocale,
);
---

{
  (selectedTasteNotes.length && (
    <TasteNotes tasteNotes={selectedTasteNotes} />
  )) ||
    null
}
