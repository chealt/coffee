---
import FilteredList from '@components/coffees/filtered-list.astro';
import brewingMethodGroups from '@data/brewingMethodGroups.json';
import { decodeSafeURL } from '@utils/string.js';

const { brewingMethodGroup } = Astro.params;

const id = brewingMethodGroups.find(({ name }) => name === decodeSafeURL(brewingMethodGroup))?.id;

Astro.response.headers.set('Cache-Control', 'public, max-age=86400');
---

<FilteredList brewingMethodGroupId={id} />
