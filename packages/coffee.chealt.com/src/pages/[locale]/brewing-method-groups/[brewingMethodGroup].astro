---
import BrewingMethodGroup from '../../../components/brewing-method-groups/brewing-method-group.astro';
import brewingMethodGroups from '../../../../data/brewingMethodGroups.json';

const { brewingMethodGroup } = Astro.params;

const id = brewingMethodGroups.find(({ name }) => name === brewingMethodGroup)?.id;

Astro.response.headers.set('Cache-Control', 'public, max-age=86400');
---

<BrewingMethodGroup id={id} />
