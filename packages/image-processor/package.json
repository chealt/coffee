{
  "name": "@centralbeans/image-processor",
  "type": "module",
  "scripts": {
    "build": "cp .yarnrc-lambda.yml .yarnrc.yml && yarn workspaces focus --production && zip -rq package.zip . -x .yarnrc.yml .yarnrc-lambda.yml && rm .yarnrc.yml",
    "deploy": "aws lambda update-function-code --function-name imageProcessor --zip-file fileb://package.zip --publish"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.978.0",
    "@aws-sdk/client-s3": "^3.978.0",
    "@aws-sdk/client-secrets-manager": "^3.978.0",
    "@aws-sdk/client-textract": "^3.978.0",
    "@libsql/client": "^0.17.0",
    "@sentry/aws-serverless": "^10.38.0",
    "sharp": "^0.34.5"
  }
}
