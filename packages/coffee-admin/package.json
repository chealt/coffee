{
  "name": "@chealt/coffee-admin",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && mkdir dist && mkdir dist/data && cp ../coffee.chealt.com/data/*.json dist/data && cp index.js dist && cp -r package.json dist && cp ../../yarn.lock dist && cp .yarnrc-lambda.yml dist/.yarnrc.yml && cp -r src dist && cd dist && yarn workspaces focus && rm -rf .yarn && rm -rf yarn.lock && rm -rf .yarnrc.yml && zip -rq package.zip .",
    "deploy": "aws lambda update-function-code --function-name coffeeAdmin --zip-file fileb://dist/package.zip --publish",
    "test": "yarn build && node --env-file=.env ./test.js",
    "users:send-registration-code": "node --env-file=.env src/users/send-registration-code.js",
    "coffees:import:CQI": "node --env-file=.env ../../node_modules/playwright/cli.js test",
    "coffees:import:varieties": "node --env-file=.env src/coffees/varieties.js",
    "currencies:import": "node --env-file=.env src/currencies/import.js",
    "images:migrate": "node --env-file=.env src/collection-item-images/migrate.js",
    "taste-notes:copy-i18n": "node --env-file=.env src/taste-notes/copy-i18n.js",
    "taste-notes:translate": "node --env-file=.env src/taste-notes/translate.js"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.962.0",
    "@aws-sdk/client-s3": "^3.962.0",
    "@aws-sdk/client-secrets-manager": "^3.962.0",
    "@aws-sdk/client-sesv2": "^3.962.0",
    "@aws-sdk/client-translate": "^3.962.0",
    "@libsql/client": "^0.15.15",
    "@playwright/test": "^1.57.0",
    "@sentry/aws-serverless": "^10.32.1",
    "@tursodatabase/api": "^1.9.2",
    "jsdom": "27.0.0",
    "jsonwebtoken": "^9.0.3",
    "undici": "^7.16.0"
  }
}
