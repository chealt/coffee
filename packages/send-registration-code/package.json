{
  "name": "@centralbeans/send-registration-code",
  "type": "module",
  "scripts": {
    "build": "cp .yarnrc-lambda.yml .yarnrc.yml && yarn workspaces focus --production && zip -rq package.zip . -x .yarnrc.yml .yarnrc-lambda.yml && rm .yarnrc.yml",
    "deploy": "aws lambda update-function-code --function-name sendRegistrationCode --zip-file fileb://package.zip --publish"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1073.0",
    "@aws-sdk/client-sesv2": "^3.1073.0",
    "@centralbeans/email": "workspace:^",
    "@libsql/client": "^0.17.4",
    "@sentry/aws-serverless": "^10.59.0",
    "@tursodatabase/api": "^2.0.4",
    "jsonwebtoken": "^9.0.3"
  }
}
