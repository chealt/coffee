{
  "name": "@centralbeans/invoke-flag-removed",
  "type": "module",
  "scripts": {
    "build": "cp .yarnrc-lambda.yml .yarnrc.yml && yarn workspaces focus --production && zip -rq package.zip . -x .yarnrc.yml .yarnrc-lambda.yml && rm .yarnrc.yml",
    "deploy": "aws lambda update-function-code --function-name invokeFlagRemoved --zip-file fileb://package.zip --publish"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.1086.0",
    "@aws-sdk/client-secrets-manager": "^3.1086.0",
    "@libsql/client": "^0.17.4",
    "@sentry/aws-serverless": "^10.65.0"
  }
}
