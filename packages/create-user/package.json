{
  "name": "@centralbeans/create-user",
  "type": "module",
  "scripts": {
    "build": "cp .yarnrc-lambda.yml .yarnrc.yml && yarn workspaces focus --production && zip -rq package.zip . -x .yarnrc.yml .yarnrc-lambda.yml && rm .yarnrc.yml",
    "deploy": "aws lambda update-function-code --function-name createUser --zip-file fileb://package.zip --publish"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.1061.0",
    "@aws-sdk/client-sesv2": "^3.1061.0",
    "@centralbeans/email": "workspace:^",
    "@libsql/client": "^0.17.3",
    "@sentry/aws-serverless": "^10.56.0",
    "@tursodatabase/api": "^2.0.2",
    "jsonwebtoken": "^9.0.3"
  }
}
