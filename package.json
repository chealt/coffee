{
  "name": "coffee",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "build": "yarn workspace @centralbeans/website build",
    "dev": "yarn workspace @centralbeans/website dev",
    "export:translations": "yarn workspace @centralbeans/website export:translations",
    "export:data": "yarn workspace @centralbeans/website export:data",
    "export:data:ci": "yarn workspace @centralbeans/website export:data:ci",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "recommendations:ci": "yarn workspace @centralbeans/website recommendations:ci"
  },
  "devDependencies": {
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "supports-color": "^10.2.2",
    "wrangler": "^4.101.0"
  },
  "resolutions": {
    "@asamuzakjp/css-color": "4.1.1"
  },
  "engines": {
    "node": "24"
  },
  "packageManager": "yarn@4.14.1"
}
