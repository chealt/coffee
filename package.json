{
  "name": "coffee",
  "packageManager": "yarn@4.9.4",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspace @chealt/coffee build",
    "dev": "yarn workspace @chealt/coffee dev",
    "lint": "eslint . --quiet",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/css": "^0.10.0",
    "eslint": "^9.34.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-plugin-astro": "^1.3.1",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^16.3.0",
    "prettier": "3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "supports-color": "^10.2.0"
  }
}
