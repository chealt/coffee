{
  "name": "coffee",
  "packageManager": "yarn@4.12.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "yarn workspace @chealt/coffee build",
    "dev": "yarn workspace @chealt/coffee dev",
    "lint": "eslint . --quiet",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/css": "^0.14.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.3.9",
    "eslint-plugin-astro": "^1.5.0",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.1.0",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-sql": "^0.19.2",
    "supports-color": "^10.2.2"
  }
}
