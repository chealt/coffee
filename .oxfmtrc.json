{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "ignorePatterns": [".yarn", "packages/coffee.chealt.com/data"],
  "semi": true,
  "singleQuote": true,
  "trailingComma": "none",
  "arrowParens": "always",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "bracketSpacing": true
}
